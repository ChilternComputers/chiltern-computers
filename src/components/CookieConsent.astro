---
// CookieConsent.astro - GDPR cookie consent banner with proper modal behavior
---

<div id="cookie-backdrop" class="cc-backdrop" aria-hidden="true"></div>
<div id="cookie-consent" role="dialog" aria-label="Cookie consent" class="cc-banner">
  <div class="cc-inner">
    <p class="cc-text">
      I use essential cookies to keep this site running. No tracking, no ads.
      <a href="/privacy-policy/" class="cc-link">Privacy Policy</a>
    </p>
    <div class="cc-buttons">
      <button id="cookie-accept" class="cc-btn cc-btn-accept">Accept</button>
      <button id="cookie-decline" class="cc-btn cc-btn-decline">Decline</button>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-consent');
  const backdrop = document.getElementById('cookie-backdrop');
  const acceptBtn = document.getElementById('cookie-accept');
  const declineBtn = document.getElementById('cookie-decline');
  const mainContent = document.getElementById('main-content');

  function showBanner() {
    if (!banner) return;
    banner.style.display = 'block';
    if (backdrop) backdrop.style.display = 'block';
    banner.setAttribute('aria-modal', 'true');
    if (mainContent) mainContent.setAttribute('inert', '');
    document.querySelector('header')?.setAttribute('inert', '');
    document.querySelector('footer')?.setAttribute('inert', '');
    requestAnimationFrame(() => acceptBtn?.focus());
  }

  function dismiss(value: string) {
    localStorage.setItem('cookie-consent', value);
    if (banner) {
      banner.style.display = 'none';
      banner.removeAttribute('aria-modal');
    }
    if (backdrop) backdrop.style.display = 'none';
    if (mainContent) mainContent.removeAttribute('inert');
    document.querySelector('header')?.removeAttribute('inert');
    document.querySelector('footer')?.removeAttribute('inert');
  }

  if (banner && !localStorage.getItem('cookie-consent')) {
    showBanner();
  }

  acceptBtn?.addEventListener('click', () => dismiss('accepted'));
  declineBtn?.addEventListener('click', () => dismiss('declined'));

  document.addEventListener('keydown', (e) => {
    if (banner?.style.display !== 'block') return;
    if (e.key === 'Escape') { dismiss('declined'); return; }
    if (e.key === 'Tab' && acceptBtn && declineBtn) {
      const focusable = [acceptBtn, declineBtn];
      if (e.shiftKey && document.activeElement === focusable[0]) {
        e.preventDefault(); focusable[focusable.length - 1].focus();
      } else if (!e.shiftKey && document.activeElement === focusable[focusable.length - 1]) {
        e.preventDefault(); focusable[0].focus();
      }
    }
  });
</script>

<style>
  .cc-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9998;
    background: rgba(2, 6, 23, 0.55);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    animation: cc-fade-in 0.35s ease-out both;
  }
  .cc-banner {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    padding: 20px 16px;
    background: linear-gradient(135deg, rgba(15,23,42,0.98), rgba(30,41,59,0.98));
    border-top: 2px solid rgba(6,182,212,0.6);
    backdrop-filter: blur(12px);
    box-shadow: 0 -18px 50px rgba(6,182,212,0.18);
    animation: cc-slide-up 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes cc-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes cc-slide-up {
    from { transform: translateY(110%); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  .cc-inner { max-width: 960px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .cc-text { color: var(--comet-silver); font-family: 'Exo 2', sans-serif; font-size: 14px; line-height: 1.6; margin: 0; flex: 1; min-width: 200px; }
  .cc-link { color: var(--plasma-cyan); text-decoration: underline; }
  .cc-buttons { display: flex; gap: 10px; flex-shrink: 0; }
  .cc-btn { padding: 12px 28px; border-radius: 8px; font-family: 'Orbitron', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; transition: transform 0.2s ease, box-shadow 0.2s ease; min-height: 44px; border: none; position: relative; }
  .cc-btn:hover { transform: translateY(-1px); }

  .cc-btn-accept {
    background: linear-gradient(45deg, var(--aurora-green), var(--plasma-cyan));
    color: #fff;
    box-shadow: 0 0 0 rgba(6,182,212,0);
    animation: cc-pulse 1.8s ease-in-out infinite;
  }
  .cc-btn-accept:hover {
    animation: none;
    box-shadow: 0 0 24px rgba(6,182,212,0.85), 0 0 48px rgba(34,197,94,0.45);
  }
  @keyframes cc-pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(6,182,212,0.7),
                  0 0 16px rgba(6,182,212,0.45),
                  0 0 32px rgba(34,197,94,0.25);
    }
    50% {
      box-shadow: 0 0 0 12px rgba(6,182,212,0),
                  0 0 28px rgba(6,182,212,0.85),
                  0 0 52px rgba(34,197,94,0.55);
    }
  }

  .cc-btn-decline { background: transparent; color: var(--comet-silver); border: 1px solid rgba(229,231,235,0.3); }
  .cc-btn-decline:hover { border-color: rgba(229,231,235,0.55); }

  @media (prefers-reduced-motion: reduce) {
    .cc-banner, .cc-backdrop, .cc-btn-accept { animation: none !important; }
  }
</style>
