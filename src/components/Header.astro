---
// Header.astro - Logo, Brand, Tabs, Call Now, Open - Each in Their Own Card
import { siteConfig } from '../config';
import Icon from './Icon.astro';
const currentPath = Astro.url.pathname;
const showWebDesign = siteConfig.showWebDesign;
---

<header class="hdr">
  <!-- Cosmic Background Effect -->
  <div class="hdr-bg" aria-hidden="true">
    <div class="hdr-bg-orb"></div>
  </div>

  <!-- Emergency Contact Bar — only visible when closed -->
  <div id="emergency-bar" class="hdr-emergency">
    <p class="tech-font hdr-emergency-text">
      <Icon name="alert" size={12} class="icon-inline-sm" style="color:var(--solar-orange);" />
      <span style="color:var(--aurora-green);">CLOSED — EMERGENCY REPAIRS?</span>
      Call <a href={`tel:${siteConfig.phone.mobile}`} class="hdr-emergency-link">{siteConfig.phone.mobileDisplay}</a>
    </p>
  </div>

  <div class="container hdr-container">
    <div class="header-toolbar">
      <!-- Logo -->
      <a href="/" class="hdr-logo-link" aria-label="Chiltern Computers — Home">
        <div class="cosmic-card hdr-logo-card">
          <img src="/logo.webp" alt="Chiltern Computers Logo" width="132" height="75" class="hdr-logo-img" />
        </div>
      </a>

      <!-- Mobile Menu Toggle -->
      <div class="mobile-menu-toggle">
        <button
          id="mobile-menu-btn"
          class="hdr-menu-btn"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="main-nav"
        >
          <span id="menu-text">Menu</span>
        </button>
      </div>

      <!-- Navigation -->
      <nav class="header-nav" id="main-nav" aria-label="Main navigation">
        <ul class="nav-list">
          <li><a href="/" class="nav-link hdr-nav-item" aria-label="Go to homepage" aria-current={currentPath === '/' ? 'page' : undefined}><Icon name="home" size={14} />Home</a></li>
          <li><a href="/services/custom-pcs/" class="nav-link hdr-nav-item hdr-nav-green" aria-label="Gaming PCs" aria-current={currentPath === '/services/custom-pcs/' ? 'page' : undefined}><Icon name="gaming" size={14} />Gaming PCs</a></li>
          <li><a href="/services/repairs/" class="nav-link hdr-nav-item hdr-nav-orange" aria-label="Repairs" aria-current={currentPath.startsWith('/services/repairs') ? 'page' : undefined}><Icon name="wrench" size={14} />Repairs</a></li>
          <li><a href="/services/new-used/" class="nav-link hdr-nav-item hdr-nav-purple" aria-label="PCs & Laptops" aria-current={currentPath === '/services/new-used/' ? 'page' : undefined}><Icon name="laptop" size={14} />PCs & Laptops</a></li>
          {showWebDesign && (
          <li><a href="/services/web-design/" class="nav-link hdr-nav-item" aria-label="Web Design" aria-current={currentPath === '/services/web-design/' ? 'page' : undefined}><Icon name="globe" size={14} />Web Design</a></li>
          )}
          <li><a href="/about/" class="nav-link hdr-nav-item" aria-label="About" aria-current={currentPath === '/about/' ? 'page' : undefined}><Icon name="info" size={14} />About</a></li>
          <li><a href="/blog/" class="nav-link hdr-nav-item" aria-label="Blog" aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}><Icon name="blog" size={14} />Blog</a></li>
          <li><a href="/book-repair/" class="nav-link hdr-nav-cta" aria-label="Book a repair" aria-current={currentPath === '/book-repair/' ? 'page' : undefined}><Icon name="wrench" size={14} />Book Repair</a></li>
        </ul>
      </nav>

      <!-- Contact Info -->
      <div class="hdr-contact-row">
        <a href="tel:+447971331814" class="cosmic-card hdr-phone-card" aria-label="Call Now 07971 331814">
          <div class="premium-glow-effect"></div>
          <Icon name="mobile" size={16} style="position:relative; z-index:2; color:var(--nebula-purple);" />
          <div style="position:relative; z-index:2;">
            <div class="tech-font hdr-label">CALL NOW</div>
            <div class="alien-font hdr-phone-num">07971 331814</div>
          </div>
        </a>
        <div class="cosmic-card hdr-hours-card">
          <div class="hdr-hours-inner">
            <Icon name="clock" size={14} style="color:var(--aurora-green);" />
            <div>
              <div class="tech-font hdr-label">OPEN</div>
              <div class="alien-font hdr-status" data-business-status aria-live="polite" aria-atomic="true">
                <span data-business-status-text>9AM - 9PM</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function updateAllBusinessStatus() {
      const hour = new Date().getHours();
      const isOpen = hour >= 9 && hour < 21;
      document.querySelectorAll('[data-business-status]').forEach(function(el) {
        const iconEl = el.querySelector('[data-business-status-icon]');
        const textEl = el.querySelector('[data-business-status-text]');
        if (textEl) textEl.textContent = isOpen ? 'OPEN NOW' : '9AM - 9PM';
        if (iconEl) iconEl.textContent = isOpen ? '✅' : '🌙';
        el.style.color = isOpen ? 'var(--aurora-green)' : 'var(--solar-orange)';
      });
      const emergencyBar = document.getElementById('emergency-bar');
      if (emergencyBar) emergencyBar.style.display = isOpen ? 'none' : 'block';
    }
    updateAllBusinessStatus();
    setInterval(updateAllBusinessStatus, 60000);

    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const headerNav = document.getElementById('main-nav');
    const mobileToggle = document.querySelector('.mobile-menu-toggle');
    const menuText = document.getElementById('menu-text');
    let mobileMenuOpen = false;

    function handleResize() {
      if (window.innerWidth <= 1100) {
        if (mobileToggle) mobileToggle.style.display = 'block';
        if (headerNav) headerNav.style.display = mobileMenuOpen ? 'flex' : 'none';
      } else {
        if (mobileToggle) mobileToggle.style.display = 'none';
        if (headerNav) headerNav.style.display = 'flex';
        mobileMenuOpen = false;
        if (menuText) menuText.textContent = 'Menu';
      }
    }
    window.addEventListener('resize', handleResize);
    handleResize();

    if (mobileMenuBtn && headerNav) {
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenuOpen = !mobileMenuOpen;
        headerNav.style.display = mobileMenuOpen ? 'flex' : 'none';
        mobileMenuBtn.setAttribute('aria-expanded', mobileMenuOpen.toString());
        mobileMenuBtn.setAttribute('aria-label', mobileMenuOpen ? 'Close navigation menu' : 'Open navigation menu');
        if (menuText) menuText.textContent = mobileMenuOpen ? 'Close' : 'Menu';
        if (mobileMenuOpen) {
          const firstLink = headerNav.querySelector('a');
          if (firstLink) requestAnimationFrame(() => firstLink.focus());
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileMenuOpen) {
          mobileMenuOpen = false;
          headerNav.style.display = 'none';
          mobileMenuBtn.setAttribute('aria-expanded', 'false');
          if (menuText) menuText.textContent = 'Menu';
          mobileMenuBtn.setAttribute('aria-label', 'Open navigation menu');
          mobileMenuBtn.focus();
        }
      });
    }
  </script>

  <style>
    /* Header shell */
    .hdr { position: relative; background: linear-gradient(135deg, rgba(15,23,42,0.95), rgba(30,41,59,0.9)); backdrop-filter: blur(20px); border-bottom: 2px solid rgba(6,182,212,0.3); z-index: 1000; }
    .hdr-container { position: relative; z-index: 2; padding: 16px 20px; }
    .header-toolbar { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }

    /* Cosmic bg */
    .hdr-bg { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
    .hdr-bg-orb { position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(6,182,212,0.1) 0%, transparent 70%); animation: orbit 20s linear infinite; }

    /* Emergency bar */
    .hdr-emergency { background: linear-gradient(45deg, rgba(220,38,38,0.15), rgba(245,158,11,0.15)); border-bottom: 1px solid rgba(220,38,38,0.3); padding: 8px; text-align: center; display: none; }
    .hdr-emergency-text { color: var(--solar-orange); font-size: 12px; margin: 0; font-weight: 600; position: relative; z-index: 2; }
    .hdr-emergency-link { color: var(--aurora-green); font-weight: bold; text-decoration: none; }

    /* Logo */
    .hdr-logo-link { text-decoration: none; }
    .hdr-logo-card { padding: 12px 16px; background: linear-gradient(145deg, rgba(248,250,252,0.95), rgba(226,232,240,0.9)); border-radius: 12px; display: flex; align-items: center; justify-content: center; min-width: 58px; position: relative; overflow: hidden; border: 2px solid rgba(6,182,212,0.4); box-shadow: 0 4px 20px rgba(6,182,212,0.3); }
    .hdr-logo-img { height: 75px; width: auto; display: block; position: relative; z-index: 2; }

    /* Mobile menu toggle */
    .mobile-menu-toggle { display: none; position: relative; }
    .hdr-menu-btn { padding: 10px 16px; font-size: 14px; border: 2px solid var(--plasma-cyan); background: rgba(6,182,212,0.1); color: var(--starlight-white); border-radius: 8px; font-weight: 600; transition: all 0.3s ease; min-height: 44px; min-width: 44px; cursor: pointer; font-family: inherit; }

    /* Nav */
    .header-nav { flex: 1 1 0; display: flex; justify-content: center; min-width: 210px; }
    .nav-list { list-style: none; padding: 0; margin: 0; display: flex; gap: 5px; justify-content: center; flex-wrap: nowrap; }
    .hdr-nav-item { padding: 10px 13px; font-size: 13px; text-decoration: none; white-space: nowrap; border: 1px solid var(--plasma-cyan); background: rgba(6,182,212,0.1); transition: all 0.3s ease; display: flex; align-items: center; gap: 6px; min-height: 44px; font-family: 'Orbitron', sans-serif; font-weight: 600; color: var(--starlight-white); border-radius: 25px; }
    .hdr-nav-green { border-color: var(--aurora-green); background: rgba(16,185,129,0.1); }
    .hdr-nav-orange { border-color: var(--solar-orange); background: rgba(245,158,11,0.1); }
    .hdr-nav-purple { border-color: var(--nebula-purple); background: rgba(139,92,246,0.1); }
    .hdr-nav-cta { padding: 10px 13px; font-size: 13px; text-decoration: none; white-space: nowrap; background: linear-gradient(45deg, var(--aurora-green), var(--plasma-cyan)); border: 2px solid var(--aurora-green); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; display: flex; align-items: center; gap: 6px; min-height: 44px; color: #fff; text-shadow: 0 1px 2px rgba(0,0,0,0.5); border-radius: 25px; font-family: 'Orbitron', sans-serif; }
    .hdr-nav-cta:hover { background: linear-gradient(45deg, #0d9668, #0891b2); }

    /* Nav hover/focus */
    .nav-link:hover, .nav-link:focus-visible { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(6,182,212,0.4); }
    .hdr-menu-btn:hover, .hdr-menu-btn:focus-visible { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(6,182,212,0.4); }

    /* Contact cards */
    .hdr-contact-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .hdr-phone-card { padding: 10px 16px; background: rgba(139,92,246,0.15); border: 2px solid var(--nebula-purple); border-radius: 10px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease; position: relative; overflow: hidden; min-height: 44px; }
    .hdr-phone-card:hover, .hdr-phone-card:focus-visible { transform: scale(1.05); }
    .hdr-phone-card:hover .premium-glow-effect, .hdr-phone-card:focus-visible .premium-glow-effect { opacity: 1; }
    .premium-glow-effect { position: absolute; inset: 0; background: linear-gradient(45deg, transparent, rgba(139,92,246,0.3), transparent); opacity: 0; transition: opacity 0.3s ease; }
    .hdr-hours-card { padding: 10px 16px; background: rgba(16,185,129,0.15); border: 2px solid var(--aurora-green); border-radius: 10px; }
    .hdr-hours-inner { display: flex; align-items: center; gap: 8px; }
    .hdr-label { color: var(--comet-silver); font-size: 12px; }
    .hdr-phone-num { color: var(--starlight-white); font-size: 14px; font-weight: 600; }
    .hdr-status { color: var(--aurora-green); font-size: 12px; font-weight: 600; }

    /* Responsive */
    @media (max-width: 1100px) {
      .header-toolbar { flex-direction: column; align-items: center; gap: 14px; }
      .header-nav { width: 100%; margin-top: 12px; display: none; }
      .hdr-logo-card { margin: 0 auto 8px; max-width: 215px; width: 100%; justify-content: center; }
      .mobile-menu-toggle { display: block; z-index: 10; align-self: center; margin: 8px auto 4px; text-align: center; }
      .nav-list { flex-direction: column; align-items: stretch; gap: 6px; }
      .nav-list li, .nav-list li a { width: 100%; justify-content: center; padding: 12px; }
      .header-nav[style*='display: flex'] { display: flex; flex-direction: column; align-items: stretch; }
      .hdr-contact-row { display: flex; justify-content: center; align-items: center; gap: 12px; width: 100%; flex-wrap: nowrap; }
    }
    @media (max-width: 768px) {
      .hdr-logo-card { max-width: 160px; }
      .hdr-contact-row { flex-wrap: nowrap; justify-content: center; gap: 8px; }
      .hdr-phone-card, .hdr-hours-card { padding: 8px 12px; font-size: 12px; }
    }
    @media (prefers-reduced-motion: reduce) {
      .hdr-bg-orb { animation: none; }
    }
  </style>
</header>
