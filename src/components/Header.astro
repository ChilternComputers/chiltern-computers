---
// Header.astro - Logo, Brand, Tabs, Call Now, Open - Each in Their Own Card
import { siteConfig } from '../config';
import Icon from './Icon.astro';
const currentPath = Astro.url.pathname;
const showWebDesign = siteConfig.showWebDesign;
---

<header
  class="cosmic-header"
  style="position:relative; background:linear-gradient(135deg,rgba(15,23,42,0.95),rgba(30,41,59,0.9)); backdrop-filter:blur(20px); border-bottom:2px solid rgba(6,182,212,0.3); z-index:1000;"
>
  <!-- Cosmic Background Effects -->
  <div
    class="header-cosmic-bg"
    style="position:absolute; top:0; left:0; right:0; bottom:0; overflow:hidden; pointer-events:none;"
  >
    <div
      style="position:absolute; top:-50%; left:-50%; width:200%; height:200%; background:radial-gradient(circle,rgba(6,182,212,0.1) 0%, transparent 70%); animation:orbit 20s linear infinite;"
    >
    </div>
  </div>

  <!-- Emergency Contact Bar — only visible when closed -->
  <div
    id="emergency-bar"
    style="background:linear-gradient(45deg,rgba(220,38,38,0.15),rgba(245,158,11,0.15)); border-bottom:1px solid rgba(220,38,38,0.3); padding:8px; text-align:center; display:none;"
  >
    <p
      class="tech-font"
      style="color:var(--solar-orange); font-size:12px; margin:0; font-weight:600; position:relative; z-index:2;"
    >
      <Icon name="alert" size={12} style="display:inline-block; vertical-align:-2px; color:var(--solar-orange);" /> <span style="color:var(--aurora-green);">CLOSED — EMERGENCY REPAIRS?</span>
      Call <a
        href={`tel:${siteConfig.phone.mobile}`}
        style="color:var(--aurora-green); font-weight:bold; text-decoration:none;"
        >{siteConfig.phone.mobileDisplay}</a
      >
    </p>
  </div>

  <div class="container" style="position:relative; z-index:2; padding:16px 20px;">
    <div
      class="header-toolbar"
      style="display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;"
    >
      <!-- Logo Image Card -->
      <a href="/" style="text-decoration:none;" aria-label="Chiltern Computers — Home">
        <div
          class="cosmic-card logo-image-card"
          style="padding:12px 16px; background:linear-gradient(145deg, rgba(248,250,252,0.95), rgba(226,232,240,0.9)); border-radius:12px; display:flex; align-items:center; justify-content:center; min-width:58px; position:relative; overflow:hidden; border:2px solid rgba(6,182,212,0.4); box-shadow:0 4px 20px rgba(6,182,212,0.3);"
        >
          <img
            src="/logo.webp"
            alt="Chiltern Computers Logo"
            width="264"
            height="150"
            style="height:75px; width:auto; display:block; position:relative; z-index:2;"
          />
        </div>
      </a>

      <!-- Mobile Menu Toggle (hidden desktop, shown mobile) -->
      <div class="mobile-menu-toggle" style="display:none; position:relative;">
        <button
          id="mobile-menu-btn"
          class="space-button"
          style="padding:10px 16px; font-size:14px; border:2px solid var(--plasma-cyan); background:rgba(6,182,212,0.1); color:var(--starlight-white); border-radius:8px; font-weight:600; transition:all 0.3s ease; min-height:44px; min-width:44px;"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="main-nav"
        >
          <span id="menu-text">Menu</span>
        </button>
      </div>

      <!-- Navigation Tabs (Center, hidden on mobile/tablet until toggled) -->
      <nav
        class="header-nav"
        id="main-nav"
        aria-label="Main navigation"
        style="flex:1 1 0; display:flex; justify-content:center; min-width:210px;"
      >
        <ul
          class="nav-list"
          style="list-style:none; padding:0; margin:0; display:flex; gap:5px; justify-content:center; flex-wrap:nowrap;"
        >
          <li>
            <a
              href="/"
              class="nav-link space-button"
              aria-label="Go to homepage"
              aria-current={currentPath === '/' ? 'page' : undefined}
              style="padding:10px 14px; font-size:12px; text-decoration:none; white-space:nowrap; border:1px solid var(--plasma-cyan); background:rgba(6,182,212,0.1); transition:all 0.3s ease; display:flex; align-items:center; gap:6px; min-height:44px;"
              ><Icon name="home" size={14} />Home</a
            >
          </li>
          <li>
            <a
              href="/services/custom-pcs/"
              class="nav-link space-button"
              aria-label="Gaming PCs - Custom gaming PC builds"
              aria-current={currentPath === '/services/custom-pcs/' ? 'page' : undefined}
              style="padding:10px 14px; font-size:12px; text-decoration:none; white-space:nowrap; border:1px solid var(--aurora-green); background:rgba(16,185,129,0.1); transition:all 0.3s ease; display:flex; align-items:center; gap:6px; min-height:44px;"
              ><Icon name="gaming" size={14} />Gaming PCs</a
            >
          </li>
          <li>
            <a
              href="/services/repairs/"
              class="nav-link space-button"
              aria-label="Repairs - Computer repair services"
              aria-current={currentPath.startsWith('/services/repairs') ? 'page' : undefined}
              style="padding:10px 14px; font-size:12px; text-decoration:none; white-space:nowrap; border:1px solid var(--solar-orange); background:rgba(245,158,11,0.1); transition:all 0.3s ease; display:flex; align-items:center; gap:6px; min-height:44px;"
              ><Icon name="wrench" size={14} />Repairs</a
            >
          </li>
          <li>
            <a
              href="/services/new-used/"
              class="nav-link space-button"
              aria-label="PCs & Laptops - New and refurbished computers"
              aria-current={currentPath === '/services/new-used/' ? 'page' : undefined}
              style="padding:10px 14px; font-size:12px; text-decoration:none; white-space:nowrap; border:1px solid var(--nebula-purple); background:rgba(139,92,246,0.1); transition:all 0.3s ease; display:flex; align-items:center; gap:6px; min-height:44px;"
              ><Icon name="laptop" size={14} />PCs & Laptops</a
            >
          </li>
          {showWebDesign && (
          <li>
            <a
              href="/services/web-design/"
              class="nav-link space-button"
              aria-label="Web Design - Professional websites from £299"
              aria-current={currentPath === '/services/web-design/' ? 'page' : undefined}
              style="padding:10px 14px; font-size:12px; text-decoration:none; white-space:nowrap; border:1px solid var(--plasma-cyan); background:rgba(6,182,212,0.1); transition:all 0.3s ease; display:flex; align-items:center; gap:6px; min-height:44px;"
              ><Icon name="globe" size={14} />Web Design</a
            >
          </li>
          )}
          <li>
            <a
              href="/about/"
              class="nav-link space-button"
              aria-label="About Chiltern Computers"
              aria-current={currentPath === '/about/' ? 'page' : undefined}
              style="padding:10px 14px; font-size:12px; text-decoration:none; white-space:nowrap; border:1px solid var(--plasma-cyan); background:rgba(6,182,212,0.1); transition:all 0.3s ease; display:flex; align-items:center; gap:6px; min-height:44px;"
              ><Icon name="info" size={14} />About</a
            >
          </li>
          <li>
            <a
              href="/blog/"
              class="nav-link space-button"
              aria-label="Computer repair tips and blog"
              aria-current={currentPath.startsWith('/blog') ? 'page' : undefined}
              style="padding:10px 14px; font-size:12px; text-decoration:none; white-space:nowrap; border:1px solid var(--plasma-cyan); background:rgba(6,182,212,0.1); transition:all 0.3s ease; display:flex; align-items:center; gap:6px; min-height:44px;"
              ><Icon name="blog" size={14} />Blog</a
            >
          </li>
          <li>
            <a
              href="/book-repair/"
              class="nav-link space-button cta-primary"
              aria-label="Book a computer repair"
              aria-current={currentPath === '/book-repair/' ? 'page' : undefined}
              style="padding:10px 14px; font-size:12px; text-decoration:none; white-space:nowrap; background:linear-gradient(45deg, var(--aurora-green), var(--plasma-cyan)) !important; border:2px solid var(--aurora-green); font-weight:600; text-transform:uppercase; letter-spacing:0.5px; display:flex; align-items:center; gap:6px; min-height:44px;"
              ><Icon name="wrench" size={14} />Book Repair</a
            >
          </li>
        </ul>
      </nav>

      <!-- Contact Info (Right) -->
      <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
        <a
          href="tel:+447971331814"
          class="cosmic-card contact-link-premium"
          aria-label="Call Now 07971 331814"
          style="padding:10px 16px; background:rgba(139,92,246,0.15); border:2px solid var(--nebula-purple); border-radius:10px; text-decoration:none; display:flex; align-items:center; gap:8px; transition:all 0.3s ease; position:relative; overflow:hidden; min-height:44px;"
        >
          <div
            class="premium-glow-effect"
            style="position:absolute; inset:0; background:linear-gradient(45deg, transparent, rgba(139,92,246,0.3), transparent); opacity:0; transition:opacity 0.3s ease;"
          >
          </div>
          <Icon name="mobile" size={16} style="position:relative; z-index:2; color:var(--nebula-purple);" />
          <div style="position:relative; z-index:2;">
            <div class="tech-font" style="color:var(--comet-silver); font-size:12px;">CALL NOW</div>
            <div
              class="alien-font"
              style="color:var(--starlight-white); font-size:13px; font-weight:600;"
            >
              07971 331814
            </div>
          </div>
        </a>
        <div
          class="cosmic-card"
          style="padding:10px 16px; background:rgba(16,185,129,0.15); border:2px solid var(--aurora-green); border-radius:10px;"
        >
          <div style="display:flex; align-items:center; gap:8px;">
            <Icon name="clock" size={14} style="color:var(--aurora-green);" />
            <div>
              <div class="tech-font" style="color:var(--comet-silver); font-size:12px;">OPEN</div>
              <div
                class="alien-font"
                style="color:var(--aurora-green); font-size:12px; font-weight:600;"
                data-business-status
                aria-live="polite"
                aria-atomic="true"
              >
                <span data-business-status-text>9AM - 9PM</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Business hours status — shared update logic
    function updateAllBusinessStatus() {
      const hour = new Date().getHours();
      const isOpen = hour >= 9 && hour < 21;
      document.querySelectorAll('[data-business-status]').forEach(function(el) {
        const iconEl = el.querySelector('[data-business-status-icon]');
        const textEl = el.querySelector('[data-business-status-text]');
        if (textEl) textEl.textContent = isOpen ? 'OPEN NOW' : '9AM - 9PM';
        if (iconEl) iconEl.textContent = isOpen ? '✅' : '🌙';
        el.style.color = isOpen ? 'var(--aurora-green)' : 'var(--solar-orange)';
      });
      // Show/hide emergency bar based on business hours
      const emergencyBar = document.getElementById('emergency-bar');
      if (emergencyBar) {
        emergencyBar.style.display = isOpen ? 'none' : 'block';
      }
    }
    updateAllBusinessStatus();
    setInterval(updateAllBusinessStatus, 60000);

    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const headerNav = document.getElementById('main-nav');
    const mobileToggle = document.querySelector('.mobile-menu-toggle');
    const menuText = document.getElementById('menu-text');
    let mobileMenuOpen = false;

    function handleResize() {
      if (window.innerWidth <= 1100) {
        if (mobileToggle) mobileToggle.style.display = 'block';
        if (headerNav) headerNav.style.display = mobileMenuOpen ? 'flex' : 'none';
      } else {
        if (mobileToggle) mobileToggle.style.display = 'none';
        if (headerNav) headerNav.style.display = 'flex';
        mobileMenuOpen = false;
        if (menuText) menuText.textContent = 'Menu';
      }
    }
    window.addEventListener('resize', handleResize);
    handleResize();

    if (mobileMenuBtn && headerNav) {
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenuOpen = !mobileMenuOpen;
        headerNav.style.display = mobileMenuOpen ? 'flex' : 'none';
        mobileMenuBtn.setAttribute('aria-expanded', mobileMenuOpen.toString());
        mobileMenuBtn.setAttribute('aria-label', mobileMenuOpen ? 'Close navigation menu' : 'Open navigation menu');
        if (menuText) {
          menuText.textContent = mobileMenuOpen ? 'Close' : 'Menu';
        }
        // Focus first nav link when menu opens
        if (mobileMenuOpen) {
          const firstLink = headerNav.querySelector('a');
          if (firstLink) requestAnimationFrame(() => firstLink.focus());
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && mobileMenuOpen) {
          mobileMenuOpen = false;
          headerNav.style.display = 'none';
          mobileMenuBtn.setAttribute('aria-expanded', 'false');
          if (menuText) menuText.textContent = 'Menu';
          mobileMenuBtn.setAttribute('aria-label', 'Open navigation menu');
          mobileMenuBtn.focus();
        }
      });
    }
  </script>

  <style>
    .nav-link:hover, .nav-link:focus-visible {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(6, 182, 212, 0.4);
    }
    #mobile-menu-btn:hover, #mobile-menu-btn:focus-visible {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(6, 182, 212, 0.4);
    }
    .contact-link-premium:hover, .contact-link-premium:focus-visible {
      transform: scale(1.05);
    }
    .contact-link-premium:hover .premium-glow-effect,
    .contact-link-premium:focus-visible .premium-glow-effect {
      opacity: 1;
    }
    .cosmic-glow {
      text-shadow:
        0 0 10px currentColor,
        0 0 20px currentColor,
        0 0 30px currentColor;
    }
    .cta-primary {
      color: #ffffff !important;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
    }
    .cta-primary:hover {
      background: linear-gradient(45deg, #0d9668, #0891b2) !important;
      color: #ffffff !important;
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.7);
    }
    @media (max-width: 1100px) {
      .header-toolbar {
        flex-direction: column !important;
        align-items: center !important;
        gap: 14px !important;
      }
      .header-nav {
        width: 100% !important;
        margin-top: 12px !important;
        display: none !important;
      }
      .logo-image-card,
      .brand-name-card {
        margin: 0 auto 8px auto !important;
        max-width: 215px !important;
        width: 100% !important;
        justify-content: center !important;
      }
      .mobile-menu-toggle {
        display: block !important;
        z-index: 10;
        align-self: center !important;
        margin: 8px auto 4px auto !important;
        text-align: center !important;
      }
      .nav-list {
        flex-direction: column !important;
        align-items: stretch !important;
        gap: 6px !important;
      }
      .nav-list li,
      .nav-list li a {
        width: 100% !important;
        justify-content: center !important;
        padding: 12px !important;
      }
      .header-nav[style*='display: flex'] {
        display: flex !important;
        flex-direction: column !important;
        align-items: stretch !important;
      }
      .header-toolbar > div:last-child {
        display: flex !important;
        justify-content: center !important;
        align-items: center !important;
        gap: 12px !important;
        width: 100% !important;
        flex-wrap: nowrap !important;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .header-cosmic-bg * { animation: none; }
    }
    @media (max-width: 768px) {
      .logo-image-card,
      .brand-name-card {
        max-width: 160px !important;
      }
      .header-toolbar > div:last-child {
        flex-wrap: nowrap !important;
        justify-content: center !important;
        gap: 8px !important;
      }
      .contact-link-premium,
      .cosmic-card {
        padding: 8px 12px !important;
        font-size: 12px !important;
      }
    }
  </style>
</header>
