---
// Footer.astro - Clean & Optimized Production Version
import { siteConfig } from '../config';
import Icon from './Icon.astro';
const currentYear = new Date().getFullYear();
---

<footer class="section-bg-5 ftr" role="contentinfo">
  <!-- Quick Contact Strip -->
  <div class="ftr-contact-strip">
    <p class="tech-font ftr-contact-text">
      <Icon name="phone" size={12} class="icon-inline-sm" />
      Need help? Call <a href={`tel:${siteConfig.phone.mobile}`} class="ftr-contact-link">{siteConfig.phone.mobileDisplay}</a>
      — Open {siteConfig.hours.display}
    </p>
  </div>

  <div class="container ftr-main">
    <!-- Service Areas Ticker -->
    <div class="footer-grid">
      <div class="cosmic-card ftr-ticker-card">
        <a href="/areas/" class="ftr-areas-link">
          <h3 class="space-font cosmic-glow ftr-areas-heading">
            <Icon name="map-pin" size={18} />
            Service Areas
            <span class="ftr-arrow">→</span>
          </h3>
        </a>

        <div class="scroll-container enhanced-ticker" tabindex="0" role="region" aria-label="Service areas I cover">
          <div class="scroll-content">
            <span class="service-area-primary">Harold Hill</span>
            <span class="service-area">Romford</span>
            <span class="service-area-primary">Harold Wood</span>
            <span class="service-area">Hornchurch</span>
            <span class="service-area-primary">Collier Row</span>
            <span class="service-area">Dagenham</span>
            <span class="service-area-primary">Rainham</span>
            <span class="service-area">Brentwood</span>
            <span class="service-area-primary">Gidea Park</span>
            <span class="service-area">Emerson Park</span>
            <span class="service-area-primary">Chadwell Heath</span>
            <span class="service-area">Upminster</span>
            <span class="service-area-primary">Cranham</span>
            <span class="service-area">Elm Park</span>
            <span class="service-area-primary">Pilgrims Hatch</span>
            <span class="service-area">Hainault</span>
            <span class="service-area-primary">Rush Green</span>
            <span class="service-area">Ardleigh Green</span>
            <span class="service-area-primary">Warley</span>
          </div>
        </div>

        <div class="ftr-coverage-text">
          <p class="tech-font ftr-coverage-label">
            <Icon name="map-pin" size={12} class="icon-inline-sm" /> SERVICE COVERAGE ACROSS HAVERING & ESSEX
          </p>
        </div>
      </div>
    </div>

    <!-- Main Footer Grid -->
    <div class="footer-grid">
      <!-- Services -->
      <div class="cosmic-card card-pad">
        <h3 class="space-font cosmic-glow ftr-section-heading ftr-heading-green">
          <Icon name="rocket" size={18} />Services
        </h3>
        <ul class="list-none">
          <li class="mb-12"><a href="/services/repairs/" class="alien-font footer-link"><Icon name="wrench" size={14} class="ftr-icon" />Computer Repairs</a></li>
          <li class="mb-12"><a href="/services/custom-pcs/" class="alien-font footer-link"><Icon name="gaming" size={14} class="ftr-icon" />Custom Gaming PCs</a></li>
          <li class="mb-12"><a href="/services/new-used/" class="alien-font footer-link"><Icon name="laptop" size={14} class="ftr-icon" />New & Refurb PCs</a></li>
          <li class="mb-12"><a href="/services/virus-removal-romford/" class="alien-font footer-link"><Icon name="shield" size={14} class="ftr-icon" />Virus Removal</a></li>
          <li class="mb-12"><a href="/services/data-recovery-havering/" class="alien-font footer-link"><Icon name="database" size={14} class="ftr-icon" />Data Recovery</a></li>
          <li class="mb-12"><a href="/services/mac-repair-romford/" class="alien-font footer-link"><Icon name="apple" size={14} class="ftr-icon" />Mac Repair</a></li>
          <li class="mb-12"><a href="/services/network-wifi-romford/" class="alien-font footer-link"><Icon name="wifi" size={14} class="ftr-icon" />Network & WiFi</a></li>
          <li class="mb-12"><a href="/services/computer-upgrades-romford/" class="alien-font footer-link"><Icon name="bolt" size={14} class="ftr-icon" />Computer Upgrades</a></li>
          <li class="mb-12"><a href="/pricing/" class="alien-font footer-link"><Icon name="bolt" size={14} class="ftr-icon" />Pricing</a></li>
          <li class="mb-12"><a href="/faq/" class="alien-font footer-link"><Icon name="chat" size={14} class="ftr-icon" />FAQ</a></li>
          <li class="mb-12"><a href="/about/" class="alien-font footer-link"><Icon name="info" size={14} class="ftr-icon" />About Me</a></li>
          <li class="mb-12"><a href="/blog/" class="alien-font footer-link"><Icon name="blog" size={14} class="ftr-icon" />Blog & Tips</a></li>
          <li><a href="/contact/" class="alien-font footer-link"><Icon name="phone" size={14} class="ftr-icon" />Contact</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="cosmic-card ftr-contact-card">
        <h3 class="space-font cosmic-glow ftr-section-heading ftr-heading-purple ftr-z2">
          <Icon name="phone" size={18} />Contact
        </h3>

        <ul class="list-none ftr-z2">
          <li class="mb-16">
            <a href={`tel:${siteConfig.phone.mobile}`} class="alien-font contact-link">
              <Icon name="mobile" size={16} />
              <div><div class="ftr-sublabel">Mobile</div><div class="ftr-value">{siteConfig.phone.mobileDisplay}</div></div>
            </a>
          </li>
          <li class="mb-16">
            <a href={`tel:${siteConfig.phone.landline}`} class="alien-font contact-link">
              <Icon name="landline" size={16} />
              <div><div class="ftr-sublabel">Landline</div><div class="ftr-value">{siteConfig.phone.landlineDisplay}</div></div>
            </a>
          </li>
          <li class="mb-16">
            <a href={`mailto:${siteConfig.email}`} class="alien-font contact-link">
              <Icon name="email" size={16} />
              <div><div class="ftr-sublabel">Email</div><div class="ftr-value">{siteConfig.email}</div></div>
            </a>
          </li>
        </ul>

        <!-- Operating Hours -->
        <div class="ftr-hours-wrap ftr-z2">
          <div class="ftr-hours-box">
            <div class="ftr-hours-header">
              <Icon name="clock" size={14} />
              <span class="tech-font ftr-hours-label">HOURS</span>
            </div>
            <div class="ftr-hours-row">
              <span class="alien-font ftr-hours-day">Mon - Sun</span>
              <span class="alien-font ftr-hours-time">9AM - 9PM</span>
            </div>
            <div class="ftr-hours-status">
              <span class="tech-font ftr-status-text" data-business-status aria-live="polite" aria-atomic="true">
                <span aria-hidden="true" data-business-status-icon>✅</span> <span data-business-status-text>Available Now</span>
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- Location & Site Info -->
      <div class="cosmic-card card-pad">
        <h3 class="space-font cosmic-glow ftr-section-heading ftr-heading-orange">
          <Icon name="map-pin" size={18} />Location
        </h3>

        <div class="mb-24">
          <div class="ftr-address-row">
            <Icon name="map-pin" size={16} class="ftr-icon-orange" />
            <address class="alien-font ftr-address">
              {siteConfig.address.street}<br />
              {siteConfig.address.locality}, {siteConfig.address.city}<br />
              {siteConfig.address.region}, {siteConfig.address.postcode}
            </address>
          </div>
          <div class="ftr-map-btn-wrap">
            <a
              href="https://www.google.com/maps/search/Chiltern+Computers+38+Hilldene+Avenue+Harold+Hill+Romford+RM3+8YP"
              target="_blank"
              rel="noopener noreferrer"
              class="space-button ftr-map-btn"
            >
              <Icon name="map" size={14} />View Map
            </a>
          </div>
        </div>

        <div>
          <h4 class="space-font ftr-site-heading">Site Info</h4>
          <ul class="list-none">
            <li class="mb-8"><a href="/sitemap.xml" class="alien-font footer-link-sm" target="_blank" rel="noopener noreferrer"><Icon name="map" size={13} class="ftr-icon-orange" /><span>Sitemap</span><span class="ftr-xml-badge">XML</span></a></li>
            <li class="mb-8"><a href="/privacy-policy/" class="alien-font footer-link-sm"><Icon name="lock" size={13} class="ftr-icon-orange" />Privacy Policy</a></li>
            <li class="mb-8"><a href="/terms-of-service/" class="alien-font footer-link-sm"><Icon name="clipboard" size={13} class="ftr-icon-orange" />Terms of Service</a></li>
            <li class="mb-8"><a href="/accessibility/" class="alien-font footer-link-sm"><Icon name="accessibility" size={13} class="ftr-icon-orange" />Accessibility</a></li>
            <li><a href="/free-play/" class="alien-font footer-link-sm"><Icon name="gaming" size={13} class="ftr-icon-orange" />Free Play</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- CTA Buttons -->
    <div class="cta-row mb-32">
      <a href="/contact/" class="space-button ftr-cta-primary" aria-label="Get Quote"><Icon name="chat" size={14} /> Get Quote</a>
      <a href={`tel:${siteConfig.phone.mobile}`} class="space-button ftr-cta-secondary" aria-label="Call Now"><Icon name="mobile" size={14} /> Call Now</a>
      <a href="/services/repairs/" class="space-button ftr-cta-tertiary" aria-label="Book Repair"><Icon name="wrench" size={14} /> Book Repair</a>
    </div>
  </div>

  <!-- Copyright -->
  <div class="ftr-copyright-wrap">
    <div class="cosmic-card ftr-copyright-card">
      <div class="ftr-copyright-inner">
        <!-- Trust Signals -->
        <div class="ftr-trust-row">
          <span class="trust-badge ftr-trust-google"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"></path><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"></path><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"></path><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"></path></svg>Google Reviewed</span>
          <span class="trust-badge ftr-trust-fb"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path></svg>Facebook Rated</span>
          <span class="trust-badge ftr-trust-est">✓ Est. 2007</span>
          <span class="trust-badge ftr-trust-rating"><Icon name="star" size={11} /> 5/5 Rating</span>
        </div>

        <!-- Copyright Text -->
        <div class="ftr-copy-text">
          <div class="ftr-copy-line">
            <Icon name="rocket" size={16} style="color: var(--plasma-cyan);" />
            <span class="tech-font ftr-copy-label">© <span id="current-year">{currentYear}</span> Chiltern Computers</span>
          </div>
          <span class="tech-font ftr-copy-sub">All rights reserved</span>
        </div>

        <!-- Feature Badges -->
        <div class="ftr-badge-row">
          <span class="feature-pill"><Icon name="bolt" size={10} /> Fast</span>
          <span class="feature-pill"><Icon name="lock" size={10} /> Secure</span>
          <span class="feature-pill"><Icon name="mobile" size={10} /> Responsive</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    const currentYear = new Date().getFullYear();
    const yearElement = document.getElementById('current-year');
    if (yearElement) yearElement.textContent = String(currentYear);
  </script>

  <style>
    .ftr { padding: 60px 0 0; position: relative; margin: 0; }
    .ftr-main { padding-top: 40px; }

    /* Contact strip */
    .ftr-contact-strip { background: rgba(16,185,129,0.1); border-bottom: 1px solid rgba(16,185,129,0.3); padding: 10px; text-align: center; }
    .ftr-contact-text { color: var(--aurora-green); font-size: 12px; margin: 0; font-weight: 600; }
    .ftr-contact-link { color: var(--plasma-cyan); font-weight: bold; text-decoration: none; }

    /* Ticker card */
    .ftr-ticker-card { padding: 20px; grid-column: 1 / -1; position: relative; overflow: hidden; }
    .ftr-areas-link { text-decoration: none; }
    .ftr-areas-heading { color: var(--plasma-cyan); font-size: 18px; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; text-align: center; justify-content: center; position: relative; z-index: 2; }
    .ftr-arrow { font-size: 12px; }
    .ftr-coverage-text { text-align: center; margin-top: 12px; position: relative; z-index: 2; }
    .ftr-coverage-label { color: var(--plasma-cyan); font-size: 12px; font-weight: 500; }

    /* Section headings */
    .ftr-section-heading { font-size: 18px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
    .ftr-heading-green { color: var(--aurora-green); }
    .ftr-heading-purple { color: var(--nebula-purple); }
    .ftr-heading-orange { color: var(--solar-orange); }
    .ftr-z2 { position: relative; z-index: 2; }
    .ftr-icon { color: var(--plasma-cyan); }
    .ftr-icon-orange { color: var(--solar-orange); flex-shrink: 0; }

    /* Contact card */
    .ftr-contact-card { padding: 24px; border: 2px solid var(--nebula-purple); box-shadow: 0 8px 25px rgba(124,58,237,0.4); position: relative; }
    .ftr-sublabel { font-size: 12px; color: var(--comet-silver); }
    .ftr-value { font-weight: 600; }

    /* Hours box */
    .ftr-hours-wrap { display: flex; justify-content: center; margin-top: 20px; }
    .ftr-hours-box { background: rgba(139,92,246,0.2); border: 2px solid var(--nebula-purple); border-radius: 12px; padding: 16px; max-width: 200px; width: 100%; box-shadow: 0 4px 15px rgba(139,92,246,0.3); }
    .ftr-hours-header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; justify-content: center; }
    .ftr-hours-label { color: var(--nebula-purple); font-size: 12px; font-weight: 600; }
    .ftr-hours-row { display: flex; justify-content: space-between; align-items: center; }
    .ftr-hours-day { color: var(--starlight-white); font-size: 14px; font-weight: 500; }
    .ftr-hours-time { color: var(--aurora-green); font-size: 14px; font-weight: 600; }
    .ftr-hours-status { text-align: center; margin-top: 8px; padding-top: 8px; border-top: 1px solid rgba(139,92,246,0.3); }
    .ftr-status-text { color: var(--aurora-green); font-size: 12px; font-weight: 500; }

    /* Address */
    .ftr-address-row { display: flex; align-items: start; gap: 12px; margin-bottom: 12px; }
    .ftr-address { color: var(--starlight-white); font-size: 14px; font-style: normal; line-height: 1.4; font-weight: 500; }
    .ftr-map-btn-wrap { text-align: left; margin-top: 16px; }
    .ftr-map-btn { font-size: 12px; padding: 10px 18px; text-decoration: none; }
    .ftr-site-heading { color: var(--comet-silver); font-size: 14px; margin-bottom: 12px; font-weight: 600; }
    .ftr-xml-badge { background: rgba(245,158,11,0.2); color: var(--solar-orange); padding: 2px 6px; border-radius: 4px; font-size: 12px; font-weight: 600; }

    /* CTAs */
    .ftr-cta-primary { font-size: 12px; padding: 12px 24px; background: linear-gradient(45deg, var(--aurora-green), var(--plasma-cyan)); border: 2px solid var(--aurora-green); font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; display: flex; align-items: center; justify-content: center; color: #fff; text-shadow: 0 1px 2px rgba(0,0,0,0.5); }
    .ftr-cta-primary:hover { background: linear-gradient(45deg, #0d9668, #0891b2); }
    .ftr-cta-secondary { font-size: 12px; padding: 12px 24px; border: 2px solid var(--solar-orange); font-weight: 600; display: flex; align-items: center; justify-content: center; }
    .ftr-cta-tertiary { font-size: 12px; padding: 12px 24px; border: 2px solid var(--nebula-purple); font-weight: 600; display: flex; align-items: center; justify-content: center; }

    /* Copyright */
    .ftr-copyright-wrap { padding: 32px 20px; margin: 0; width: 100%; display: flex; justify-content: center; align-items: center; }
    .ftr-copyright-card { padding: 24px; max-width: 600px; margin: 0; width: 100%; text-align: center; position: relative; overflow: hidden; }
    .ftr-copyright-inner { display: flex; flex-direction: column; gap: 16px; align-items: center; position: relative; z-index: 2; }
    .ftr-trust-row { display: flex; gap: 10px; justify-content: center; margin-bottom: 12px; flex-wrap: wrap; }
    .ftr-trust-google { background: rgba(66,133,244,0.2); border: 1px solid #4285f4; color: #4285f4; }
    .ftr-trust-fb { background: rgba(24,119,242,0.2); border: 1px solid #1877f2; color: #1877f2; }
    .ftr-trust-est { background: rgba(16,185,129,0.2); border: 1px solid var(--aurora-green); color: var(--aurora-green); }
    .ftr-trust-rating { background: rgba(245,158,11,0.2); border: 1px solid var(--solar-orange); color: var(--solar-orange); }
    .ftr-copy-text { display: flex; flex-direction: column; align-items: center; gap: 4px; }
    .ftr-copy-line { display: flex; align-items: center; gap: 8px; justify-content: center; flex-wrap: wrap; }
    .ftr-copy-label { color: var(--comet-silver); font-size: 12px; text-align: center; font-weight: 600; }
    .ftr-copy-sub { color: var(--comet-silver); font-size: 12px; text-align: center; }
    .ftr-badge-row { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; margin-top: 8px; }

    @media (prefers-reduced-motion: reduce) {
      .cosmic-bg-animation, .premium-glow-effect, .copyright-bg-effect { animation: none; }
    }
  </style>
</footer>
