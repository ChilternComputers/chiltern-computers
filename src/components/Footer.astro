---
// Footer.astro - Clean & Optimized Production Version
import { siteConfig } from '../config';
import Icon from './Icon.astro';
const currentYear = new Date().getFullYear();
---

<footer class="section-bg-5 ftr" role="contentinfo">
  <!-- Quick Contact Strip -->
  <div class="ftr-contact-strip">
    <p class="tech-font ftr-contact-text">
      <Icon name="phone" size={12} class="icon-inline-sm" />
      Need help? Call <a href={`tel:${siteConfig.phone.mobile}`} class="ftr-contact-link">{siteConfig.phone.mobileDisplay}</a>
      — Open {siteConfig.hours.display}
    </p>
  </div>

  <div class="container ftr-main">
    <!-- Service Areas Ticker -->
    <div class="footer-grid">
      <div class="cosmic-card ftr-ticker-card">
        <a href="/areas/" class="ftr-areas-link">
          <h3 class="space-font cosmic-glow ftr-areas-heading">
            <Icon name="map-pin" size={18} />
            Service Areas
            <span class="ftr-arrow">→</span>
          </h3>
        </a>

        <div class="scroll-container enhanced-ticker" tabindex="0" role="region" aria-label="Service areas I cover">
          <div class="scroll-content">
            <span class="service-area-primary">Harold Hill</span>
            <span class="service-area">Romford</span>
            <span class="service-area-primary">Harold Wood</span>
            <span class="service-area">Hornchurch</span>
            <span class="service-area-primary">Collier Row</span>
            <span class="service-area">Dagenham</span>
            <span class="service-area-primary">Rainham</span>
            <span class="service-area">Brentwood</span>
            <span class="service-area-primary">Gidea Park</span>
            <span class="service-area">Emerson Park</span>
            <span class="service-area-primary">Chadwell Heath</span>
            <span class="service-area">Upminster</span>
            <span class="service-area-primary">Cranham</span>
            <span class="service-area">Elm Park</span>
            <span class="service-area-primary">Pilgrims Hatch</span>
            <span class="service-area">Hainault</span>
            <span class="service-area-primary">Rush Green</span>
            <span class="service-area">Ardleigh Green</span>
            <span class="service-area-primary">Warley</span>
          </div>
        </div>

        <div class="ftr-coverage-text">
          <p class="tech-font ftr-coverage-label">
            <Icon name="map-pin" size={12} class="icon-inline-sm" /> SERVICE COVERAGE ACROSS HAVERING & ESSEX
          </p>
        </div>
      </div>
    </div>

    <!-- Main Footer Grid -->
    <div class="footer-grid">
      <!-- Services -->
      <div class="cosmic-card card-pad">
        <h3 class="space-font cosmic-glow ftr-section-heading ftr-heading-green">
          <Icon name="rocket" size={18} />Services
        </h3>
        <ul class="list-none">
          <li class="mb-12"><a href="/services/repairs/" class="alien-font footer-link"><Icon name="wrench" size={14} class="ftr-icon" />Computer Repairs</a></li>
          <li class="mb-12"><a href="/services/custom-pcs/" class="alien-font footer-link"><Icon name="gaming" size={14} class="ftr-icon" />Custom Gaming PCs</a></li>
          <li class="mb-12"><a href="/services/new-used/" class="alien-font footer-link"><Icon name="laptop" size={14} class="ftr-icon" />New & Refurb PCs</a></li>
          <li class="mb-12"><a href="/services/virus-removal-romford/" class="alien-font footer-link"><Icon name="shield" size={14} class="ftr-icon" />Virus Removal</a></li>
          <li class="mb-12"><a href="/services/data-recovery-havering/" class="alien-font footer-link"><Icon name="database" size={14} class="ftr-icon" />Data Recovery</a></li>
          <li class="mb-12"><a href="/services/mac-repair-romford/" class="alien-font footer-link"><Icon name="apple" size={14} class="ftr-icon" />Mac Repair</a></li>
          <li class="mb-12"><a href="/services/network-wifi-romford/" class="alien-font footer-link"><Icon name="wifi" size={14} class="ftr-icon" />Network & WiFi</a></li>
          <li class="mb-12"><a href="/services/computer-upgrades-romford/" class="alien-font footer-link"><Icon name="bolt" size={14} class="ftr-icon" />Computer Upgrades</a></li>
          <li class="mb-12"><a href="/pricing/" class="alien-font footer-link"><Icon name="bolt" size={14} class="ftr-icon" />Pricing</a></li>
          <li class="mb-12"><a href="/faq/" class="alien-font footer-link"><Icon name="chat" size={14} class="ftr-icon" />FAQ</a></li>
          <li class="mb-12"><a href="/about/" class="alien-font footer-link"><Icon name="info" size={14} class="ftr-icon" />About Me</a></li>
          <li class="mb-12"><a href="/blog/" class="alien-font footer-link"><Icon name="blog" size={14} class="ftr-icon" />Blog & Tips</a></li>
          <li><a href="/contact/" class="alien-font footer-link"><Icon name="phone" size={14} class="ftr-icon" />Contact</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="cosmic-card ftr-contact-card">
        <h3 class="space-font cosmic-glow ftr-section-heading ftr-heading-purple ftr-z2">
          <Icon name="phone" size={18} />Contact
        </h3>

        <ul class="list-none ftr-z2">
          <li class="mb-16">
            <a href={`tel:${siteConfig.phone.mobile}`} class="alien-font contact-link">
              <Icon name="mobile" size={16} />
              <div><div class="ftr-sublabel">Mobile</div><div class="ftr-value">{siteConfig.phone.mobileDisplay}</div></div>
            </a>
          </li>
          <li class="mb-16">
            <a href={`tel:${siteConfig.phone.landline}`} class="alien-font contact-link">
              <Icon name="landline" size={16} />
              <div><div class="ftr-sublabel">Landline</div><div class="ftr-value">{siteConfig.phone.landlineDisplay}</div></div>
            </a>
          </li>
          <li class="mb-16">
            <a href={`mailto:${siteConfig.email}`} class="alien-font contact-link">
              <Icon name="email" size={16} />
              <div><div class="ftr-sublabel">Email</div><div class="ftr-value">{siteConfig.email}</div></div>
            </a>
          </li>
        </ul>

        <!-- Operating Hours -->
        <div class="ftr-hours-wrap ftr-z2">
          <div class="ftr-hours-box">
            <div class="ftr-hours-header">
              <Icon name="clock" size={14} />
              <span class="tech-font ftr-hours-label">HOURS</span>
            </div>
            <div class="ftr-hours-row">
              <span class="alien-font ftr-hours-day">Mon - Sun</span>
              <span class="alien-font ftr-hours-time">9AM - 9PM</span>
            </div>
            <div class="ftr-hours-status">
              <span class="tech-font ftr-status-text" data-business-status aria-live="polite" aria-atomic="true">
                <span aria-hidden="true" data-business-status-icon>✅</span> <span data-business-status-text>Available Now</span>
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- Location & Site Info -->
      <div class="cosmic-card card-pad">
        <h3 class="space-font cosmic-glow ftr-section-heading ftr-heading-orange">
          <Icon name="map-pin" size={18} />Location
        </h3>

        <div class="mb-24">
          <div class="ftr-address-row">
            <Icon name="map-pin" size={16} class="ftr-icon-orange" />
            <address class="alien-font ftr-address">
              {siteConfig.address.street}<br />
              {siteConfig.address.locality}, {siteConfig.address.city}<br />
              {siteConfig.address.region}, {siteConfig.address.postcode}
            </address>
          </div>
          <div class="ftr-map-btn-wrap">
            <a
              href="https://www.google.com/maps/search/Chiltern+Computers+38+Hilldene+Avenue+Harold+Hill+Romford+RM3+8YP"
              target="_blank"
              rel="noopener noreferrer"
              class="space-button ftr-map-btn"
            >
              <Icon name="map" size={14} />View Map
            </a>
          </div>
        </div>

        <div>
          <h4 class="space-font ftr-site-heading">Site Info</h4>
          <ul class="list-none">
            <li class="mb-8"><a href="/sitemap.xml" class="alien-font footer-link-sm" target="_blank" rel="noopener noreferrer"><Icon name="map" size={13} class="ftr-icon-orange" /><span>Sitemap</span><span class="ftr-xml-badge">XML</span></a></li>
            <li class="mb-8"><a href="/privacy-policy/" class="alien-font footer-link-sm"><Icon name="lock" size={13} class="ftr-icon-orange" />Privacy Policy</a></li>
            <li class="mb-8"><a href="/terms-of-service/" class="alien-font footer-link-sm"><Icon name="clipboard" size={13} class="ftr-icon-orange" />Terms of Service</a></li>
