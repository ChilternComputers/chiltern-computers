  <script>
    // Update copyright year automatically
    const currentYear = new Date().getFullYear();
    const yearElement = document.getElementById('current-year');
    if (yearElement) {
      yearElement.textContent = currentYear;
    }

    // Back to top functionality with scroll-based visibility
    const backToTopButton = document.getElementById('back-to-top');
    if (backToTopButton) {
      backToTopButton.addEventListener('click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth',
        });
      });

      // Show/hide back to top based on scroll position
      window.addEventListener('scroll', () => {
        if (window.scrollY > 300) {
          backToTopButton.style.opacity = '1';
          backToTopButton.style.transform = 'translateY(0)';
        } else {
          backToTopButton.style.opacity = '0.7';
          backToTopButton.style.transform = 'translateY(10px)';
        }
      });
    }

    // Real-time availability status
    function updateAvailabilityStatus() {
      const now = new Date();
      const hour = now.getHours();
      const statusElement = document.getElementById('availability-status');

      const iconEl = document.getElementById('availability-icon');
      const textEl = document.getElementById('availability-text');

      if (statusElement && iconEl && textEl) {
        if (hour >= 9 && hour < 21) {
          iconEl.textContent = '✅';
          textEl.textContent = 'Available Now';
          statusElement.style.color = 'var(--aurora-green)';
        } else {
          iconEl.textContent = '🌙';
          textEl.textContent = 'Call Tomorrow 9AM';
          statusElement.style.color = 'var(--solar-orange)';
        }
      }
    }

    // Update availability immediately and every minute
    updateAvailabilityStatus();
    setInterval(updateAvailabilityStatus, 60000);

  </script>

