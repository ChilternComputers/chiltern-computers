---
// Footer.astro - Clean & Optimized Production Version
import { siteConfig } from '../config';
---

<footer
  class="section-bg-5"
  style="padding: 60px 0 0 0; position: relative; margin: 0;"
  role="contentinfo"
>
  <!-- Emergency Contact Banner -->
  <div
    style="background: linear-gradient(45deg, rgba(220, 38, 38, 0.15), rgba(245, 158, 11, 0.15)); border-bottom: 2px solid rgba(220, 38, 38, 0.3); padding: 12px; text-align: center; animation: emergencyPulse 3s ease-in-out infinite;"
  >
    <p
      class="tech-font"
      style="color: var(--solar-orange); font-size: 12px; margin: 0; font-weight: 600;"
    >
      <span aria-hidden="true">🚨</span> <span style="color: var(--aurora-green);">EMERGENCY REPAIRS?</span>
      Call <a
        href={`tel:${siteConfig.phone.mobile}`}
        style="color: var(--aurora-green); font-weight: bold; text-decoration: none;"
        >{siteConfig.phone.mobileDisplay}</a
      >
      - Available {siteConfig.hours.display} <span aria-hidden="true">🚨</span>
    </p>
  </div>

  <div class="container" style="padding-top: 40px;">
    <!-- Service Areas Ticker -->
    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 32px; margin-bottom: 48px;"
    >
      <div
        class="cosmic-card service-areas-enhanced"
        style="padding: 20px; grid-column: 1 / -1; position: relative; overflow: hidden;"
      >
        <div class="cosmic-bg-animation"></div>

        <a href="/areas/" style="text-decoration: none;">
          <h3
            class="space-font cosmic-glow"
            style="color: var(--plasma-cyan); font-size: 18px; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; text-align: center; justify-content: center; position: relative; z-index: 2;"
          >
            <span aria-hidden="true" style="animation: float-cosmic 3s ease-in-out infinite;">🌌</span>
            Service Areas
            <span style="font-size: 12px;">→</span>
          </h3>
        </a>

        <div class="scroll-container enhanced-ticker" tabindex="0" role="marquee" aria-label="Service areas we cover">
          <div class="scroll-content">
            <span class="service-area-primary"><span aria-hidden="true">🌍</span> Harold Hill</span>
            <span class="service-area"><span aria-hidden="true">🪐</span> Romford</span>
            <span class="service-area-primary"><span aria-hidden="true">🌙</span> Harold Wood</span>
            <span class="service-area"><span aria-hidden="true">🌟</span> Hornchurch</span>
            <span class="service-area-primary"><span aria-hidden="true">☄️</span> Collier Row</span>
            <span class="service-area"><span aria-hidden="true">🌌</span> Dagenham</span>
            <span class="service-area-primary"><span aria-hidden="true">🛸</span> Rainham</span>
            <span class="service-area"><span aria-hidden="true">🚀</span> Brentwood</span>
            <span class="service-area-primary"><span aria-hidden="true">🌠</span> Gidea Park</span>
            <span class="service-area"><span aria-hidden="true">🛰️</span> Emerson Park</span>
            <span class="service-area-primary"><span aria-hidden="true">⭐</span> Chadwell Heath</span>
            <span class="service-area"><span aria-hidden="true">🌊</span> Upminster</span>
            <span class="service-area-primary"><span aria-hidden="true">🌑</span> Cranham</span>
            <span class="service-area"><span aria-hidden="true">🌈</span> Elm Park</span>
            <span class="service-area-primary"><span aria-hidden="true">🌸</span> Pilgrims Hatch</span>
            <span class="service-area"><span aria-hidden="true">🌿</span> Hainault</span>
            <span class="service-area-primary"><span aria-hidden="true">⚡</span> Rush Green</span>
            <span class="service-area"><span aria-hidden="true">🏡</span> Ardleigh Green</span>
            <span class="service-area-primary"><span aria-hidden="true">🌺</span> Warley</span>
          </div>
        </div>

        <div style="text-align: center; margin-top: 12px; position: relative; z-index: 2;">
          <p
            class="tech-font"
            style="color: var(--plasma-cyan); font-size: 10px; opacity: 0.8; font-weight: 500;"
          >
            <span aria-hidden="true">🛸</span> SERVICE COVERAGE ACROSS HAVERING & ESSEX <span aria-hidden="true">🛸</span>
          </p>
        </div>
      </div>
    </div>

    <!-- Main Footer Grid -->
    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 32px; margin-bottom: 48px;"
    >
      <!-- Services -->
      <div class="cosmic-card" style="padding: 24px;">
        <h3
          class="space-font cosmic-glow"
          style="color: var(--aurora-green); font-size: 18px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px;"
        >
          <span aria-hidden="true">🚀</span>Services
        </h3>
        <ul style="list-style: none; padding: 0; margin: 0;">
          <li style="margin-bottom: 12px;">
            <a
              href="/services/repairs/"
              class="alien-font footer-link"
              style="color: var(--comet-silver); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
            >
              <span aria-hidden="true" style="color: var(--plasma-cyan);">🛠️</span>Computer Repairs
            </a>
          </li>
          <li style="margin-bottom: 12px;">
            <a
              href="/services/custom-pcs/"
              class="alien-font footer-link"
              style="color: var(--comet-silver); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
            >
              <span aria-hidden="true" style="color: var(--plasma-cyan);">🎮</span>Custom Gaming PCs
            </a>
          </li>
          <li style="margin-bottom: 12px;">
            <a
              href="/services/new-used/"
              class="alien-font footer-link"
              style="color: var(--comet-silver); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
            >
              <span aria-hidden="true" style="color: var(--plasma-cyan);">💻</span>New & Refurb PCs
            </a>
          </li>
          <li style="margin-bottom: 12px;">
            <a
              href="/services/virus-removal-romford/"
              class="alien-font footer-link"
              style="color: var(--comet-silver); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
            >
              <span aria-hidden="true" style="color: var(--plasma-cyan);">🛡️</span>Virus Removal
            </a>
          </li>
          <li style="margin-bottom: 12px;">
            <a
              href="/services/data-recovery-havering/"
              class="alien-font footer-link"
              style="color: var(--comet-silver); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
            >
              <span aria-hidden="true" style="color: var(--plasma-cyan);">💾</span>Data Recovery
            </a>
          </li>
          <li style="margin-bottom: 12px;">
            <a
              href="/services/mac-repair-romford/"
              class="alien-font footer-link"
              style="color: var(--comet-silver); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
            >
              <span aria-hidden="true" style="color: var(--plasma-cyan);">🍎</span>Mac Repair
            </a>
          </li>
          <li style="margin-bottom: 12px;">
            <a
              href="/services/network-wifi-romford/"
              class="alien-font footer-link"
              style="color: var(--comet-silver); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
            >
              <span aria-hidden="true" style="color: var(--plasma-cyan);">📡</span>Network & WiFi
            </a>
          </li>
          <li style="margin-bottom: 12px;">
            <a
              href="/services/computer-upgrades-romford/"
              class="alien-font footer-link"
              style="color: var(--comet-silver); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
            >
              <span aria-hidden="true" style="color: var(--plasma-cyan);">⚡</span>Computer Upgrades
            </a>
          </li>
          <li style="margin-bottom: 12px;">
            <a
              href="/services/web-design/"
              class="alien-font footer-link"
              style="color: var(--comet-silver); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
            >
              <span aria-hidden="true" style="color: var(--plasma-cyan);">🌐</span>Web Design
            </a>
          </li>
          <li style="margin-bottom: 12px;">
            <a
              href="/about/"
              class="alien-font footer-link"
              style="color: var(--comet-silver); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
            >
              <span aria-hidden="true" style="color: var(--plasma-cyan);">ℹ️</span>About Us
            </a>
          </li>
          <li style="margin-bottom: 12px;">
            <a
              href="/blog/"
              class="alien-font footer-link"
              style="color: var(--comet-silver); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
            >
              <span aria-hidden="true" style="color: var(--plasma-cyan);">📝</span>Blog & Tips
            </a>
          </li>
          <li>
            <a
              href="/contact/"
              class="alien-font footer-link"
              style="color: var(--comet-silver); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
            >
              <span aria-hidden="true" style="color: var(--plasma-cyan);">📞</span>Contact
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div
        class="cosmic-card contact-card-premium"
        style="padding: 24px; border: 2px solid var(--nebula-purple); box-shadow: 0 8px 25px rgba(124, 58, 237, 0.4); position: relative;"
      >
        <div class="premium-glow-effect"></div>

        <h3
          class="space-font cosmic-glow"
          style="color: var(--nebula-purple); font-size: 18px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; position: relative; z-index: 2;"
        >
          <span aria-hidden="true" style="animation: float-cosmic 2s ease-in-out infinite;">📡</span>Contact
        </h3>

        <ul style="list-style: none; padding: 0; margin: 0; position: relative; z-index: 2;">
          <li style="margin-bottom: 16px;">
            <a
              href={`tel:${siteConfig.phone.mobile}`}
              class="alien-font contact-link-premium"
              style="color: var(--starlight-white); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 12px; transition: all 0.3s ease; padding: 8px; border-radius: 6px;"
            >
              <span aria-hidden="true" style="font-size: 16px;">📱</span>
              <div>
                <div style="font-size: 12px; color: var(--comet-silver);">Mobile</div>
                <div style="font-weight: 600;">{siteConfig.phone.mobileDisplay}</div>
              </div>
            </a>
          </li>
          <li style="margin-bottom: 16px;">
            <a
              href={`tel:${siteConfig.phone.landline}`}
              class="alien-font contact-link-premium"
              style="color: var(--starlight-white); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 12px; transition: all 0.3s ease; padding: 8px; border-radius: 6px;"
            >
              <span aria-hidden="true" style="font-size: 16px;">☎️</span>
              <div>
                <div style="font-size: 12px; color: var(--comet-silver);">Landline</div>
                <div style="font-weight: 600;">{siteConfig.phone.landlineDisplay}</div>
              </div>
            </a>
          </li>
          <li style="margin-bottom: 16px;">
            <a
              href={`mailto:${siteConfig.email}`}
              class="alien-font contact-link-premium"
              style="color: var(--starlight-white); font-size: 14px; text-decoration: none; display: flex; align-items: center; gap: 12px; transition: all 0.3s ease; padding: 8px; border-radius: 6px;"
            >
              <span aria-hidden="true" style="font-size: 16px;">✉️</span>
              <div>
                <div style="font-size: 12px; color: var(--comet-silver);">Email</div>
                <div style="font-weight: 600;">{siteConfig.email}</div>
              </div>
            </a>
          </li>
        </ul>

        <!-- Operating Hours -->
        <div
          style="display: flex; justify-content: center; margin-top: 20px; position: relative; z-index: 2;"
        >
          <div
            style="background: rgba(139, 92, 246, 0.2); border: 2px solid var(--nebula-purple); border-radius: 12px; padding: 16px; max-width: 200px; width: 100%; box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);"
          >
            <div
              style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px; justify-content: center;"
            >
              <span aria-hidden="true" style="font-size: 14px;">🕒</span>
              <span
                class="tech-font"
                style="color: var(--nebula-purple); font-size: 12px; font-weight: 600;">HOURS</span
              >
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span
                class="alien-font"
                style="color: var(--starlight-white); font-size: 13px; font-weight: 500;"
                >Mon - Sun</span
              >
              <span
                class="alien-font"
                style="color: var(--aurora-green); font-size: 13px; font-weight: 600;"
                >9AM - 9PM</span
              >
            </div>
            <div
              style="text-align: center; margin-top: 8px; padding-top: 8px; border-top: 1px solid rgba(139, 92, 246, 0.3);"
            >
              <span
                class="tech-font"
                style="color: var(--aurora-green); font-size: 10px; font-weight: 500;"
                id="availability-status"
                aria-live="polite"
                aria-atomic="true"><span aria-hidden="true" id="availability-icon">✅</span> <span id="availability-text">Available Now</span></span
              >
            </div>
          </div>
        </div>
      </div>

      <!-- Location & Site Info -->
      <div class="cosmic-card" style="padding: 24px;">
        <h3
          class="space-font cosmic-glow"
          style="color: var(--solar-orange); font-size: 18px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px;"
        >
          <span aria-hidden="true">🌍</span>Location
        </h3>

        <!-- Address -->
        <div style="margin-bottom: 24px;">
          <div style="display: flex; align-items: start; gap: 12px; margin-bottom: 12px;">
            <span aria-hidden="true" style="font-size: 16px; color: var(--solar-orange);">📍</span>
            <address
              class="alien-font"
              style="color: var(--starlight-white); font-size: 14px; font-style: normal; line-height: 1.4; font-weight: 500;"
            >
              {siteConfig.address.street}<br />
              {siteConfig.address.locality}, {siteConfig.address.city}<br />
              {siteConfig.address.region}, {siteConfig.address.postcode}
            </address>
          </div>

          <!-- Map Button -->
          <div style="text-align: left; margin-top: 16px;">
            <a
              href="https://www.google.com/maps/search/Chiltern+Computers+38+Hilldene+Avenue+Harold+Hill+Romford+RM3+8YP"
              target="_blank"
              rel="noopener noreferrer"
              class="space-button map-button-enhanced"
              style="font-size: 12px; padding: 10px 18px; text-decoration: none;"
            >
              <span aria-hidden="true">🗺️</span>View Map
            </a>
          </div>
        </div>

        <!-- Site Navigation -->
        <div>
          <h4
            class="space-font"
            style="color: var(--comet-silver); font-size: 14px; margin-bottom: 12px; font-weight: 600;"
          >
            Site Info
          </h4>
          <ul style="list-style: none; padding: 0; margin: 0;">
            <li style="margin-bottom: 8px;">
              <a
                href="/sitemap.xml"
                class="alien-font footer-link"
                style="color: var(--comet-silver); font-size: 13px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
                target="_blank"
                rel="noopener noreferrer"
              >
                <span aria-hidden="true" style="color: var(--solar-orange);">🗺️</span>
                <span>Sitemap</span>
                <span
                  style="background: rgba(245, 158, 11, 0.2); color: var(--solar-orange); padding: 2px 6px; border-radius: 4px; font-size: 10px; font-weight: 600;"
                  >XML</span
                >
              </a>
            </li>
            <li style="margin-bottom: 8px;">
              <a
                href="/privacy-policy/"
                class="alien-font footer-link"
                style="color: var(--comet-silver); font-size: 13px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
              >
                <span aria-hidden="true" style="color: var(--solar-orange);">🔒</span>Privacy Policy
              </a>
            </li>
            <li style="margin-bottom: 8px;">
              <a
                href="/terms-of-service/"
                class="alien-font footer-link"
                style="color: var(--comet-silver); font-size: 13px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
              >
                <span aria-hidden="true" style="color: var(--solar-orange);">📋</span>Terms of Service
              </a>
            </li>
            <li style="margin-bottom: 8px;">
              <a
                href="/accessibility/"
                class="alien-font footer-link"
                style="color: var(--comet-silver); font-size: 13px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
              >
                <span aria-hidden="true" style="color: var(--solar-orange);">♿</span>Accessibility
              </a>
            </li>
            <li>
              <a
                href="/free-play/"
                class="alien-font footer-link"
                style="color: var(--comet-silver); font-size: 13px; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.3s ease;"
              >
                <span aria-hidden="true" style="color: var(--solar-orange);">🎮</span>Free Play
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Call-to-Action Buttons -->
    <div
      style="display: flex; gap: 16px; justify-content: center; margin-bottom: 32px; flex-wrap: wrap;"
    >
      <a
        href="/contact/"
        class="space-button cta-primary"
        aria-label="Get Quote"
        style="font-size: 12px; padding: 12px 24px; background: linear-gradient(45deg, var(--aurora-green), var(--plasma-cyan)) !important; border: 2px solid var(--aurora-green); font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; display: flex; align-items: center; justify-content: center; text-align: center;"
      >
        <span aria-hidden="true">💬</span> Get Quote
      </a>
      <a
        href={`tel:${siteConfig.phone.mobile}`}
        class="space-button cta-secondary"
        aria-label="Call Now"
        style="font-size: 12px; padding: 12px 24px; border: 2px solid var(--solar-orange); font-weight: 600; display: flex; align-items: center; justify-content: center; text-align: center;"
      >
        <span aria-hidden="true">📱</span> Call Now
      </a>
      <a
        href="/services/repairs/"
        class="space-button cta-tertiary"
        aria-label="Book Repair"
        style="font-size: 12px; padding: 12px 24px; border: 2px solid var(--nebula-purple); font-weight: 600; display: flex; align-items: center; justify-content: center; text-align: center;"
      >
        <span aria-hidden="true">🛠️</span> Book Repair
      </a>
    </div>

    <!-- Back to Top Button -->
    <div style="display: flex; justify-content: center; margin-bottom: 32px;">
      <button
        id="back-to-top"
        class="space-button back-to-top-enhanced"
        aria-label="Scroll back to top of page"
        style="font-size: 12px; padding: 10px 20px; cursor: pointer; transition: all 0.3s ease;"
      >
        <span aria-hidden="true">🚀</span>Back to Top
      </button>
    </div>
  </div>

  <!-- Copyright Section -->
  <div
    style="padding: 32px 20px; margin: 0; width: 100%; display: flex; justify-content: center; align-items: center;"
  >
    <div
      class="cosmic-card copyright-enhanced"
      style="padding: 24px; max-width: 600px; margin: 0; width: 100%; text-align: center; position: relative; overflow: hidden;"
    >
      <div class="copyright-bg-effect"></div>

      <div
        style="display: flex; flex-direction: column; gap: 16px; align-items: center; position: relative; z-index: 2;"
      >
        <!-- Trust Signals -->
        <div
          style="display: flex; gap: 10px; justify-content: center; margin-bottom: 12px; flex-wrap: wrap;"
        >
          <span
            style="background: rgba(66, 133, 244, 0.2); border: 1px solid #4285f4; color: #4285f4; padding: 6px 12px; border-radius: 15px; font-size: 11px; font-weight: 600; display: flex; align-items: center; gap: 5px;"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
              ></path><path
                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
              ></path><path
                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
              ></path><path
                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
              ></path></svg
            >
            Google Reviewed
          </span>
          <span
            style="background: rgba(24, 119, 242, 0.2); border: 1px solid #1877f2; color: #1877f2; padding: 6px 12px; border-radius: 15px; font-size: 11px; font-weight: 600; display: flex; align-items: center; gap: 5px;"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
              ></path></svg
            >
            Facebook Rated
          </span>
          <span
