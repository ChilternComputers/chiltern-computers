---
// StarRating.astro — Accessible SVG star rating display
// Replaces emoji stars (⭐/★) with consistent SVGs and proper ARIA

interface Props {
  rating: number;
  max?: number;
  size?: number;
  color?: string;
}

const { rating, max = 5, size = 16, color = 'var(--star-color)' } = Astro.props;
---

<span
  role="img"
  aria-label={`${rating} out of ${max} stars`}
  style={`display: inline-flex; gap: 2px;`}
>
  {Array.from({ length: max }, (_, i) => (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill={i < rating ? color : 'none'}
      stroke={color}
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
    </svg>
  ))}
</span>
