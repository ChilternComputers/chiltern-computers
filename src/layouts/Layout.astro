---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import SEO from '../components/SEO.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  keywords?: string;
  type?: 'website' | 'article' | 'service';
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
  breadcrumbs?: Array<{ name: string; url: string }>;
  reviews?: Array<{
    author: string;
    location: string;
    text: string;
    rating: number;
    date?: string;
  }>;
}

const {
  title,
  description,
  image,
  keywords,
  type,
  publishedTime,
  modifiedTime,
  noindex,
  breadcrumbs,
  reviews,
} = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <SEO
      title={title}
      description={description}
      image={image}
      keywords={keywords}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      noindex={noindex}
      breadcrumbs={breadcrumbs}
      reviews={reviews}
    />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/icon-192x192.png" />
  </head>
  <body class="min-h-screen" style="background: var(--void-black);">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <CookieConsent />

    <!-- Floating Back to Top -->
    <button
      id="back-to-top"
      aria-label="Scroll back to top"
      style="position: fixed; bottom: 28px; right: 28px; z-index: 9998; width: 52px; height: 52px; border-radius: 50%; border: 2px solid var(--plasma-cyan); background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(12px); cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 0; visibility: hidden; transform: translateY(20px) scale(0.8); transition: opacity 0.4s ease, visibility 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), border-color 0.3s ease, box-shadow 0.3s ease;"
    >
      <svg id="btt-rocket" width="24" height="24" viewBox="0 0 24 24" fill="none" style="transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);">
        <path d="M12 2C12 2 8 6 8 12c0 2.5.8 4.5 2 6h4c1.2-1.5 2-3.5 2-6 0-6-4-10-4-10z" fill="var(--plasma-cyan)" opacity="0.9"/>
        <path d="M12 2c0 0-2.5 2.5-3.5 7h7C14.5 4.5 12 2 12 2z" fill="var(--aurora-green)" opacity="0.6"/>
        <circle cx="12" cy="10" r="1.5" fill="rgba(15,23,42,0.8)"/>
        <path d="M10 18l-1.5 4L12 20l3.5 2L14 18" fill="var(--solar-orange)" opacity="0.9"/>
        <path d="M9.5 18l-2 1.5c0 0 .5-2.5 1-3.5" fill="var(--nebula-purple)" opacity="0.7"/>
        <path d="M14.5 18l2 1.5c0 0-.5-2.5-1-3.5" fill="var(--nebula-purple)" opacity="0.7"/>
      </svg>
      <div id="btt-trail" style="position: absolute; bottom: -2px; left: 50%; transform: translateX(-50%); width: 16px; height: 0; overflow: hidden; transition: height 0.3s ease;">
        <div style="width: 4px; height: 100%; margin: 0 auto; background: linear-gradient(to bottom, var(--solar-orange), transparent); border-radius: 2px; opacity: 0.8;"></div>
      </div>
    </button>

    <style>
      #back-to-top.visible {
        opacity: 1 !important;
        visibility: visible !important;
        transform: translateY(0) scale(1) !important;
      }
      #back-to-top:hover {
        border-color: var(--aurora-green) !important;
        box-shadow: 0 0 20px rgba(6, 182, 212, 0.4), 0 0 40px rgba(16, 185, 129, 0.2) !important;
      }
      #back-to-top:hover #btt-rocket {
        transform: translateY(-3px) !important;
      }
      #back-to-top:hover #btt-trail {
        height: 12px !important;
      }
      #back-to-top.launching #btt-rocket {
        animation: rocketLaunch 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards !important;
      }
      #back-to-top.launching #btt-trail {
        height: 20px !important;
        animation: trailFlicker 0.6s ease-out forwards !important;
      }
      #back-to-top.launching {
        animation: buttonPulse 0.6s ease-out !important;
      }
      @keyframes rocketLaunch {
        0% { transform: translateY(0); }
        50% { transform: translateY(-10px) scale(1.15); }
        100% { transform: translateY(-4px) scale(1); }
      }
      @keyframes trailFlicker {
        0% { height: 8px; opacity: 0.5; }
        30% { height: 24px; opacity: 1; }
        100% { height: 0; opacity: 0; }
      }
      @keyframes buttonPulse {
        0% { box-shadow: 0 0 0 0 rgba(6, 182, 212, 0.5); }
        50% { box-shadow: 0 0 25px 8px rgba(6, 182, 212, 0.3), 0 0 50px 16px rgba(245, 158, 11, 0.15); }
        100% { box-shadow: 0 0 20px rgba(6, 182, 212, 0.4); }
      }
      @media (prefers-reduced-motion: reduce) {
        #back-to-top,
        #back-to-top:hover #btt-rocket,
        #back-to-top.launching #btt-rocket,
        #back-to-top.launching #btt-trail,
        #back-to-top.launching {
          animation: none !important;
          transition: opacity 0.1s ease, visibility 0.1s ease !important;
        }
      }
      @media print {
        #back-to-top { display: none !important; }
      }
    </style>

    <script>
      const btt = document.getElementById('back-to-top');
      if (btt) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 400) {
            btt.classList.add('visible');
          } else {
            btt.classList.remove('visible');
          }
        }, { passive: true });

        btt.addEventListener('click', () => {
          btt.classList.add('launching');
          setTimeout(() => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }, 150);
          setTimeout(() => {
            btt.classList.remove('launching');
          }, 700);
        });
      }
    </script>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }
    </script>
  </body>
</html>
