---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import SEO from '../components/SEO.astro';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  keywords?: string;
  type?: 'website' | 'article' | 'service';
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
  breadcrumbs?: Array<{ name: string; url: string }>;
  reviews?: Array<{
    author: string;
    location: string;
    text: string;
    rating: number;
    date?: string;
  }>;
}

const {
  title,
  description,
  image,
  keywords,
  type,
  publishedTime,
  modifiedTime,
  noindex,
  breadcrumbs,
  reviews,
} = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <SEO
      title={title}
      description={description}
      image={image}
      keywords={keywords}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      noindex={noindex}
      breadcrumbs={breadcrumbs}
      reviews={reviews}
    />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/icon-192x192.png" />
  </head>
  <body class="min-h-screen" style="background: var(--void-black);">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <CookieConsent />

    <!-- Floating WhatsApp Button -->
    <a
      href="https://wa.me/447971331814"
      target="_blank"
      rel="noopener noreferrer"
      id="whatsapp-btn"
      aria-label="Message me on WhatsApp"
      style="position: fixed; bottom: 28px; left: 28px; z-index: 9998; width: 56px; height: 56px; border-radius: 50%; background: #25D366; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 16px rgba(37, 211, 102, 0.4); transition: transform 0.3s ease, box-shadow 0.3s ease; text-decoration: none;"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="white" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.885 3.608"/>
      </svg>
    </a>

    <!-- Floating Back to Top -->
    <button
      id="back-to-top"
      aria-label="Scroll back to top"
      style="position: fixed; bottom: 28px; right: 28px; z-index: 9998; width: 52px; height: 52px; border-radius: 50%; border: 2px solid var(--plasma-cyan); background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(12px); cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 0; visibility: hidden; transform: translateY(20px) scale(0.8); transition: opacity 0.4s ease, visibility 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), border-color 0.3s ease, box-shadow 0.3s ease;"
    >
      <svg id="btt-rocket" width="24" height="24" viewBox="0 0 24 24" fill="none" style="transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);">
        <path d="M12 2C12 2 8 6 8 12c0 2.5.8 4.5 2 6h4c1.2-1.5 2-3.5 2-6 0-6-4-10-4-10z" fill="var(--plasma-cyan)" opacity="0.9"/>
        <path d="M12 2c0 0-2.5 2.5-3.5 7h7C14.5 4.5 12 2 12 2z" fill="var(--aurora-green)" opacity="0.6"/>
        <circle cx="12" cy="10" r="1.5" fill="rgba(15,23,42,0.8)"/>
        <path d="M10 18l-1.5 4L12 20l3.5 2L14 18" fill="var(--solar-orange)" opacity="0.9"/>
        <path d="M9.5 18l-2 1.5c0 0 .5-2.5 1-3.5" fill="var(--nebula-purple)" opacity="0.7"/>
        <path d="M14.5 18l2 1.5c0 0-.5-2.5-1-3.5" fill="var(--nebula-purple)" opacity="0.7"/>
      </svg>
      <div id="btt-trail" style="position: absolute; bottom: -2px; left: 50%; transform: translateX(-50%); width: 16px; height: 0; overflow: hidden; transition: height 0.3s ease;">
        <div style="width: 4px; height: 100%; margin: 0 auto; background: linear-gradient(to bottom, var(--solar-orange), transparent); border-radius: 2px; opacity: 0.8;"></div>
      </div>
    </button>

    <style>
      #whatsapp-btn:hover {
        transform: scale(1.1);
        box-shadow: 0 6px 24px rgba(37, 211, 102, 0.6);
      }
      #whatsapp-btn:focus-visible {
        outline: 3px solid var(--aurora-green);
        outline-offset: 2px;
      }
      @media (max-width: 480px) {
        #whatsapp-btn {
          width: 48px; height: 48px; bottom: 20px; left: 20px;
        }
        #whatsapp-btn svg { width: 24px; height: 24px; }
      }
      @media print { #whatsapp-btn { display: none; } }
      @media (prefers-reduced-motion: reduce) {
        #whatsapp-btn { transition: none; }
      }
      #back-to-top.visible {
        opacity: 1 !important;
        visibility: visible !important;
        transform: translateY(0) scale(1) !important;
      }
      #back-to-top:hover {
        border-color: var(--aurora-green) !important;
        box-shadow: 0 0 20px rgba(6, 182, 212, 0.4), 0 0 40px rgba(16, 185, 129, 0.2) !important;
      }
      #back-to-top:hover #btt-rocket {
        transform: translateY(-3px) !important;
      }
      #back-to-top:hover #btt-trail {
        height: 12px !important;
      }
      #back-to-top.launching #btt-rocket {
        animation: rocketLaunch 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards !important;
      }
      #back-to-top.launching #btt-trail {
        height: 20px !important;
        animation: trailFlicker 0.6s ease-out forwards !important;
      }
      #back-to-top.launching {
        animation: buttonPulse 0.6s ease-out !important;
      }
      @keyframes rocketLaunch {
        0% { transform: translateY(0); }
        50% { transform: translateY(-10px) scale(1.15); }
        100% { transform: translateY(-4px) scale(1); }
      }
      @keyframes trailFlicker {
        0% { height: 8px; opacity: 0.5; }
        30% { height: 24px; opacity: 1; }
        100% { height: 0; opacity: 0; }
      }
      @keyframes buttonPulse {
        0% { box-shadow: 0 0 0 0 rgba(6, 182, 212, 0.5); }
        50% { box-shadow: 0 0 25px 8px rgba(6, 182, 212, 0.3), 0 0 50px 16px rgba(245, 158, 11, 0.15); }
        100% { box-shadow: 0 0 20px rgba(6, 182, 212, 0.4); }
      }
      @media (prefers-reduced-motion: reduce) {
        #back-to-top,
        #back-to-top:hover #btt-rocket,
        #back-to-top.launching #btt-rocket,
        #back-to-top.launching #btt-trail,
        #back-to-top.launching {
          animation: none !important;
          transition: opacity 0.1s ease, visibility 0.1s ease !important;
        }
      }
      @media print {
        #back-to-top { display: none !important; }
      }
    </style>

    <script>
      const btt = document.getElementById('back-to-top');
      if (btt) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 400) {
            btt.classList.add('visible');
          } else {
            btt.classList.remove('visible');
          }
        }, { passive: true });

        btt.addEventListener('click', () => {
          btt.classList.add('launching');
          setTimeout(() => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }, 150);
          setTimeout(() => {
            btt.classList.remove('launching');
          }, 700);
        });
      }
    </script>
    <script>
      // Skip link focus management — move focus to main content
      const skipLink = document.querySelector('.skip-link');
      const mainContent = document.getElementById('main-content');
      if (skipLink && mainContent) {
        skipLink.addEventListener('click', (e) => {
          e.preventDefault();
          mainContent.focus();
          mainContent.scrollIntoView();
        });
      }
    </script>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }
    </script>
  </body>
</html>
