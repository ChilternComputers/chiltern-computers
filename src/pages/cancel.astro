---
const title = "Cancel Booking — Blades & Fades";
---
<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href="https://chilterncomputers.net/cancel/" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Orbitron:wght@700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <main class="cancel-page" id="main-content" aria-live="polite">
    <div class="cancel-card">
      <div id="state-loading" role="status">
        <div class="spinner" aria-hidden="true"></div>
        <p class="subtle">Looking up your booking...</p>
      </div>

      <div id="state-found" style="display:none;">
        <div class="logo-block" aria-hidden="true">
          <span class="logo-text">BLADES <span class="amp">&</span> FADES</span>
          <span class="logo-sub">PREMIUM BARBERING</span>
        </div>
        <h1 id="page-heading">Cancel Your Booking</h1>
        <div class="booking-details" role="list" aria-label="Booking details">
          <div class="detail-row" role="listitem"><span class="label">Barber</span><span class="value" id="d-barber"></span></div>
          <div class="detail-row" role="listitem"><span class="label">Service</span><span class="value" id="d-service"></span></div>
          <div class="detail-row" role="listitem"><span class="label">Date</span><span class="value" id="d-date"></span></div>
          <div class="detail-row last" role="listitem"><span class="label">Time</span><span class="value cyan" id="d-time"></span></div>
        </div>
        <p class="warn">This will cancel your appointment and free the slot for others.</p>
        <button type="button" class="btn-cancel" id="cancel-btn">Cancel This Booking</button>
        <a href="/" class="back-link">Keep my booking — go back</a>
      </div>

      <div id="state-cancelled" style="display:none;">
        <div class="logo-block" aria-hidden="true">
          <span class="logo-text">BLADES <span class="amp">&</span> FADES</span>
          <span class="logo-sub">PREMIUM BARBERING</span>
        </div>
        <div class="tick" aria-hidden="true">&#10003;</div>
        <h1>Booking Cancelled</h1>
        <p class="subtle">Your appointment has been cancelled and the time slot is now available for others.</p>
        <a href="/#booking" class="btn-rebook">Book a New Appointment</a>
      </div>

      <div id="state-already" style="display:none;">
        <div class="logo-block" aria-hidden="true">
          <span class="logo-text">BLADES <span class="amp">&</span> FADES</span>
          <span class="logo-sub">PREMIUM BARBERING</span>
        </div>
        <h1>Already Cancelled</h1>
        <p class="subtle" style="font-size:16px;margin-bottom:24px;">This booking has already been cancelled.</p>
        <a href="/#booking" class="btn-rebook">Book a New Appointment</a>
      </div>

      <div id="state-error" style="display:none;">
        <div class="logo-block" aria-hidden="true">
          <span class="logo-text">BLADES <span class="amp">&</span> FADES</span>
          <span class="logo-sub">PREMIUM BARBERING</span>
        </div>
        <h1>Error</h1>
        <p class="error-text" id="error-msg" role="alert">Booking not found. The link may have expired or be invalid.</p>
        <a href="/" class="back-link">Go to homepage</a>
      </div>
    </div>
  </main>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: #020617;
    color: #f8fafc;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    -webkit-font-smoothing: antialiased;
  }
  *:focus-visible { outline: 3px solid #06b6d4; outline-offset: 2px; }
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
  }
  .cancel-page { padding: 24px; width: 100%; max-width: 480px; }
  .cancel-card {
    background: #0f172a; border: 1px solid rgba(6,182,212,0.15);
    border-radius: 16px; padding: 40px 32px; text-align: center;
  }
  .logo-block { margin-bottom: 32px; }
  .logo-text {
    font-family: 'Orbitron', sans-serif;
    font-size: 20px; font-weight: 800; letter-spacing: 3px; color: #f8fafc;
  }
  .amp { color: #06b6d4; }
  .logo-sub {
    display: block; font-size: 9px; font-weight: 700;
    letter-spacing: 4px; color: #06b6d4; margin-top: 4px;
  }
  h1 {
    font-family: 'Orbitron', sans-serif;
    font-size: 22px; font-weight: 700; margin-bottom: 24px; color: #f8fafc;
  }
  .booking-details {
    background: rgba(6,182,212,0.05); border: 1px solid rgba(6,182,212,0.12);
    border-radius: 10px; padding: 4px 20px; margin-bottom: 24px; text-align: left;
  }
  .detail-row {
    display: flex; justify-content: space-between; padding: 12px 0;
    border-bottom: 1px solid rgba(6,182,212,0.08); font-size: 14px;
  }
  .detail-row.last { border-bottom: none; }
  .label { color: rgba(248,250,252,0.5); }
  .value { color: #f8fafc; font-weight: 600; }
  .value.cyan { color: #06b6d4; font-weight: 800; font-size: 16px; }
  .warn { font-size: 13px; color: rgba(248,250,252,0.45); margin-bottom: 24px; line-height: 1.6; }
  .btn-cancel {
    display: block; width: 100%; padding: 14px; background: #dc2626; color: #fff;
    border: none; border-radius: 8px; font-family: 'Inter', sans-serif;
    font-size: 15px; font-weight: 700; cursor: pointer; transition: background 0.2s ease;
    margin-bottom: 16px; min-height: 44px;
  }
  .btn-cancel:hover { background: #b91c1c; }
  .btn-cancel:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-rebook {
    display: inline-block; padding: 14px 32px; background: #06b6d4; color: #020617;
    border-radius: 8px; font-weight: 700; font-size: 15px; text-decoration: none;
    transition: background 0.2s ease; min-height: 44px;
  }
  .btn-rebook:hover { background: #0891b2; }
  .back-link {
    display: block; font-size: 13px; color: rgba(248,250,252,0.4);
    text-decoration: none; transition: color 0.2s ease; padding: 8px;
  }
  .back-link:hover { color: #06b6d4; }
  .tick { font-size: 56px; color: #22c55e; margin-bottom: 16px; }
  .subtle { font-size: 14px; color: rgba(248,250,252,0.55); line-height: 1.7; margin-bottom: 24px; }
  .error-text { font-size: 15px; color: #ef4444; margin-bottom: 24px; line-height: 1.6; }
  .spinner {
    width: 32px; height: 32px;
    border: 3px solid rgba(6,182,212,0.15);
    border-top-color: #06b6d4;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 16px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>

<script>
  const params = new URLSearchParams(window.location.search);
  const token = params.get('token');

  const allStates = ['state-loading', 'state-found', 'state-cancelled', 'state-already', 'state-error'];

  function showState(id: string) {
    allStates.forEach(s => {
      const el = document.getElementById(s);
      if (el) el.style.display = s === id ? 'block' : 'none';
    });
    // Move focus to the newly visible state for screen readers
    const target = document.getElementById(id);
    if (target) {
      const focusEl = target.querySelector('h1, a, button, [role="alert"]') as HTMLElement | null;
      if (focusEl) focusEl.focus();
    }
  }

  async function init() {
    if (!token) {
      (document.getElementById('error-msg') as HTMLElement).textContent = 'No booking token provided. Please use the link from your confirmation email.';
      showState('state-error');
      return;
    }

    try {
      const res = await fetch(`/api/cancel?token=${encodeURIComponent(token)}`);
      const data = await res.json();

      if (!res.ok) {
        (document.getElementById('error-msg') as HTMLElement).textContent = data.error || 'Booking not found.';
        showState('state-error');
        return;
      }

      if (data.status === 'cancelled') {
        showState('state-already');
        return;
      }

      (document.getElementById('d-barber') as HTMLElement).textContent = data.barber;
      (document.getElementById('d-service') as HTMLElement).textContent = data.service;
      const dateObj = new Date(data.date + 'T12:00:00Z');
      (document.getElementById('d-date') as HTMLElement).textContent = dateObj.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long' });
      (document.getElementById('d-time') as HTMLElement).textContent = data.time;

      showState('state-found');
    } catch {
      (document.getElementById('error-msg') as HTMLElement).textContent = 'Could not look up your booking. Please try again.';
      showState('state-error');
    }
  }

  document.getElementById('cancel-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('cancel-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Cancelling...';

    try {
      const res = await fetch('/api/cancel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token }),
      });
      const data = await res.json();

      if (data.success) {
        showState('state-cancelled');
      } else if (data.error?.includes('already')) {
        showState('state-already');
      } else {
        btn.disabled = false;
        btn.textContent = 'Cancel This Booking';
        (document.getElementById('error-msg') as HTMLElement).textContent = data.error || 'Cancellation failed. Please try again.';
        showState('state-error');
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Cancel This Booking';
      (document.getElementById('error-msg') as HTMLElement).textContent = 'Network error. Please try again.';
      showState('state-error');
    }
  });

  init();
</script>

</body>
</html>
