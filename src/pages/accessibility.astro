---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { siteConfig } from '../config';
---

<Layout
  title="Accessibility Statement - Chiltern Computers"
  description="Accessibility statement for Chiltern Computers. WCAG 2.1 AA conformance details and my commitment to making services accessible to everyone."
  noindex={true}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Accessibility', url: '/accessibility/' },
  ]}
>
  <div class="section-bg-3" style="padding: 120px 20px 80px; min-height: 100vh;">
    <div class="container">
      <!-- Page Header -->
      <div style="text-align: center; margin-bottom: 60px;">
        <h1
          class="space-font galaxy-text cosmic-glow"
          style="font-size: clamp(32px, 6vw, 48px); margin-bottom: 16px;"
        >
          Accessibility Statement
        </h1>
        <div style="height: 3px; width: 120px; background: linear-gradient(90deg, var(--solar-orange), var(--mars-red)); margin: 0 auto 20px; border-radius: 2px;"></div>
        <p class="alien-font" style="color: var(--comet-silver); font-size: 16px; max-width: 600px; margin: 0 auto;">
          Last updated: 18 March 2026
        </p>
      </div>

      <div style="max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 24px;">

        <!-- Commitment -->
        <div class="cosmic-card" style="padding: 32px;">
          <h2 class="space-font" style="color: var(--solar-orange); font-size: 22px; margin-bottom: 16px;">
            My Commitment
          </h2>
          <p class="alien-font" style="color: var(--starlight-white); line-height: 1.7; margin-bottom: 12px;">
            Chiltern Computers is committed to ensuring digital accessibility for people of all abilities. I continually improve the user experience for everyone and apply the relevant accessibility standards.
          </p>
          <p class="alien-font" style="color: var(--starlight-white); line-height: 1.7;">
            This website aims to conform to <strong>WCAG 2.1 Level AA</strong> standards. This statement was last reviewed on 18 March 2026.
          </p>
        </div>

        <!-- Conformance Status -->
        <div class="cosmic-card" style="padding: 32px;">
          <h2 class="space-font" style="color: var(--solar-orange); font-size: 22px; margin-bottom: 16px;">
            WCAG 2.1 AA Conformance
          </h2>
          <p class="alien-font" style="color: var(--starlight-white); line-height: 1.7; margin-bottom: 20px;">
            This site has been built and tested against the Web Content Accessibility Guidelines (WCAG) 2.1 Level AA criteria. Below is a summary of conformance:
          </p>
          <div style="overflow-x: auto;">
            <table class="alien-font" style="width: 100%; border-collapse: collapse; font-size: 14px;">
              <thead>
                <tr style="border-bottom: 2px solid var(--plasma-cyan);">
                  <th style="text-align: left; padding: 12px 16px; color: var(--plasma-cyan); font-weight: 600;">Guideline</th>
                  <th style="text-align: left; padding: 12px 16px; color: var(--plasma-cyan); font-weight: 600;">Status</th>
                </tr>
              </thead>
              <tbody>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="padding: 12px 16px; color: var(--starlight-white);">1.1 Text Alternatives</td>
                  <td style="padding: 12px 16px; color: var(--aurora-green);">Conforming</td>
                </tr>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="padding: 12px 16px; color: var(--starlight-white);">1.3 Adaptable</td>
                  <td style="padding: 12px 16px; color: var(--aurora-green);">Conforming</td>
                </tr>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="padding: 12px 16px; color: var(--starlight-white);">1.4 Distinguishable</td>
                  <td style="padding: 12px 16px; color: var(--aurora-green);">Conforming</td>
                </tr>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="padding: 12px 16px; color: var(--starlight-white);">2.1 Keyboard Accessible</td>
                  <td style="padding: 12px 16px; color: var(--aurora-green);">Conforming</td>
                </tr>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="padding: 12px 16px; color: var(--starlight-white);">2.4 Navigable</td>
                  <td style="padding: 12px 16px; color: var(--aurora-green);">Conforming</td>
                </tr>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="padding: 12px 16px; color: var(--starlight-white);">2.5 Input Modalities</td>
                  <td style="padding: 12px 16px; color: var(--aurora-green);">Conforming</td>
                </tr>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="padding: 12px 16px; color: var(--starlight-white);">3.1 Readable</td>
                  <td style="padding: 12px 16px; color: var(--aurora-green);">Conforming</td>
                </tr>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="padding: 12px 16px; color: var(--starlight-white);">3.2 Predictable</td>
                  <td style="padding: 12px 16px; color: var(--aurora-green);">Conforming</td>
                </tr>
                <tr>
                  <td style="padding: 12px 16px; color: var(--starlight-white);">4.1 Compatible</td>
                  <td style="padding: 12px 16px; color: var(--aurora-green);">Conforming</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- What I've implemented -->
        <div class="cosmic-card" style="padding: 32px;">
          <h2 class="space-font" style="color: var(--solar-orange); font-size: 22px; margin-bottom: 16px;">
            Accessibility Features
          </h2>
          <ul class="alien-font" style="color: var(--starlight-white); line-height: 1.8; padding-left: 20px;">
            <li>Skip-to-content link for keyboard users</li>
            <li>Semantic HTML with proper heading hierarchy</li>
            <li>ARIA labels on all interactive elements</li>
            <li>Focus-visible indicators on links, buttons, and form fields</li>
            <li>Colour contrast meeting 4.5:1 ratio for normal text</li>
            <li>Keyboard-navigable menus with Escape key support</li>
            <li>SVG icons with <code>aria-hidden</code> for decorative elements</li>
            <li>Form validation with <code>aria-invalid</code> and visible error messages</li>
            <li>Touch targets minimum 44x44px</li>
            <li>Respects <code>prefers-reduced-motion</code> — all animations disabled</li>
            <li>Respects <code>prefers-contrast: high</code> — enhanced borders</li>
            <li>Cookie consent banner with focus trap and inert background</li>
            <li>Mobile-friendly responsive design</li>
            <li>Print stylesheet support</li>
          </ul>
        </div>

        <!-- Browser & AT Compatibility -->
        <div class="cosmic-card" style="padding: 32px;">
          <h2 class="space-font" style="color: var(--solar-orange); font-size: 22px; margin-bottom: 16px;">
            Browser & Assistive Technology Compatibility
          </h2>
          <p class="alien-font" style="color: var(--starlight-white); line-height: 1.7; margin-bottom: 12px;">
            This website is designed to work with:
          </p>
          <ul class="alien-font" style="color: var(--starlight-white); line-height: 1.8; padding-left: 20px;">
            <li>Chrome, Firefox, Safari, Edge (latest versions)</li>
            <li>Screen readers: NVDA, JAWS, VoiceOver, TalkBack</li>
            <li>Voice control software</li>
            <li>Keyboard-only navigation</li>
            <li>Browser zoom up to 200%</li>
          </ul>
        </div>

        <!-- Physical Accessibility -->
        <div class="cosmic-card" style="padding: 32px;">
          <h2 class="space-font" style="color: var(--solar-orange); font-size: 22px; margin-bottom: 16px;">
            Physical Accessibility
          </h2>
          <p class="alien-font" style="color: var(--starlight-white); line-height: 1.7; margin-bottom: 12px;">
            At my Harold Hill workshop:
          </p>
          <ul class="alien-font" style="color: var(--starlight-white); line-height: 1.8; padding-left: 20px;">
            <li>Ground floor access</li>
            <li>Collection and delivery service available</li>
            <li>Flexible appointment times</li>
            <li>Patient, clear communication</li>
            <li>Support by phone, email, WhatsApp, or in person</li>
            <li>Carers and family members welcome to join</li>
          </ul>
        </div>

        <!-- Feedback -->
        <div class="cosmic-card" style="padding: 32px;">
          <h2 class="space-font" style="color: var(--solar-orange); font-size: 22px; margin-bottom: 16px;">
            Feedback
          </h2>
          <p class="alien-font" style="color: var(--starlight-white); line-height: 1.7; margin-bottom: 16px;">
            If you encounter any accessibility barriers on this website, or have suggestions for improvement, please contact me:
          </p>
          <div style="background: rgba(245, 158, 11, 0.1); border: 1px solid var(--solar-orange); border-radius: 8px; padding: 20px;">
            <p class="alien-font" style="color: var(--starlight-white); font-size: 14px; line-height: 1.8; margin: 0;">
              <Icon name="email" size={14} style="display:inline-block; vertical-align:-2px;" /> <a href="mailto:david@chilterncomputers.net" style="color: var(--plasma-cyan); text-decoration: none;">david@chilterncomputers.net</a><br />
              <Icon name="mobile" size={14} style="display:inline-block; vertical-align:-2px;" /> <a href={`tel:${siteConfig.phone.mobile}`} style="color: var(--plasma-cyan); text-decoration: none;">{siteConfig.phone.mobileDisplay}</a><br />
              <Icon name="map-pin" size={14} style="display:inline-block; vertical-align:-2px;" /> {siteConfig.address.full}
            </p>
          </div>
        </div>

        <div style="text-align: center; margin-top: 16px;">
          <a href="/contact/" class="space-button space-font" style="font-size: 14px;">
            <Icon name="chat" size={14} /> Get in Touch
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
