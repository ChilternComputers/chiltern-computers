---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout>
  <main class="max-w-4xl mx-auto p-8">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold mb-4 text-blue-700">Contact Me</h1>
      <p class="text-gray-600 max-w-2xl mx-auto">
        Get in touch for professional IT support, custom PC builds, computer repairs and servicing.
     
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      <!-- Contact Information -->
      <div class="bg-gray-50 p-6 rounded-lg">
        <h2 class="text-xl font-semibold text-gray-800 mb-4">Get In Touch</h2>
        
        <div class="space-y-4">
          <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <span class="text-gray-700">01708 347341</span>
          </div>
          
          <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <span class="text-gray-700">07971 331 814</span>
          </div>
          
          <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <span class="text-gray-700">david@chilterncomputers.co.uk</span>
          </div>
          
          <div class="flex items-start space-x-3">
            <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <div class="text-gray-700">
              <div>38 Hilldene Avenue</div>
              <div>Harold Hill, Romford</div>
              <div>Essex. RM3 8YP</div>
            </div>
          </div>
          
          <div class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="text-gray-700">Mon - Sun: 9:00 AM - 9:00 PM</span>
          </div>
        </div>

        <div class="mt-6 pt-6 border-t border-gray-200">
          <h3 class="font-semibold text-gray-800 mb-2">Our Services</h3>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>• Custom PC Builds</li>
            <li>• Computer Repairs & Diagnostics</li>
            <li>• Refurbished Systems</li>
            <li>• IT Support</li>
          </ul>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <form method="POST" action="/api/contact" class="space-y-4 bg-white p-6 rounded-lg shadow border">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700">Name</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required 
              class="mt-1 block w-full border border-gray-300 rounded px-3 py-2 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            />
          </div>
          
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              class="mt-1 block w-full border border-gray-300 rounded px-3 py-2 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            />
          </div>
          
          <div>
            <label for="area" class="block text-sm font-medium text-gray-700">Area</label>
            <input 
              type="text" 
              id="area" 
              name="area" 
              class="mt-1 block w-full border border-gray-300 rounded px-3 py-2 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              placeholder="Your location/area (optional)"
            />
          </div>
          
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700">Message</label>
            <textarea 
              id="message" 
              name="message" 
              required 
              rows="4"
              class="mt-1 block w-full border border-gray-300 rounded px-3 py-2 shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              placeholder="Tell us about your requirements or the issue you're experiencing..."
            ></textarea>
          </div>
          
          <button 
            type="submit" 
            class="w-full bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition-colors duration-200"
          >
            Send Message
          </button>
        </form>
        
        <p class="text-xs text-gray-500 text-center mt-4">
          We typically respond within 24 hours.
        </p>
      </div>
    </div>
  </main>



<style>
  /* Enhanced form styling */
  form {
    background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  }
  
  /* Input focus enhancement */
  input:focus,
  textarea:focus,
  select:focus {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15);
  }
  
  /* Button hover enhancement */
  button:hover {
    box-shadow: 0 8px 20px rgba(59, 130, 246, 0.3);
  }
  
  /* Custom scrollbar for textarea */
  textarea::-webkit-scrollbar {
    width: 8px;
  }
  
  textarea::-webkit-scrollbar-track {
    background: #f1f5f9;
    border-radius: 4px;
  }
  
  textarea::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 4px;
  }
  
  textarea::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
  }
</style>