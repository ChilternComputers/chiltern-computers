  <div>
    <!-- Article Hero -->
    <section class="article-hero" style="padding: 100px 0 50px;">
      <div class="container">
        <nav class="breadcrumb tech-font">
          <a href="/">Home</a>
          <span>/</span>
          <a href="/blog/">Blog</a>
          <span>/</span>
