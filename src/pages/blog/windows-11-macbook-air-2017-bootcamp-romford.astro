const author = 'David Hagon';
const readTime = '7 min read';

const faqs = [
  {
    question: 'Can a 2017 MacBook Air really run Windows 11?',
    answer:
      "Yes. I've just installed Windows 11 Pro on a 2017 MacBook Air via Boot Camp here in Harold Hill. Officially Microsoft says no — the machine lacks TPM 2.0 and uses a CPU older than the supported list. In practice, with the right approach during installation, Windows 11 runs cleanly on it, gets updates, and the MacBook keeps full Apple hardware support (trackpad, keyboard, brightness, audio) via the Boot Camp drivers.",
  },
  {
    question: 'Which older Macs can run Windows 11 via Boot Camp?',
    answer:
      'Most Intel-based Macs from 2013 onwards are good candidates: the 2013-2020 MacBook Air, 2012-2019 MacBook Pro, 2013-2019 iMac, and 2013-2018 Mac mini. Anything with 8 GB RAM or more, an SSD, and at least an Intel Core i5 will handle Windows 11 well. M1/M2/M3 Apple Silicon Macs are a different story — they can run Windows 11 ARM via Parallels but not via Boot Camp (Apple removed Boot Camp from Apple Silicon).',
  },
  {
    question: "Why would I want Windows 11 on a MacBook instead of just using macOS?",
    answer:
      'Common reasons: software that only runs on Windows (engineering apps, accounting tools, games, niche business software), needing a familiar Windows environment for work, or just getting more years out of a Mac that Apple has dropped from current macOS support. A 2017 MacBook Air can be a perfectly capable Windows 11 laptop — better build quality than most £300 PCs at this price point.',
  },
  {
    question: 'Does Boot Camp install Windows 11 by default?',
    answer:
      "No. Apple's Boot Camp Assistant only officially supports Windows 10 on most older Macs. Boot Camp Assistant simply won't offer Windows 11 as an option. That's where it needs an experienced engineer to bridge the gap — getting Windows 11 onto the machine while keeping Boot Camp's Apple drivers working so the trackpad, keyboard, audio, and brightness controls all function correctly.",
  },
  {
    question: 'How much does a Windows 11 Boot Camp install cost in Romford?',
    answer:
      "I price this per job based on your specific Mac and what you need. Typically it covers data backup if needed, the Windows 11 install, all the Apple hardware drivers, and verification that everything works (Wi-Fi, trackpad, keyboard, sound, brightness, etc.). Get in touch with the Mac model and I'll give you a fixed-price quote. No fix, no fee applies if for any reason your specific hardware turns out to be incompatible.",
  },
  {
    question: 'Will my MacBook still run macOS after the Windows 11 install?',
    answer:
      "Yes. Boot Camp creates a dual-boot setup — macOS stays on its own partition, Windows 11 lives on a separate one. You choose which OS to boot at startup by holding the Option key. Switch between them whenever you want. Your macOS apps, Apple ID, and existing files stay intact.",
  },
];
