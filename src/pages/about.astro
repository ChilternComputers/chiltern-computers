---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import StarRating from '../components/StarRating.astro';
---

<Layout
  title="About Us - PC Repair Harold Hill, Romford"
  description="Meet David, your local PC repair expert. Established 2007 — honest, affordable computer repairs in Harold Hill, Romford and Essex."
  keywords="about chiltern computers, computer repair harold hill, pc repair romford, david hagon, local computer repair essex"
  type="website"
  modifiedTime="2026-03-18"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'About Us', url: '/about/' },
  ]}
>
  <style>
    /* PAGE-SPECIFIC STYLES FOR ABOUT PAGE */

    /* Larger planet icon for this page */
    .planet-icon {
      width: 80px;
      height: 80px;
      font-size: 32px;
    }

    .small-planet-icon {
      width: 50px;
      height: 50px;
      font-size: 20px;
      margin: 0 auto 12px;
      animation: orbit 15s linear infinite;
    }

    /* BACKGROUND */
    .section-bg {
      background:
        radial-gradient(ellipse at 20% 80%, rgba(124, 58, 237, 0.15) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 20%, rgba(30, 58, 138, 0.12) 0%, transparent 50%),
        var(--void-black);
      background-size:
        800px 600px,
        900px 700px;
      animation: plasma-flow 30s ease-in-out infinite;
      min-height: 100vh;
      width: 100%;
      overflow-x: hidden;
    }

    /* CONTENT STYLES */
    .content-text {
      color: var(--comet-silver);
      font-size: 16px;
      line-height: 1.7;
      margin-bottom: 24px;
    }

    .contact-info {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .contact-info li {
      color: var(--starlight-white);
      font-size: 16px;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .contact-info a {
      color: var(--plasma-cyan);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    .contact-info a:hover {
      color: var(--aurora-green);
    }

    /* TESTIMONIALS */
    .testimonial-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
      margin-top: 40px;
    }

    .testimonial-card {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 58, 138, 0.1));
      border: 1px solid var(--solar-orange);
      border-radius: 12px;
      backdrop-filter: blur(10px);
      box-shadow: 0 4px 12px rgba(245, 158, 11, 0.2);
      padding: 24px;
      transition: all 0.3s ease;
      position: relative;
    }

    .testimonial-card:hover {
      transform: translateY(-4px);
      border-color: var(--aurora-green);
      box-shadow: 0 8px 25px rgba(16, 185, 129, 0.3);
    }

    .stars {
      color: var(--solar-orange);
      font-size: 20px;
      margin-bottom: 16px;
      animation: stellar-blink 3s ease-in-out infinite;
    }

    .testimonial-text {
      color: var(--starlight-white);
      font-style: italic;
      margin-bottom: 16px;
      line-height: 1.6;
    }

    .testimonial-author {
      color: var(--plasma-cyan);
      font-size: 14px;
      font-weight: 600;
    }

    /* MOBILE OPTIMIZATIONS */
    @media (max-width: 768px) {
      .section-bg {
        background-size:
          400px 300px,
          450px 350px;
      }

      .container {
        padding: 0 16px;
      }

      .planet-icon {
        width: 60px;
        height: 60px;
        font-size: 24px;
      }

      .small-planet-icon {
        width: 40px;
        height: 40px;
        font-size: 16px;
      }

      .testimonial-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 480px) {
      .container {
        padding: 0 12px;
      }

      .content-text {
        font-size: 14px;
      }

      .contact-info li {
        font-size: 14px;
      }
    }
  </style>

  <!-- About Section -->
  <section class="section-bg" style="padding: 80px 0;">
    <div class="container">
      <!-- Header -->
      <div style="text-align: center; margin-bottom: 60px;">
        <h1
          class="space-font galaxy-text cosmic-glow"
          style="font-size: clamp(28px, 5vw, 48px); margin-bottom: 20px; margin-top: 20px; line-height: 1.2;"
        >
          ABOUT YOUR LOCAL COMPUTER REPAIR EXPERT
        </h1>

        <p
          class="alien-font"
          style="font-size: clamp(16px, 3vw, 20px); color: var(--comet-silver); margin-bottom: 32px; max-width: 700px; margin-left: auto; margin-right: auto; line-height: 1.4;"
        >
          Meet David, the engineer behind Chiltern Computers — established 2007, serving
          Harold Hill, Romford, and Essex.
        </p>
      </div>

      <!-- Main Content -->
      <div
        style="display: grid; grid-template-columns: 1fr; gap: 40px; max-width: 900px; margin: 0 auto;"
      >
        <!-- About Content -->
        <div class="cosmic-card" style="padding: 40px;">
          <div
            class="planet-icon"
            style="background: rgba(6, 182, 212, 0.2); color: var(--plasma-cyan); margin-bottom: 32px;"
            aria-hidden="true"
          >
            <Icon name="laptop" size={32} />
          </div>

          <h2
            class="space-font galaxy-text cosmic-glow"
            style="font-size: clamp(24px, 4vw, 32px); margin-bottom: 32px; text-align: center;"
          >
            PROFESSIONAL IT ENGINEER
          </h2>

          <p class="alien-font content-text">
            I'm David, the founder and engineer behind Chiltern Computers. Since 2007, I've been
            repairing, upgrading, and supplying computers and laptops, and I've
            helped thousands of satisfied customers across <a href="/areas/romford/" style="color: var(--plasma-cyan);">Romford</a> and nearby areas.
          </p>

          <p class="alien-font content-text">
            My goal is simple: to offer friendly, honest, and affordable computer services — without
            the jargon. Whether you're a home user, student, or small business, I provide
            professional support tailored to your needs.
          </p>

          <p class="alien-font content-text">
            From <a href="/services/repairs/" style="color: var(--plasma-cyan);">fixing a slow laptop</a> to <a href="/services/custom-pcs/" style="color: var(--plasma-cyan);">building a high-performance gaming PC</a>, I handle every job
            personally with care and precision. I also offer a local collection and return service
            across <a href="/areas/" style="color: var(--plasma-cyan);">Havering and Essex</a>.
          </p>

          <p class="alien-font content-text">
            I provide <a href="/services/virus-removal-romford/" style="color: var(--plasma-cyan);">virus removal</a>, <a href="/services/data-recovery-havering/" style="color: var(--plasma-cyan);">data recovery</a>, and <a href="/services/new-used/" style="color: var(--plasma-cyan);">new and refurbished PCs</a> — all with a £20 diagnostic check — waived if you go ahead with the repair.
          </p>

          <p class="alien-font content-text">
            Need help? Don't hesitate to <a href="/contact/" style="color: var(--plasma-cyan);">get in touch</a>. I'd be happy to assist.
          </p>
        </div>

        <!-- Qualifications & Experience -->
        <div class="cosmic-card" style="padding: 40px;">
          <h2
            class="space-font"
            style="color: var(--aurora-green); font-size: clamp(20px, 4vw, 28px); margin-bottom: 24px; text-align: center;"
          >
            QUALIFICATIONS & EXPERIENCE
          </h2>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 24px;">
            <div>
              <h3 class="space-font heading-cyan" style="font-size: 15px;">Technical Skills</h3>
              <ul class="alien-font" style="color: var(--comet-silver); font-size: 14px; line-height: 1.8; padding-left: 20px;">
                <li>Hardware diagnostics & component-level repair</li>
                <li>Windows, macOS & Linux installation and troubleshooting</li>
                <li>Network infrastructure, WiFi & router configuration</li>
                <li>Data recovery from failed HDDs, SSDs & USB drives</li>
                <li>Custom PC building & cable management</li>
                <li>Virus/malware removal & security hardening</li>
              </ul>
            </div>
            <div>
              <h3 class="space-font heading-green" style="font-size: 15px;">Experience</h3>
              <ul class="alien-font" style="color: var(--comet-silver); font-size: 14px; line-height: 1.8; padding-left: 20px;">
                <li><strong style="color: var(--starlight-white);">Est. 2007</strong> — Chiltern Computers founded</li>
                <li><strong style="color: var(--starlight-white);">10,000+</strong> repairs completed</li>
                <li><strong style="color: var(--starlight-white);">5/5</strong> Google Reviews rating</li>
                <li>Residential, business & education sector clients</li>
                <li>All major brands: Dell, HP, Lenovo, Asus, Acer, Apple</li>
                <li>Custom gaming builds from budget to high-end</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Case Studies -->
        <div class="cosmic-card" style="padding: 40px;">
          <h2
            class="space-font"
            style="color: var(--solar-orange); font-size: clamp(20px, 4vw, 28px); margin-bottom: 24px; text-align: center;"
          >
            RECENT REPAIR STORIES
          </h2>

          <div style="display: flex; flex-direction: column; gap: 24px;">
            <!-- Case Study 1 -->
            <div style="border-left: 3px solid var(--plasma-cyan); padding-left: 20px;">
              <h3 class="space-font" style="color: var(--plasma-cyan); font-size: 16px; margin-bottom: 8px;">
                Laptop wouldn't boot — data recovered, SSD upgraded
              </h3>
              <p class="tech-font" style="color: var(--text-muted); font-size: 12px; margin-bottom: 8px;">
                Client: Home user, Hornchurch · Device: HP Pavilion (2019)
              </p>
              <p class="alien-font" style="color: var(--comet-silver); font-size: 14px; line-height: 1.7; margin-bottom: 8px;">
                Customer brought in a laptop that wouldn't get past the Windows loading screen. Diagnostic revealed a failing mechanical hard drive with bad sectors. I recovered all photos, documents, and work files onto an external drive, then cloned the recoverable data to a new 512GB SSD. Reinstalled Windows, restored their files, and the laptop now boots in under 15 seconds.
              </p>
              <p class="alien-font" style="color: var(--aurora-green); font-size: 13px; font-weight: 600;">
                Result: Full data recovery + 10x faster boot time. Cost: £95 (inc. SSD)
              </p>
            </div>

            <!-- Case Study 2 -->
            <div style="border-left: 3px solid var(--aurora-green); padding-left: 20px;">
              <h3 class="space-font" style="color: var(--aurora-green); font-size: 16px; margin-bottom: 8px;">
                Business network down — remote office back online same day
              </h3>
              <p class="tech-font" style="color: var(--text-muted); font-size: 12px; margin-bottom: 8px;">
                Client: Small business (3 staff), Harold Hill · Issue: No internet, WiFi dropping
              </p>
              <p class="alien-font" style="color: var(--comet-silver); font-size: 14px; line-height: 1.7; margin-bottom: 8px;">
                A local accountancy firm called at 10am — their internet had been intermittent for a week and finally died. I visited on-site within the hour, diagnosed a failing router and incorrectly configured DNS settings from their ISP. Replaced the router, configured a proper network with separate guest WiFi, set up automatic backups to a NAS drive, and had all three workstations back online by 2pm.
              </p>
              <p class="alien-font" style="color: var(--aurora-green); font-size: 13px; font-weight: 600;">
                Result: Same-day fix, zero data loss, reliable network. Cost: £80 (exc. router)
              </p>
            </div>
          </div>
        </div>

        <!-- Contact Info -->
        <div class="cosmic-card" style="padding: 32px;">
          <div
            class="small-planet-icon"
            style="background: rgba(16, 185, 129, 0.2); color: var(--aurora-green);"
            aria-hidden="true"
          >
            <Icon name="map-pin" size={20} />
          </div>

          <h3
            class="space-font cosmic-glow"
            style="color: var(--aurora-green); font-size: 20px; margin-bottom: 24px; text-align: center;"
          >
            CONTACT INFORMATION
          </h3>

          <ul class="contact-info alien-font">
            <li><Icon name="map-pin" size={14} class="icon-inline" /> Based in: Harold Hill, covering the local area</li>
            <li><Icon name="phone" size={14} class="icon-inline" /> Phone: 07971 331814 / 01708 347341</li>
            <li>
              <Icon name="email" size={14} class="icon-inline" /> Email: <a href="mailto:david@chilterncomputers.net">david@chilterncomputers.net</a>
            </li>
            <li>
              <Icon name="chat" size={14} class="icon-inline" /> WhatsApp: <a
                href="https://wa.me/447971331814"
                target="_blank"
                rel="noopener noreferrer">07971 331814</a
              >
            </li>
          </ul>
        </div>
      </div>

      <!-- Testimonials Section -->
      <div style="margin-top: 80px;">
        <h2
          class="space-font galaxy-text cosmic-glow"
          style="font-size: clamp(28px, 5vw, 40px); margin-bottom: 40px; text-align: center;"
        >
          CUSTOMER TESTIMONIALS
        </h2>

        <p
          class="alien-font"
          style="font-size: clamp(16px, 3vw, 18px); color: var(--comet-silver); margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto; text-align: center; line-height: 1.4;"
        >
          Hear from satisfied customers who trust Chiltern Computers for their IT needs.
        </p>

        <div class="testimonial-grid">
          <div class="testimonial-card">
            <div class="stars"><StarRating rating={5} size={16} /></div>
            <p class="testimonial-text alien-font">
              "David fixed my laptop quickly and explained everything clearly. Highly recommended!"
            </p>
            <div class="testimonial-author tech-font">– Sarah M.</div>
          </div>

          <div class="testimonial-card">
            <div class="stars"><StarRating rating={5} size={16} /></div>
            <p class="testimonial-text alien-font">
              "Great service and fair prices. Wouldn't go anywhere else for PC repairs."
            </p>
            <div class="testimonial-author tech-font">– James P.</div>
          </div>

          <div class="testimonial-card">
            <div class="stars"><StarRating rating={5} size={16} /></div>
            <p class="testimonial-text alien-font">
              "Friendly, professional, and very knowledgeable. Helped me recover lost data fast."
            </p>
            <div class="testimonial-author tech-font">– Anita L.</div>
          </div>

          <div class="testimonial-card">
            <div class="stars"><StarRating rating={5} size={16} /></div>
            <p class="testimonial-text alien-font">
              "Excellent service every time. Always goes the extra mile to help."
            </p>
            <div class="testimonial-author tech-font">– Tom H.</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
