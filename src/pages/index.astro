  <!-- Booking system styles -->
  <style is:global>
    /* ===== BOOKING WRAPPER ===== */
    .booking-wrapper {
      background: var(--deep-space);
      border: 1px solid rgba(6,182,212,0.15);
      border-radius: 16px;
      padding: 36px;
      max-width: 680px;
      margin: 0 auto;
    }
    .booking-steps {
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 32px; padding-bottom: 24px;
      border-bottom: 1px solid rgba(6,182,212,0.1);
    }
    .step { display: flex; flex-direction: column; align-items: center; gap: 6px; }
    .step-num {
      width: 30px; height: 30px; border-radius: 50%;
      border: 2px solid rgba(6,182,212,0.2);
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; color: rgba(248,250,252,0.3);
      transition: all 0.4s ease;
    }
    .step.active .step-num { border-color: var(--plasma-cyan); color: var(--void-black); background: var(--plasma-cyan); box-shadow: 0 0 14px rgba(6,182,212,0.3); }
    .step.completed .step-num { border-color: var(--plasma-cyan); color: var(--plasma-cyan); background: rgba(6,182,212,0.15); }
    .step-label { font-size: 9px; font-weight: 600; letter-spacing: 0.5px; color: rgba(248,250,252,0.3); transition: color 0.4s ease; }
    .step.active .step-label, .step.completed .step-label { color: var(--plasma-cyan); }
    .step-line { flex: 1; height: 1px; background: rgba(6,182,212,0.15); margin: 0 8px; margin-bottom: 18px; max-width: 40px; }

    /* Buttons */
    .bk-btn {
      display: inline-block; padding: 16px 40px; border-radius: 6px; font-weight: 700;
      font-size: 15px; text-decoration: none; transition: all 0.3s ease;
      cursor: pointer; border: 2px solid transparent; letter-spacing: 0.5px;
      font-family: inherit;
    }
    .bk-btn-primary { background: var(--plasma-cyan); color: var(--void-black); border-color: var(--plasma-cyan); }
    .bk-btn-primary:hover { background: transparent; color: var(--plasma-cyan); }
    .bk-btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }
    .bk-btn-ghost { background: transparent; color: var(--starlight-white); border-color: rgba(248,250,252,0.2); }
    .bk-btn-ghost:hover { border-color: var(--plasma-cyan); color: var(--plasma-cyan); }

    /* Field labels */
    .bk-field-label { display: block; font-weight: 600; font-size: 12px; color: rgba(248,250,252,0.6); margin-bottom: 14px; letter-spacing: 1px; text-transform: uppercase; }

    /* Form groups */
    .bk-form-group { margin-bottom: 20px; }
    .bk-form-group label { display: block; font-weight: 600; font-size: 13px; color: rgba(248,250,252,0.7); margin-bottom: 6px; letter-spacing: 0.5px; }
    .bk-form-group input {
      width: 100%; padding: 12px 16px;
      border: 1px solid rgba(6,182,212,0.12); border-radius: 6px;
      font-size: 15px; font-family: inherit;
      background: var(--void-black); color: var(--starlight-white);
      transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }
    .bk-form-group input:focus { outline: none; border-color: var(--plasma-cyan); box-shadow: 0 0 0 3px rgba(6,182,212,0.1); }

    /* Barber grid */
    .barber-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .barber-card {
      display: flex; flex-direction: column; align-items: center; gap: 12px;
      padding: 24px 16px; background: var(--void-black); border: 1px solid rgba(6,182,212,0.1);
      border-radius: 12px; cursor: pointer; transition: all 0.3s ease;
      color: var(--starlight-white); font-family: inherit;
    }
    .barber-card:hover { border-color: rgba(6,182,212,0.4); background: rgba(6,182,212,0.04); }
    .barber-card.selected { border-color: var(--plasma-cyan); background: rgba(6,182,212,0.08); box-shadow: 0 0 16px rgba(6,182,212,0.15); }
    .barber-avatar {
      width: 56px; height: 56px; border-radius: 50%;
      background: linear-gradient(135deg, var(--plasma-cyan), var(--cosmic-blue));
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; font-weight: 800; color: var(--void-black);
    }
    .barber-avatar.any-avatar { background: linear-gradient(135deg, var(--aurora-green), #059669); font-size: 18px; }
    .barber-info { text-align: center; }
    .barber-name { display: block; font-weight: 700; font-size: 15px; }
    .barber-role { display: block; font-size: 11px; color: rgba(248,250,252,0.45); margin-top: 2px; }
    .barber-status-badge {
      display: inline-block; font-size: 9px; font-weight: 700; letter-spacing: 1px;
      padding: 2px 8px; border-radius: 4px; margin-top: 4px; text-transform: uppercase;
    }
    .barber-status-badge.away { background: rgba(245,158,11,0.15); color: #f59e0b; }
    .barber-status-badge.holiday { background: rgba(239,68,68,0.15); color: #ef4444; }

    /* Calendar */
    .calendar-legend { display: flex; gap: 16px; justify-content: center; margin-bottom: 16px; flex-wrap: wrap; }
    .legend-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: rgba(248,250,252,0.55); }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
    .legend-dot.green { background: #22c55e; }
    .legend-dot.amber { background: #f59e0b; }
    .legend-dot.red { background: #ef4444; }
    .legend-dot.closed { background: rgba(248,250,252,0.12); }
    .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 8px; }

    .cal-day {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 12px 4px; border-radius: 8px; cursor: pointer;
      border: 1px solid transparent; transition: all 0.25s ease;
      font-family: inherit; min-height: 64px; background: transparent;
    }
    .cal-day .cal-label { font-size: 10px; font-weight: 600; color: rgba(248,250,252,0.45); letter-spacing: 0.5px; }
    .cal-day .cal-num { font-size: 18px; font-weight: 800; margin-top: 2px; }
    .cal-day .cal-indicator { width: 8px; height: 8px; border-radius: 50%; margin-top: 4px; }
    .cal-day.green { background: rgba(34,197,94,0.08); }
    .cal-day.green .cal-num { color: #22c55e; }
    .cal-day.green .cal-indicator { background: #22c55e; }
    .cal-day.green:hover { border-color: #22c55e; background: rgba(34,197,94,0.15); }
    .cal-day.amber { background: rgba(245,158,11,0.08); }
    .cal-day.amber .cal-num { color: #f59e0b; }
    .cal-day.amber .cal-indicator { background: #f59e0b; }
    .cal-day.amber:hover { border-color: #f59e0b; background: rgba(245,158,11,0.15); }
    .cal-day.red { background: rgba(239,68,68,0.06); cursor: not-allowed; }
    .cal-day.red .cal-num { color: #ef4444; opacity: 0.6; }
    .cal-day.red .cal-indicator { background: #ef4444; }
    .cal-day.closed { background: rgba(248,250,252,0.02); cursor: not-allowed; }
    .cal-day.closed .cal-num { color: rgba(248,250,252,0.15); }
    .cal-day.closed .cal-indicator { background: rgba(248,250,252,0.08); }
    .cal-day.selected { border-color: var(--plasma-cyan) !important; box-shadow: 0 0 12px rgba(6,182,212,0.25); }

    /* Service grid */
    .service-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .service-btn {
      display: flex; flex-direction: column; align-items: center; gap: 6px;
      padding: 20px 12px; background: var(--void-black); border: 1px solid rgba(6,182,212,0.1);
      border-radius: 12px; cursor: pointer; transition: all 0.3s ease;
      color: var(--starlight-white); font-family: inherit; text-align: center;
    }
    .service-btn:hover { border-color: rgba(6,182,212,0.4); background: rgba(6,182,212,0.05); transform: translateY(-2px); }
    .service-btn.selected { border-color: var(--plasma-cyan); background: rgba(6,182,212,0.1); box-shadow: 0 0 14px rgba(6,182,212,0.2); }
    .service-icon { font-size: 24px; line-height: 1; margin-bottom: 2px; }
    .service-name { font-weight: 700; font-size: 14px; line-height: 1.3; }
    .service-meta { font-size: 11px; color: rgba(248,250,252,0.4); font-weight: 500; }
    .service-price { font-weight: 800; color: var(--plasma-cyan); font-size: 18px; }

    /* Time slots */
    .slots-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
    .slot-btn {
      padding: 16px 8px; background: var(--void-black); border: 1px solid rgba(6,182,212,0.12);
      border-radius: 10px; color: var(--starlight-white); font-family: inherit;
      font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.2s ease;
      letter-spacing: 0.5px;
    }
    .slot-btn:hover:not(.booked) { border-color: var(--plasma-cyan); background: rgba(6,182,212,0.08); transform: translateY(-2px); }
    .slot-btn.selected { background: var(--plasma-cyan); color: var(--void-black); border-color: var(--plasma-cyan); box-shadow: 0 0 14px rgba(6,182,212,0.3); transform: translateY(-2px); }
    .slot-btn.booked { opacity: 0.2; cursor: not-allowed; text-decoration: line-through; }

    /* Any available mode */
    .slots-grid.any-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
    .any-card {
      background: var(--void-black); border: 1px solid rgba(6,182,212,0.08);
      border-radius: 10px; padding: 14px 12px; text-align: center; transition: all 0.2s ease;
    }
    .any-card.selected { border-color: var(--plasma-cyan); background: rgba(6,182,212,0.06); }
    .any-card.fully-booked { opacity: 0.25; }
    .any-card-time { font-size: 17px; font-weight: 800; color: var(--plasma-cyan); margin-bottom: 10px; letter-spacing: 0.5px; }
    .any-card.fully-booked .any-card-time { text-decoration: line-through; color: rgba(248,250,252,0.3); }
    .any-card-barbers { display: flex; flex-direction: column; gap: 5px; }
    .any-barber-btn {
      display: block; width: 100%; padding: 7px 8px; border-radius: 6px;
      font-size: 12px; font-weight: 600; font-family: inherit;
      border: 1px solid rgba(6,182,212,0.12); background: rgba(6,182,212,0.04);
      color: rgba(248,250,252,0.7); cursor: pointer; transition: all 0.2s ease;
    }
    .any-barber-btn:hover:not(.unavailable) { border-color: var(--plasma-cyan); color: var(--starlight-white); background: rgba(6,182,212,0.12); }
    .any-barber-btn.selected { background: var(--plasma-cyan); color: var(--void-black); border-color: var(--plasma-cyan); }
    .any-barber-btn.unavailable { text-decoration: line-through; opacity: 0.35; cursor: not-allowed; border-color: transparent; background: transparent; }

    /* Booking summary */
    .booking-summary { background: rgba(6,182,212,0.06); border: 1px solid rgba(6,182,212,0.15); border-radius: 10px; padding: 16px 20px; }
    .summary-row { display: flex; justify-content: space-between; padding: 8px 0; font-size: 14px; }
    .summary-label { color: rgba(248,250,252,0.55); }
    .summary-value { color: var(--starlight-white); font-weight: 600; }
    .summary-value.gold { color: var(--plasma-cyan); font-size: 16px; }

    /* Spinner */
    .bk-spinner { width: 28px; height: 28px; border: 3px solid rgba(6,182,212,0.15); border-top-color: var(--plasma-cyan); border-radius: 50%; animation: bkSpin 0.8s linear infinite; margin: 0 auto; }
    @keyframes bkSpin { to { transform: rotate(360deg); } }

    /* Responsive */
    @media (max-width: 580px) {
      .barber-grid { grid-template-columns: 1fr; max-width: 280px; margin: 0 auto; }
      .calendar-grid { grid-template-columns: repeat(7, 1fr); gap: 4px; }
      .cal-day { padding: 8px 2px; min-height: 52px; }
      .cal-day .cal-num { font-size: 14px; }
      .cal-day .cal-label { font-size: 8px; }
      .service-grid { grid-template-columns: 1fr; }
      .slots-grid { grid-template-columns: 1fr; }
      .slots-grid.any-grid { grid-template-columns: repeat(2, 1fr); }
      .booking-wrapper { padding: 24px 16px; }
      .booking-steps { gap: 0; }
      .step-label { font-size: 8px; }
      .bk-form-group + div { grid-template-columns: 1fr !important; }
    }
  </style>

  <!-- Booking system JavaScript -->
  <script>
    // ===== BOOKING SYSTEM (4-step: Barber → Calendar → Time/Service → Confirm) =====
    const booking: { barber: string; barberName: string; chosenBarber: string; chosenBarberName: string; date: string; time: string; service: string; price: string } = {
      barber: '', barberName: '', chosenBarber: '', chosenBarberName: '',
      date: '', time: '', service: '', price: '',
    };

    const stepEls = document.querySelectorAll('.step');
    const errorBox = document.getElementById('booking-error') as HTMLElement;
    const errorText = document.getElementById('error-text') as HTMLElement;
    const calGrid = document.getElementById('calendar-grid') as HTMLElement;
    const calLoading = document.getElementById('cal-loading') as HTMLElement;
    const slotsGrid = document.getElementById('slots-grid') as HTMLElement;
    const slotsLoading = document.getElementById('slots-loading') as HTMLElement;
    const toStep4Btn = document.getElementById('to-step-4') as HTMLButtonElement;
    const bookingWrapper = document.querySelector('.booking-wrapper') as HTMLElement;

    function showStep(num: number | string) {
      document.querySelectorAll('.booking-step').forEach(s => (s as HTMLElement).style.display = 'none');
      const target = document.getElementById(`step-${num}`) as HTMLElement;
      if (target) target.style.display = 'block';
      stepEls.forEach(s => {
        const sn = parseInt(s.getAttribute('data-step') || '0');
        s.classList.remove('active', 'completed');
        if (typeof num === 'number') {
          if (sn === num) s.classList.add('active');
          if (sn < num) s.classList.add('completed');
        }
      });
      errorBox.style.display = 'none';
      if (bookingWrapper) {
        setTimeout(() => bookingWrapper.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
      }
    }

    function showError(msg: string) {
      errorText.textContent = msg;
      errorBox.style.display = 'block';
    }

    // Step 1: Load barbers dynamically
    const barberGridEl = document.getElementById('barber-grid') as HTMLElement;

    async function loadBarbers() {
      try {
        const res = await fetch('/api/barbers');
        const data = await res.json();
        barberGridEl.innerHTML = '';

        data.barbers.forEach((b: { id: string; name: string; role: string; status: string }) => {
          const card = document.createElement('button');
          card.type = 'button';
          card.className = 'barber-card';
          card.dataset.barber = b.id;
          const initial = b.name.charAt(0).toUpperCase();

          if (b.status !== 'active') {
            card.innerHTML = `
              <div class="barber-avatar" style="opacity:0.3;">${initial}</div>
              <div class="barber-info">
                <span class="barber-name" style="opacity:0.4;">${b.name}</span>
                <span class="barber-role" style="opacity:0.3;">${b.role}</span>
                <span class="barber-status-badge ${b.status}">${b.status === 'away' ? 'Away' : 'On Holiday'}</span>
              </div>
            `;
            card.style.cursor = 'not-allowed';
            card.style.opacity = '0.5';
          } else {
            card.innerHTML = `
              <div class="barber-avatar">${initial}</div>
              <div class="barber-info">
                <span class="barber-name">${b.name}</span>
                <span class="barber-role">${b.role}</span>
              </div>
            `;
            card.addEventListener('click', () => selectBarber(b.id, b.name));
          }
          barberGridEl.appendChild(card);
        });

        // Add "Any Available" card
        const anyCard = document.createElement('button');
        anyCard.type = 'button';
        anyCard.className = 'barber-card';
        anyCard.dataset.barber = 'any';
        anyCard.innerHTML = `
          <div class="barber-avatar any-avatar">&#10022;</div>
          <div class="barber-info">
            <span class="barber-name">Any Available</span>
            <span class="barber-role">First available barber</span>
          </div>
        `;
        anyCard.addEventListener('click', () => selectBarber('any', 'Any Available'));
        barberGridEl.appendChild(anyCard);
      } catch {
        barberGridEl.innerHTML = '<p style="color:#ef4444;text-align:center;padding:20px;">Could not load barbers. Please refresh.</p>';
      }
    }

    function selectBarber(id: string, name: string) {
      document.querySelectorAll('.barber-card').forEach(c => c.classList.remove('selected'));
      const card = barberGridEl.querySelector(`[data-barber="${id}"]`) as HTMLElement;
      if (card) card.classList.add('selected');
      booking.barber = id;
      booking.barberName = name;
      booking.chosenBarber = '';
      booking.chosenBarberName = '';
      booking.date = '';
      booking.time = '';
      booking.service = '';
      booking.price = '';
      showStep(2);
      loadCalendar();
    }

    loadBarbers();

    // Load 14-day traffic light calendar
    async function loadCalendar() {
      calGrid.innerHTML = '';
      calLoading.style.display = 'block';
      try {
        const res = await fetch(`/api/slots?mode=week&barber=${booking.barber}`);
        const data = await res.json();
        calLoading.style.display = 'none';
        calGrid.innerHTML = '';
        data.days.forEach((day: { date: string; day: string; status: string }) => {
          const el = document.createElement('button');
          el.type = 'button';
          const parts = day.day.split(' ');
          el.className = `cal-day ${day.status}`;
          el.innerHTML = `<span class="cal-label">${parts[0]}</span><span class="cal-num">${parts[1]}</span><span class="cal-indicator"></span>`;
          el.dataset.date = day.date;
          if (day.status === 'green' || day.status === 'amber') {
            el.addEventListener('click', () => {
              document.querySelectorAll('.cal-day').forEach(d => d.classList.remove('selected'));
              el.classList.add('selected');
              booking.date = day.date;
              showStep(3);
              const dateObj = new Date(day.date + 'T12:00:00Z');
              const dateLabel = dateObj.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long' });
              (document.getElementById('selected-date-label') as HTMLElement).textContent = `${booking.barberName} — ${dateLabel}`;
              loadSlots();
            });
          }
          calGrid.appendChild(el);
        });
      } catch {
        calLoading.style.display = 'none';
        showError('Could not load calendar. Please try again.');
      }
    }

    // Load time slots
    async function loadSlots() {
      slotsGrid.innerHTML = '';
      slotsLoading.style.display = 'block';
      booking.time = '';
      booking.service = '';
      booking.price = '';
      booking.chosenBarber = '';
      booking.chosenBarberName = '';
      document.querySelectorAll('.service-btn').forEach(b => b.classList.remove('selected'));
      toStep4Btn.disabled = true;

      try {
        const res = await fetch(`/api/slots?date=${booking.date}&barber=${booking.barber}`);
        const data = await res.json();
        slotsLoading.style.display = 'none';
        slotsGrid.innerHTML = '';

        if (booking.barber === 'any') {
          slotsGrid.className = 'slots-grid any-grid';
          data.slots.forEach((slot: { time: string; available: boolean; slotBarbers?: Array<{ id: string; name: string; status: string; available: boolean }> }) => {
            const card = document.createElement('div');
            card.className = `any-card${slot.available ? '' : ' fully-booked'}`;
            const timeEl = document.createElement('div');
            timeEl.className = 'any-card-time';
            timeEl.textContent = slot.time;
            card.appendChild(timeEl);
            const list = document.createElement('div');
            list.className = 'any-card-barbers';
            if (slot.slotBarbers) {
              slot.slotBarbers.forEach(b => {
                const item = document.createElement('button');
                item.type = 'button';
                if (b.available) {
                  item.className = 'any-barber-btn';
                  item.textContent = b.name;
                  item.addEventListener('click', () => {
                    clearSlotSelection();
                    item.classList.add('selected');
                    card.classList.add('selected');
                    booking.time = slot.time;
                    booking.chosenBarber = b.id;
                    booking.chosenBarberName = b.name;
                    checkStep3Ready();
                  });
                } else {
                  item.className = 'any-barber-btn unavailable';
                  item.textContent = b.name;
                  item.disabled = true;
                }
                list.appendChild(item);
              });
            }
            card.appendChild(list);
            slotsGrid.appendChild(card);
          });
        } else {
          slotsGrid.className = 'slots-grid';
          data.slots.forEach((slot: { time: string; available: boolean }) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = `slot-btn${slot.available ? '' : ' booked'}`;
            btn.textContent = slot.time;
            if (slot.available) {
              btn.addEventListener('click', () => {
                document.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('selected'));
                btn.classList.add('selected');
                booking.time = slot.time;
                checkStep3Ready();
              });
            }
            slotsGrid.appendChild(btn);
          });
        }
      } catch {
        slotsLoading.style.display = 'none';
        showError('Could not load time slots. Please try again.');
      }
    }

    function clearSlotSelection() {
      document.querySelectorAll('.any-barber-btn').forEach(c => c.classList.remove('selected'));
      document.querySelectorAll('.any-card').forEach(c => c.classList.remove('selected'));
      document.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('selected'));
    }

    // Service selection
    const timesLabel = document.getElementById('times-label') as HTMLElement;
    document.querySelectorAll('.service-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.service-btn').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        booking.service = (btn as HTMLElement).dataset.service || '';
        booking.price = (btn as HTMLElement).dataset.price || '';
        checkStep3Ready();
        setTimeout(() => timesLabel.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
      });
    });

    function checkStep3Ready() {
      toStep4Btn.disabled = !(booking.time && booking.service);
    }

    toStep4Btn.addEventListener('click', () => {
      if (!booking.time || !booking.service) return;
      showStep(4);
      renderSummary();
    });

    // Back buttons
    document.getElementById('back-to-1')?.addEventListener('click', () => showStep(1));
    document.getElementById('back-to-2')?.addEventListener('click', () => showStep(2));
    document.getElementById('back-to-3')?.addEventListener('click', () => showStep(3));

    function renderSummary() {
      const summary = document.getElementById('booking-summary') as HTMLElement;
      const dateObj = new Date(booking.date + 'T12:00:00Z');
      const dateStr = dateObj.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long' });
      const displayBarber = booking.chosenBarberName || booking.barberName;
      summary.innerHTML = `
        <div class="summary-row"><span class="summary-label">Barber</span><span class="summary-value">${displayBarber}</span></div>
        <div class="summary-row"><span class="summary-label">Date</span><span class="summary-value">${dateStr}</span></div>
        <div class="summary-row"><span class="summary-label">Time</span><span class="summary-value">${booking.time}</span></div>
        <div class="summary-row"><span class="summary-label">Service</span><span class="summary-value">${booking.service}</span></div>
        <div class="summary-row" style="border-top:1px solid rgba(6,182,212,0.15);padding-top:10px;margin-top:4px;"><span class="summary-label">Price</span><span class="summary-value gold">£${booking.price}</span></div>
      `;
    }

    // Confirm booking
    document.getElementById('confirm-booking')?.addEventListener('click', async () => {
      const emailInput = document.getElementById('b-email') as HTMLInputElement;
      const nameInput = document.getElementById('b-name') as HTMLInputElement;
      const phoneInput = document.getElementById('b-phone') as HTMLInputElement;
      const honeypot = document.getElementById('b-website') as HTMLInputElement;
      if (honeypot.value) return;

      const email = emailInput.value.trim();
      const name = nameInput.value.trim();
      const phone = phoneInput.value.trim();

      if (!email || !name || !phone) { showError('Please fill in all fields.'); return; }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showError('Please enter a valid email address.'); return; }
      if (name.length < 2) { showError('Please enter a valid name.'); return; }
      if (phone.length < 7) { showError('Please enter a valid phone number.'); return; }

      const confirmBtn = document.getElementById('confirm-booking') as HTMLButtonElement;
      confirmBtn.disabled = true;
      confirmBtn.textContent = 'Booking...';

      try {
        const res = await fetch('/api/book', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name, phone, email,
            service: booking.service,
            date: booking.date,
            time: booking.time,
            barber: booking.chosenBarber || booking.barber,
          }),
        });
        const data = await res.json();

        if (!res.ok) {
          showError(data.error || 'Booking failed. Please try again.');
          confirmBtn.disabled = false;
          confirmBtn.textContent = 'Confirm Booking';
          return;
        }

        const dateObj = new Date(booking.date + 'T12:00:00Z');
        const dateStr = dateObj.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long' });
        const confirmedBarber = data.booking?.barberName || booking.barberName;
        const msg = document.getElementById('confirm-message') as HTMLElement;
        msg.innerHTML = `
          <strong style="color:var(--plasma-cyan);">${booking.service}</strong> with
          <strong style="color:var(--starlight-white);">${confirmedBarber}</strong> booked for
          <strong style="color:var(--starlight-white);">${dateStr}</strong> at
          <strong style="color:var(--starlight-white);">${booking.time}</strong>.<br/>
          A confirmation email has been sent to <strong style="color:var(--plasma-cyan);">${email}</strong>.<br/>
          We'll see you then, ${name}!
        `;
        showStep('done');
        document.querySelectorAll('.step').forEach(s => s.classList.add('completed'));
      } catch {
        showError('Network error. Please try again.');
        confirmBtn.disabled = false;
        confirmBtn.textContent = 'Confirm Booking';
      }
    });

    // Book Another
    document.getElementById('new-booking')?.addEventListener('click', () => {
      booking.barber = '';
      booking.barberName = '';
      booking.chosenBarber = '';
      booking.chosenBarberName = '';
      booking.date = '';
      booking.time = '';
      booking.service = '';
      booking.price = '';
      document.querySelectorAll('.service-btn').forEach(b => b.classList.remove('selected'));
      document.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('selected'));
      document.querySelectorAll('.cal-day').forEach(d => d.classList.remove('selected'));
      (document.getElementById('b-email') as HTMLInputElement).value = '';
      (document.getElementById('b-name') as HTMLInputElement).value = '';
      (document.getElementById('b-phone') as HTMLInputElement).value = '';
      calGrid.innerHTML = '';
      slotsGrid.innerHTML = '';
      const confirmBtn = document.getElementById('confirm-booking') as HTMLButtonElement;
      confirmBtn.disabled = false;
      confirmBtn.textContent = 'Confirm Booking';
      loadBarbers();
      showStep(1);
    });
  </script>
</Layout>
