    date: '2024-12-05',
  },
  {
    author: 'Tom H.',
    location: 'Harold Wood',
    text: 'Great repair service. Professional work and my PC runs like new!',
    rating: 5,
    date: '2024-11-20',
  },
  {
    author: 'Rachel A.',
    location: 'Hornchurch',
    text: 'Built me an amazing gaming computer within budget. Excellent quality!',
    rating: 5,
    date: '2024-10-28',
  },
  {
    author: 'Mike D.',
