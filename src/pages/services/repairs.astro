    rating: 5,
    date: '2024-10-22',
  },
  {
    author: 'Claire S.',
    location: 'Brentwood',
    text: "MacBook wouldn't boot – they fixed it same day. Life saver!",
    rating: 5,
    date: '2024-09-18',
  },
];

