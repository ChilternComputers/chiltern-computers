  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Get Your Computer Repaired at Chiltern Computers',
  description:
    'Step-by-step guide to getting professional computer repair service from Chiltern Computers in Harold Hill, Romford.',
  totalTime: 'PT24H',
  estimatedCost: {
    '@type': 'MonetaryAmount',
    currency: 'GBP',
    value: '30-80',
  },
  supply: [],
  tool: [],
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Get in Touch',
      text: 'Contact us by phone, email, or visit our workshop to describe the problem with your device. Call 07971 331814 or email david@chilterncomputers.net.',
      url: 'https://chilterncomputers.net/contact/',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: '£20 Diagnostic Check',
      text: 'We thoroughly diagnose your device for just £20, usually within an hour. The diagnostic fee is waived if you go ahead with the repair.',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Expert Repair',
      text: 'Our experienced technician performs professional repairs, typically completed same day or next working day depending on parts availability.',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Pickup or Delivery',
      text: 'Collect your fully repaired device from our Harold Hill workshop, or take advantage of our local delivery service within Romford and surrounding areas.',
    },
  ],
};
