  type="service"
  publishedTime="2026-03-08"
  modifiedTime="2026-03-08"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Services', url: '/services/repairs/' },
    { name: 'Web Design', url: '/services/web-design/' },
  ]}
>
  <style>
    * {
      box-sizing: border-box;
    }
    html,
    body {
      overflow-x: hidden;
      width: 100%;
    }
    :root {
      --cosmic-blue: #1e3a8a;
      --nebula-purple: #7c3aed;
      --starlight-white: #f8fafc;
      --plasma-cyan: #06b6d4;
      --aurora-green: #10b981;
      --solar-orange: #f59e0b;
      --deep-space: #0f172a;
      --void-black: #020617;
      --comet-silver: #e5e7eb;
      --mars-red: #dc2626;
    }
    .space-font {
      font-family: 'Orbitron', sans-serif;
      font-weight: 600;
    }
    .alien-font {
      font-family: 'Exo 2', sans-serif;
    }
    .tech-font {
      font-family: 'Space Mono', monospace;
    }
    @keyframes cosmic-pulse {
      0%,
      100% {
        text-shadow: 0 0 5px currentColor;
      }
      50% {
        text-shadow: 0 0 15px currentColor;
      }
    }
    @keyframes galaxy-flow {
      0% {
        background-position: 0% 0%;
      }
      50% {
        background-position: 100% 100%;
      }
      100% {
        background-position: 0% 0%;
      }
    }
    .cosmic-glow {
      animation: cosmic-pulse 3s ease-in-out infinite alternate;
    }
    .galaxy-text {
      background: linear-gradient(
        135deg,
        var(--plasma-cyan),
        var(--aurora-green),
        var(--solar-orange)
      );
      background-size: 200% 200%;
      animation: galaxy-flow 4s ease-in-out infinite;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .section-bg {
      background: linear-gradient(135deg, rgba(2, 6, 23, 0.95), rgba(15, 23, 42, 0.9));
    }
    .cosmic-card {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 58, 138, 0.1));
      border: 1px solid var(--plasma-cyan);
      border-radius: 20px;
      backdrop-filter: blur(15px);
      box-shadow: 0 8px 32px rgba(6, 182, 212, 0.2);
      transition: all 0.3s ease;
    }
    .cosmic-card:hover {
      transform: translateY(-5px);
      border-color: var(--aurora-green);
    }
    .space-button {
      background: linear-gradient(135deg, var(--cosmic-blue), var(--nebula-purple));
      border: 1px solid var(--aurora-green);
      color: var(--starlight-white);
      padding: 14px 28px;
      border-radius: 25px;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      transition: all 0.3s ease;
    }
    .space-button:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 25px rgba(30, 58, 138, 0.4);
    }
    .container {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    /* Pricing Grid */
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .pricing-card {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 58, 138, 0.1));
      border: 1px solid var(--plasma-cyan);
      border-radius: 20px;
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      transition: all 0.3s ease;
    }
    .pricing-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 35px rgba(6, 182, 212, 0.25);
    }
    .pricing-card.featured {
      border-color: var(--aurora-green);
      box-shadow: 0 8px 32px rgba(16, 185, 129, 0.3);
      position: relative;
    }
    .pricing-card.premium {
      border-color: var(--nebula-purple);
      box-shadow: 0 8px 32px rgba(124, 58, 237, 0.3);
    }
    .pricing-card .price {
      font-size: clamp(28px, 4vw, 36px);
      margin: 16px 0;
    }
    .pricing-card .features {
      list-style: none;
      padding: 0;
      margin: 0 0 24px;
      flex-grow: 1;
    }
    .pricing-card .features li {
      display: flex;
      gap: 10px;
      align-items: baseline;
      padding: 8px 0;
      border-bottom: 1px solid rgba(6, 182, 212, 0.1);
      color: var(--comet-silver);
      font-size: 14px;
    }
    .pricing-card .features li .check {
      color: var(--aurora-green);
      flex-shrink: 0;
    }
    .pricing-card .best-for {
      background: rgba(6, 182, 212, 0.1);
      border: 1px solid rgba(6, 182, 212, 0.2);
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 13px;
      color: var(--comet-silver);
    }

    /* Benefits Grid */
    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    }

    /* Process Steps */
    .process-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
    .process-step {
      text-align: center;
      position: relative;
    }
    .process-step .step-number {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--cosmic-blue), var(--nebula-purple));
      border: 2px solid var(--aurora-green);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
      font-size: 20px;
      font-weight: 700;
      color: var(--starlight-white);
    }

    /* Comparison Grid */
    .comparison-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .comparison-card {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 58, 138, 0.1));
      border-radius: 16px;
      padding: 28px;
    }
    .comparison-card.bad {
      border: 1px solid rgba(239, 68, 68, 0.3);
    }
    .comparison-card.good {
      border: 1px solid rgba(16, 185, 129, 0.3);
    }
    .comparison-card ul {
      padding-left: 20px;
      margin: 0;
    }
    .comparison-card li {
      color: var(--comet-silver);
      font-size: 14px;
      margin-bottom: 8px;
      line-height: 1.5;
    }

    /* Backend Feature Grid */
    .backend-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }

    /* FAQ */
    .faq-item {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 58, 138, 0.1));
      border: 1px solid rgba(6, 182, 212, 0.3);
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 16px;
    }

    /* Services Grid */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    }

    @media (max-width: 968px) {
      .pricing-grid {
        grid-template-columns: 1fr;
        max-width: 500px;
        margin: 0 auto;
      }
      .process-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 768px) {
      .container {
        padding: 0 16px;
      }
      .comparison-grid {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 580px) {
      .process-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

