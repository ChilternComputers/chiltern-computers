  <script is:inline>
    // Hero title scramble + stat-value shuffle for web-design page.
    // Honours prefers-reduced-motion (skips animations entirely).
    (function () {
      var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ── Scramble each [data-scramble] element with its own delay/duration ──
      var chars = '!<>-_\\/[]{}—=+*^?#@$%&|01ΞΩΣΨЖ▓░▒█▌▐';

      function scramble(el) {
        var finalText = el.getAttribute('data-scramble') || el.textContent;
        var delay = parseInt(el.getAttribute('data-scramble-delay') || '0', 10);
        var duration = parseInt(el.getAttribute('data-scramble-duration') || '1500', 10);

        // Pre-fill with random chars and reveal the element
        var randomised = '';
        for (var i = 0; i < finalText.length; i++) {
          randomised += finalText[i] === ' ' ? ' ' : chars[Math.floor(Math.random() * chars.length)];
        }
        el.textContent = randomised;
        el.classList.add('wd-scramble-active');

        // Per-character reveal times (L→R bias + jitter)
        var reveals = [];
        for (var k = 0; k < finalText.length; k++) {
          var base = (k / finalText.length) * duration * 0.75;
          var jitter = Math.random() * duration * 0.3;
          reveals.push(base + jitter);
        }

        var start;
        function tick(ts) {
          if (!start) start = ts;
          var t = ts - start;
          var out = '';
          for (var j = 0; j < finalText.length; j++) {
            if (finalText[j] === ' ') { out += ' '; continue; }
            if (t >= reveals[j]) {
              out += finalText[j];
            } else {
              out += chars[Math.floor(Math.random() * chars.length)];
            }
          }
          el.textContent = out;
          if (t < duration + 80) {
            requestAnimationFrame(tick);
          } else {
            el.textContent = finalText;
          }
        }
        setTimeout(function () { requestAnimationFrame(tick); }, delay);
      }

      // ── Shuffle stat values (slot-machine cycle then land) ──
      var shuffleChars = '0123456789';
      function shuffleVal(el) {
        var finalText = el.getAttribute('data-shuffle') || el.textContent;
        var delay = parseInt(el.getAttribute('data-shuffle-delay') || '0', 10);
        var duration = 900;

        // Build the initial garbled state — keep non-digit chars (— + spaces) fixed
        function garble() {
          var s = '';
          for (var i = 0; i < finalText.length; i++) {
            var c = finalText[i];
            if (/[0-9]/.test(c)) {
              s += shuffleChars[Math.floor(Math.random() * shuffleChars.length)];
            } else {
              s += c;
            }
          }
          return s;
        }

        // Start cycling on each animation frame, settle after `duration`
        var startCycle = function () {
          var t0 = performance.now();
          function loop(now) {
            var elapsed = now - t0;
            if (elapsed >= duration) {
              el.textContent = finalText;
              return;
            }
            el.textContent = garble();
            requestAnimationFrame(loop);
          }
          requestAnimationFrame(loop);
        };
        setTimeout(startCycle, delay);
      }

      if (reduceMotion) {
        // Just reveal everything in its final state
        document.querySelectorAll('[data-scramble]').forEach(function (el) {
          el.classList.add('wd-scramble-active');
        });
        return;
      }

      document.querySelectorAll('[data-scramble]').forEach(scramble);
      document.querySelectorAll('[data-shuffle]').forEach(shuffleVal);
    })();
  </script>
