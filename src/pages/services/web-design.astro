  <main>
    <!-- HERO -->
    <section class="wd-hero">
      <div class="wd-hero-bg" aria-hidden="true">
        <div class="wd-hero-orb wd-orb-1"></div>
        <div class="wd-hero-orb wd-orb-2"></div>
        <div class="wd-hero-orb wd-orb-3"></div>
      </div>
      <div class="container wd-hero-content">
        <div class="wd-hero-badge">
          <Icon name="globe" size={14} />
          <span>NEW SERVICE FROM CHILTERN COMPUTERS</span>
        </div>
        <h1
          class="space-font wd-hero-title"
          aria-label="Bespoke Websites, Built by Hand"
        >
          <span
            class="galaxy-text wd-title-line1"
            data-scramble="Bespoke Websites,"
            data-scramble-delay="200"
            data-scramble-duration="1900"
            aria-hidden="true"
          >Bespoke Websites,</span>
          <br />
          <span
            class="galaxy-text wd-title-line2"
            data-scramble="Built by Hand"
            data-scramble-delay="2000"
            data-scramble-duration="2100"
            aria-hidden="true"
          >Built by Hand</span>
        </h1>
        <p class="alien-font wd-hero-subtitle">
          Bespoke websites for businesses and brands of every&nbsp;scale.
          Fast, mobile-first and SEO-ready — never built from a&nbsp;template.
        </p>
        <div class="wd-hero-cta">
          <a href="/contact/" class="wd-btn wd-btn-primary">
            <Icon name="rocket" size={16} />
            Get a Free Quote
          </a>
          <a href="#live-sites" class="wd-btn wd-btn-ghost">
            <Icon name="arrow-right" size={16} />
            See My Work
          </a>
          <a href="/portfolio-report/" class="wd-btn wd-btn-ghost">
            <Icon name="signal" size={16} />
            Performance Report
          </a>
        </div>
        <div class="wd-hero-trust">
          <span><Icon name="check-circle" size={14} class="wd-trust-icon" /> Pay once — it's yours</span>
          <span><Icon name="check-circle" size={14} class="wd-trust-icon" /> Free hosting</span>
          <span><Icon name="check-circle" size={14} class="wd-trust-icon" /> No monthly fees</span>
        </div>
        <div class="wd-hero-stats">
          <div class="wd-stat">
            <div class="space-font wd-stat-num" data-shuffle="13" data-shuffle-delay="4400">13</div>
            <div class="tech-font wd-stat-label">DEPLOYED SITES</div>
          </div>
          <div class="wd-stat">
            <div class="space-font wd-stat-num" data-shuffle="2–4" data-shuffle-delay="4600">2–4</div>
            <div class="tech-font wd-stat-label">WEEKS TO BUILD</div>
          </div>
          <div class="wd-stat">
            <div class="space-font wd-stat-num" data-shuffle="1–100+" data-shuffle-delay="4800">1–100+</div>
            <div class="tech-font wd-stat-label">PAGE WEBSITES</div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT'S INCLUDED -->
    <section class="wd-section">
      <div class="container">
        <div class="wd-section-head">
          <h2 class="space-font galaxy-text cosmic-glow wd-section-title">WHAT YOU GET</h2>
          <div class="wd-section-line"></div>
          <p class="alien-font wd-section-sub">
            Every site I build comes with the basics done properly — not as upsells.
          </p>
        </div>
        <div class="wd-services-grid">
          {services.map((s) => (
            <article class="cosmic-card wd-service-card">
              <div class="wd-service-icon" style={`color: ${s.color}; border-color: ${s.color}; box-shadow: 0 0 25px ${s.color}55;`}>
