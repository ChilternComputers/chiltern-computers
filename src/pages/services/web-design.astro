---
import Layout from '../../layouts/Layout.astro';
import { siteConfig } from '../../config';
import Icon from '../../components/Icon.astro';

const liveSites = [
  {
    name: 'Chiltern Computers',
    industry: 'Computer Repair · Tech Services',
    accent: '#06b6d4',
    description:
      'My own business — the site you are reading right now. Computer repair shop in Harold Hill with 75+ pages: service catalogue, 30+ area-specific landing pages for local SEO, blog and online booking flow. Built with Astro and deployed on Cloudflare Pages.',
    pages: '75+ pages',
    features: ['Local SEO across 30+ areas', 'Online booking', 'Blog & insights', 'Full schema markup'],
    url: 'https://chilterncomputers.net',
    iconName: 'cpu',
  },
  {
    name: 'FreshWax',
    industry: 'Music · Record Label',
    accent: '#f59e0b',
    description:
      'Independent music site with release catalogue, artist profiles and direct purchase / streaming links. Fast and lean for record-shop browsing — designed to put the music first.',
    pages: 'Multi-page',
    features: ['Release catalogue', 'Artist profiles', 'Audio links', 'Mobile-first browsing'],
    url: 'https://freshwax.co.uk',
    iconName: 'star',
  },
  {
    name: 'Flames After Dark',
    industry: 'Independent Artist Hub',
    accent: '#ea580c',
    description:
      'Custom-built artist platform for an electronic music collective. Includes a full CMS with auth, gallery management, music features, blog with comments, visitor stats and an inbox — all powered by Cloudflare Workers, R2 storage and KV. Lighthouse averages 99 desktop / 98 mobile.',
    pages: '10 pages + CMS',
    features: ['Custom CMS dashboard', 'Gallery & music features', 'Live comments + spam filter', 'Visitor analytics'],
    url: 'https://flames-after-dark.co.uk',
    iconName: 'bolt',
  },
];

const portfolio = [
  {
    name: 'Forge Gym',
    industry: 'Fitness & Wellness',
    accent: '#d4a843',
    description:
      'Modern gym brand with a dark cinematic theme and gold accents. Built around a custom timetable, trainer profiles, membership pricing and a free-trial booking flow.',
    pages: '10 pages',
    features: ['Custom timetable', 'Trainer profiles', 'Free-trial form', 'Gallery'],
    url: 'https://forge-gym.pages.dev',
    iconColor: 'var(--solar-orange)',
    iconName: 'bolt',
  },
  {
    name: 'Sable',
    industry: 'Fine Dining',
    accent: '#c9a96e',
    description:
      'Sophisticated restaurant site with warm dark tones and champagne accents. Includes a full à la carte menu, reservation system, private dining and gift voucher pages.',
    pages: '9 pages',
    features: ['Reservations', 'Full menu', 'Private dining', 'Gift vouchers'],
    url: 'https://sable-restaurant.pages.dev',
    iconColor: 'var(--solar-orange)',
    iconName: 'star',
  },
  {
    name: 'Aurea Spa',
    industry: 'Health & Beauty',
    accent: '#4a5d4e',
    description:
      'Calm, premium spa website with sage and gold palette on warm cream. Treatment catalogue, online booking, team profiles and gift voucher purchase — built for fast loading.',
    pages: '10 pages',
    features: ['Online booking', 'Treatments catalogue', 'Smooth scroll animations', 'Gift vouchers'],
    url: 'https://aurea-spa.pages.dev',
    iconColor: 'var(--aurora-green)',
    iconName: 'shield',
  },
  {
    name: 'Aldridge & Pryce Solicitors',
    industry: 'Legal Services',
    accent: '#b8975a',
    description:
      'Professional legal firm site with ivory background, deep navy and brass accents. Practice areas, transparent fees, team filter, consultation CTA and an insights blog.',
    pages: '9 pages',
    features: ['Practice areas', 'Transparent fees', 'Team filter', 'Insights blog'],
    url: 'https://aldridge-pryce.pages.dev',
    iconColor: 'var(--nebula-purple)',
    iconName: 'clipboard',
  },
  {
    name: 'Hartwell & Stone',
    industry: 'Premium Construction',
    accent: '#b8860b',
    description:
      'High-end construction firm with charcoal and stone palette, brass accents. Before/after slider, multi-step quote form, filterable project portfolio and accreditation badges.',
    pages: '9 pages',
    features: ['Before/after slider', 'Multi-step quote form', 'Project portfolio', 'Accreditation badges'],
    url: 'https://hartwell-stone.pages.dev',
    iconColor: 'var(--solar-orange)',
    iconName: 'tools',
  },
];

const services = [
  {
    title: 'Bespoke Design',
    description:
      'No templates. Every site is designed around your brand, your customers and the way you actually do business.',
    iconName: 'rocket',
    color: 'var(--plasma-cyan)',
  },
  {
    title: 'Mobile-First Build',
    description:
      'Your site looks sharp and works fast on every device, from phones to ultrawide monitors.',
    iconName: 'mobile',
    color: 'var(--aurora-green)',
  },
  {
    title: 'Built-In SEO',
    description:
      'Schema markup, sitemap, fast load times and search-engine-ready structure included from day one.',
    iconName: 'globe',
    color: 'var(--solar-orange)',
  },
  {
    title: 'Hosting Sorted',
    description:
      'I deploy your site to a fast global CDN. No fiddly hosting setup to worry about — it just works.',
    iconName: 'database',
    color: 'var(--nebula-purple)',
  },
  {
    title: 'Same Person Forever',
    description:
      'You deal directly with me from quote to launch and beyond. No account managers, no handoffs.',
    iconName: 'shield',
    color: 'var(--primary-blue)',
  },
  {
    title: 'Fast Turnaround',
    description:
      'Most small business sites go live within 2–4 weeks of brief sign-off, depending on content readiness.',
    iconName: 'bolt',
    color: 'var(--mars-red)',
  },
];

const process = [
  { step: '1', title: 'Discovery Call', text: 'A free 30-minute call to understand your business, your customers and your goals.' },
  { step: '2', title: 'Quote & Brief', text: 'Fixed-price quote based on what you actually need. No surprises mid-project.' },
  { step: '3', title: 'Design Mockups', text: 'I produce visual mockups of the key pages and agree the look and feel with you before any code is written.' },
  { step: '4', title: 'Build & Code', text: 'I build the site page by page using modern tools, with regular progress check-ins so nothing surprises you.' },
  { step: '5', title: 'Review & Launch', text: 'You review on a private staging URL. Once you approve, I deploy to your domain with no downtime.' },
  { step: '6', title: 'Aftercare', text: 'Ongoing support packages, or pay-as-you-go for tweaks, content edits and security updates.' },
];
---

<Layout
  title="Web Design Romford & Essex | Small Business & Corporate Sites | Chiltern Computers"
  description="Bespoke small business and corporate websites built by Chiltern Computers in Harold Hill, Romford. Fast, mobile-first sites with built-in SEO. View live demos. Call 07971 331814."
  keywords="web design romford, web designer harold hill, website builder essex, small business website romford, corporate website essex, bespoke website design"
  type="service"
  publishedTime="2026-05-12"
  modifiedTime="2026-05-12"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Web Design', url: '/services/web-design/' },
  ]}
>
  <main>
    <!-- HERO -->
    <section class="wd-hero">
      <div class="wd-hero-bg" aria-hidden="true">
        <div class="wd-hero-orb wd-orb-1"></div>
        <div class="wd-hero-orb wd-orb-2"></div>
        <div class="wd-hero-orb wd-orb-3"></div>
      </div>
      <div class="container wd-hero-content">
        <div class="wd-hero-badge">
          <Icon name="globe" size={14} />
          <span>NEW SERVICE FROM CHILTERN COMPUTERS</span>
        </div>
        <h1
          class="space-font cosmic-glow wd-hero-title"
          aria-label="Bespoke Websites, Built by Hand"
        >
          <span class="galaxy-text wd-title-line1" aria-hidden="true">Bespoke Websites,</span>
          <br />
          <span class="galaxy-text wd-title-line2" data-scramble="Built by Hand" aria-hidden="true">Built by Hand</span>
        </h1>
        <p class="alien-font wd-hero-subtitle">
          Small business and corporate websites, designed and built one at a time, by me, in Harold Hill.
          Fast, mobile-first, SEO-ready — and not a template in sight.
        </p>
        <div class="wd-hero-cta">
          <a href="/contact/" class="wd-btn wd-btn-primary">
            <Icon name="rocket" size={16} />
            Get a Free Quote
          </a>
          <a href="#live-sites" class="wd-btn wd-btn-ghost">
            <Icon name="arrow-right" size={16} />
            See My Work
          </a>
        </div>
        <div class="wd-hero-stats">
          <div class="wd-stat">
            <div class="space-font wd-stat-num">8</div>
            <div class="tech-font wd-stat-label">DEPLOYED SITES</div>
          </div>
          <div class="wd-stat">
            <div class="space-font wd-stat-num">2–4</div>
            <div class="tech-font wd-stat-label">WEEKS TO BUILD</div>
          </div>
          <div class="wd-stat">
            <div class="space-font wd-stat-num">1–100+</div>
            <div class="tech-font wd-stat-label">PAGE WEBSITES</div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT'S INCLUDED -->
    <section class="wd-section">
      <div class="container">
        <div class="wd-section-head">
          <h2 class="space-font galaxy-text cosmic-glow wd-section-title">WHAT YOU GET</h2>
          <div class="wd-section-line"></div>
          <p class="alien-font wd-section-sub">
            Every site I build comes with the basics done properly — not as upsells.
          </p>
        </div>
        <div class="wd-services-grid">
          {services.map((s) => (
            <article class="cosmic-card wd-service-card">
              <div class="wd-service-icon" style={`color: ${s.color}; border-color: ${s.color}; box-shadow: 0 0 25px ${s.color}55;`}>
                <Icon name={s.iconName} size={32} />
              </div>
              <h3 class="space-font wd-service-title" style={`color: ${s.color};`}>{s.title}</h3>
              <p class="alien-font wd-service-desc">{s.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- LIVE SITES -->
    <section id="live-sites" class="wd-section wd-section-alt">
      <div class="container">
        <div class="wd-section-head">
          <h2 class="space-font galaxy-text cosmic-glow wd-section-title">LIVE SITES</h2>
          <div class="wd-section-line"></div>
          <p class="alien-font wd-section-sub">
            Real businesses, real traffic — all designed, built and hosted by me.
          </p>
        </div>
        <div class="wd-stack-grid">
          {liveSites.map((p, i) => (
            <a
              href={p.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Visit ${p.name} (opens in new tab)`}
              class={`cosmic-card wd-stack-card${i % 2 === 1 ? ' wd-stack-reverse' : ''}`}
              style={`--accent: ${p.accent};`}
            >
              <div class="wd-stack-text">
                <div class="tech-font wd-stack-industry">
                  <span class="wd-live-badge">LIVE</span>
                  {p.industry.toUpperCase()}
                </div>
                <h3 class="space-font wd-stack-name">{p.name}</h3>
                <p class="alien-font wd-stack-desc">{p.description}</p>
                <ul class="wd-stack-features">
                  {p.features.map((f) => (
                    <li>
                      <Icon name="check-circle" size={14} class="wd-feat-icon" />
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>
                <div class="wd-stack-footer">
                  <span class="tech-font wd-stack-pages">{p.pages}</span>
                  <span class="wd-stack-cta">
                    Visit Live Site
                    <Icon name="arrow-right" size={14} />
                  </span>
                </div>
              </div>
              <div class="wd-stack-preview" aria-hidden="true">
                <div class="wd-browser-frame">
                  <div class="wd-browser-bar">
                    <span class="wd-browser-dot wd-bd-r"></span>
                    <span class="wd-browser-dot wd-bd-y"></span>
                    <span class="wd-browser-dot wd-bd-g"></span>
                    <span class="wd-browser-url">{p.url.replace('https://', '')}</span>
                  </div>
                  <div class="wd-mock-canvas">
                    <div class="wd-mock-nav">
                      <span class="wd-mock-logo">{p.name}</span>
                      <span class="wd-mock-nav-items">
                        <span></span><span></span><span></span><span></span>
                      </span>
                    </div>
                    <div class="wd-mock-hero">
                      <div class="wd-mock-h1"></div>
                      <div class="wd-mock-h2"></div>
                      <div class="wd-mock-btn">EXPLORE</div>
                    </div>
                    <div class="wd-mock-cards">
                      <div class="wd-mock-card"></div>
                      <div class="wd-mock-card"></div>
                      <div class="wd-mock-card"></div>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- DEMO DESIGNS -->
    <section id="portfolio" class="wd-section">
      <div class="container">
        <div class="wd-section-head">
          <h2 class="space-font galaxy-text cosmic-glow wd-section-title">DEMO DESIGNS</h2>
          <div class="wd-section-line"></div>
          <p class="alien-font wd-section-sub">
            Five showcase sites covering different industries. Each one is fully responsive — click through and try them on your phone.
          </p>
        </div>
        <div class="wd-stack-grid">
          {portfolio.map((p, i) => (
            <a
              href={p.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Visit ${p.name} live demo (opens in new tab)`}
              class={`cosmic-card wd-stack-card${i % 2 === 1 ? ' wd-stack-reverse' : ''}`}
              style={`--accent: ${p.accent};`}
            >
              <div class="wd-stack-text">
                <div class="tech-font wd-stack-industry">
                  {p.industry.toUpperCase()}
                </div>
                <h3 class="space-font wd-stack-name">{p.name}</h3>
                <p class="alien-font wd-stack-desc">{p.description}</p>
                <ul class="wd-stack-features">
                  {p.features.map((f) => (
                    <li>
                      <Icon name="check-circle" size={14} class="wd-feat-icon" />
                      <span>{f}</span>
                    </li>
                  ))}
                </ul>
                <div class="wd-stack-footer">
                  <span class="tech-font wd-stack-pages">{p.pages}</span>
                  <span class="wd-stack-cta">
                    Visit Live Demo
                    <Icon name="arrow-right" size={14} />
                  </span>
                </div>
              </div>
              <div class="wd-stack-preview" aria-hidden="true">
                <div class="wd-browser-frame">
                  <div class="wd-browser-bar">
                    <span class="wd-browser-dot wd-bd-r"></span>
                    <span class="wd-browser-dot wd-bd-y"></span>
                    <span class="wd-browser-dot wd-bd-g"></span>
                    <span class="wd-browser-url">{p.url.replace('https://', '')}</span>
                  </div>
                  <div class="wd-mock-canvas">
                    <div class="wd-mock-nav">
                      <span class="wd-mock-logo">{p.name}</span>
                      <span class="wd-mock-nav-items">
                        <span></span><span></span><span></span><span></span>
                      </span>
                    </div>
                    <div class="wd-mock-hero">
                      <div class="wd-mock-h1"></div>
                      <div class="wd-mock-h2"></div>
                      <div class="wd-mock-btn">EXPLORE</div>
                    </div>
                    <div class="wd-mock-cards">
                      <div class="wd-mock-card"></div>
                      <div class="wd-mock-card"></div>
                      <div class="wd-mock-card"></div>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section class="wd-section">
      <div class="container">
        <div class="wd-section-head">
          <h2 class="space-font galaxy-text cosmic-glow wd-section-title">HOW IT WORKS</h2>
          <div class="wd-section-line"></div>
          <p class="alien-font wd-section-sub">
            Simple, predictable, and built around your time — not mine.
          </p>
        </div>
        <div class="wd-process-grid">
          {process.map((p) => (
            <div class="cosmic-card wd-process-card">
              <div class="space-font wd-process-num">{p.step}</div>
              <h3 class="space-font wd-process-title">{p.title}</h3>
              <p class="alien-font wd-process-text">{p.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="wd-section wd-section-alt">
      <div class="container">
        <div class="wd-section-head">
          <h2 class="space-font galaxy-text cosmic-glow wd-section-title">COMMON QUESTIONS</h2>
          <div class="wd-section-line"></div>
        </div>
        <div class="wd-faq-grid">
          <details class="cosmic-card wd-faq-item">
            <summary class="space-font wd-faq-q">How much does a website cost?</summary>
            <p class="alien-font wd-faq-a">
              It depends on the number of pages, features and how much content you can provide yourself.
              A simple brochure site for a small business typically starts in the low hundreds. I always
              quote a fixed price up front after the discovery call — no hidden extras.
            </p>
          </details>
          <details class="cosmic-card wd-faq-item">
            <summary class="space-font wd-faq-q">Do I own the site once it's built?</summary>
            <p class="alien-font wd-faq-a">
              Yes. You own the domain, the design and all the content. I deploy and maintain the hosting,
              but you're never locked in — the code can be handed over if you want it.
            </p>
          </details>
          <details class="cosmic-card wd-faq-item">
            <summary class="space-font wd-faq-q">What about ongoing maintenance?</summary>
            <p class="alien-font wd-faq-a">
              I offer two options: a monthly care plan that covers small tweaks, content edits, security
              updates and a check-in call, or pay-as-you-go where you just message me when you need
              something changed.
            </p>
          </details>
          <details class="cosmic-card wd-faq-item">
            <summary class="space-font wd-faq-q">Will my site rank on Google?</summary>
            <p class="alien-font wd-faq-a">
              I build with the technical SEO foundations every site needs — fast load times, structured
              data, sitemap, mobile-first design. Long-term ranking depends on your content, your local
              presence and competition in your area, which I can advise on.
            </p>
          </details>
          <details class="cosmic-card wd-faq-item">
            <summary class="space-font wd-faq-q">Can you redesign my existing site?</summary>
            <p class="alien-font wd-faq-a">
              Absolutely. If you've got an old or tired-looking site I can rebuild it from scratch with a
              modern design, keep your existing content and URLs, and migrate everything over with no
              downtime.
            </p>
          </details>
          <details class="cosmic-card wd-faq-item">
            <summary class="space-font wd-faq-q">Are you local?</summary>
            <p class="alien-font wd-faq-a">
              Yes — I'm based in Harold Hill, Romford, and most of my customers are within a 15-mile
              radius. I'm happy to meet in person for the discovery call and pop in for any milestone
              review. Remote work also fine if you're further out.
            </p>
          </details>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="wd-cta-section">
      <div class="container">
        <div class="wd-cta-card cosmic-card">
          <h2 class="space-font galaxy-text cosmic-glow wd-cta-title">
            Ready to talk about your website?
          </h2>
          <p class="alien-font wd-cta-sub">
            Free, no-pressure discovery call. Tell me what you have in mind and I'll come back with
            ideas and a fixed-price quote within 48 hours.
          </p>
          <div class="wd-cta-buttons">
            <a href={`tel:${siteConfig.phone.mobile}`} class="wd-btn wd-btn-primary">
              <Icon name="mobile" size={16} />
              {siteConfig.phone.mobileDisplay}
            </a>
            <a href="/contact/" class="wd-btn wd-btn-ghost">
              <Icon name="email" size={16} />
              Send a Message
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <style>
    /* Page-scoped styling — matches the cosmic theme used across Chiltern Computers */
    main {
      background: linear-gradient(135deg, var(--deep-space) 0%, var(--darker-space) 50%, var(--void-black) 100%);
      color: var(--starlight-white);
      min-height: 100vh;
    }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

    /* HERO */
    .wd-hero {
      position: relative;
      overflow: hidden;
      padding: 100px 0 80px;
    }
    .wd-hero-bg {
      position: absolute; inset: 0; pointer-events: none;
    }
    .wd-hero-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.4;
    }
    .wd-orb-1 { width: 400px; height: 400px; top: -100px; left: -100px; background: var(--primary-blue); }
    .wd-orb-2 { width: 350px; height: 350px; top: 30%; right: -120px; background: var(--plasma-cyan); }
    .wd-orb-3 { width: 300px; height: 300px; bottom: -80px; left: 30%; background: var(--nebula-purple); }
    .wd-hero-content { position: relative; z-index: 2; text-align: center; }
    .wd-hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 8px 16px;
      background: rgba(59, 130, 246, 0.12);
      border: 1px solid var(--primary-blue);
      border-radius: 25px;
      font-family: 'Space Mono', monospace;
      font-size: 12px;
      color: var(--primary-blue);
      margin-bottom: 24px;
      letter-spacing: 1px;
    }
    .wd-hero-title {
      font-size: clamp(36px, 6vw, 64px);
      line-height: 1.1;
      margin-bottom: 24px;
    }
    .wd-title-line1 {
      display: inline-block;
      opacity: 0;
      filter: blur(10px);
      transform: translateY(-12px);
      animation: wd-title-fade-in 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    }
    .wd-title-line2 {
      display: inline-block;
      opacity: 0;
      animation: wd-title-line2-appear 0.3s ease-out 1.2s forwards;
      font-variant-ligatures: none;
      white-space: nowrap;
    }
    @keyframes wd-title-fade-in {
      0%   { opacity: 0; filter: blur(10px); transform: translateY(-12px); }
      60%  { opacity: 0.4; filter: blur(2px); }
      100% { opacity: 1; filter: blur(0); transform: translateY(0); }
    }
    @keyframes wd-title-line2-appear {
      0%   { opacity: 0; }
      100% { opacity: 1; }
    }
    /* Stats slide-up cascade after title finishes */
    .wd-hero-stats .wd-stat {
      opacity: 0;
      transform: translateY(20px);
      animation: wd-stat-rise 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .wd-hero-stats .wd-stat:nth-child(1) { animation-delay: 2.6s; }
    .wd-hero-stats .wd-stat:nth-child(2) { animation-delay: 2.75s; }
    .wd-hero-stats .wd-stat:nth-child(3) { animation-delay: 2.9s; }
    @keyframes wd-stat-rise {
      0%   { opacity: 0; transform: translateY(20px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    /* CTA buttons fade in after title */
    .wd-hero-cta .wd-btn {
      opacity: 0;
      animation: wd-cta-fade 0.6s ease-out 2.2s forwards;
    }
    .wd-hero-cta .wd-btn:nth-child(2) { animation-delay: 2.35s; }
    @keyframes wd-cta-fade {
      0%   { opacity: 0; transform: translateY(8px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    /* Subtitle also fades in */
