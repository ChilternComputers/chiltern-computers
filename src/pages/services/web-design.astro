  <script is:inline>
    // Scramble/decrypt effect for "Built by Hand" on the hero title.
    // Starts after the line2 fade-in finishes (~1.5s after page load),
    // cycles random characters per position, then progressively resolves
    // letter by letter to the final text. Honours prefers-reduced-motion.
    (function () {
      var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var el = document.querySelector('[data-scramble]');
      if (!el || reduceMotion) return;

      var finalText = el.getAttribute('data-scramble') || el.textContent;
      var chars = '!<>-_\\/[]{}—=+*^?#@$%&|01ΞΩΣΨЖ▓░▒█▌▐';
      var duration = 1800;

      // Set initial scrambled state so there's no flash of real text
      function randText() {
        var s = '';
        for (var i = 0; i < finalText.length; i++) {
          s += finalText[i] === ' ' ? ' ' : chars[Math.floor(Math.random() * chars.length)];
        }
        return s;
      }
      el.textContent = randText();

      // Each character gets its own reveal time, weighted to progress L→R
      // with some randomness so it looks more "decrypting" than a wipe.
      var reveals = [];
      for (var i = 0; i < finalText.length; i++) {
        var base = (i / finalText.length) * duration * 0.85;
        var jitter = Math.random() * duration * 0.25;
        reveals.push(base + jitter);
      }

      var start;
      function tick(ts) {
        if (!start) start = ts;
        var t = ts - start;
        var out = '';
        for (var j = 0; j < finalText.length; j++) {
          if (finalText[j] === ' ') { out += ' '; continue; }
          if (t >= reveals[j]) {
            out += finalText[j];
          } else {
            out += chars[Math.floor(Math.random() * chars.length)];
          }
        }
        el.textContent = out;
        if (t < duration + 50) {
          requestAnimationFrame(tick);
        } else {
          el.textContent = finalText;
        }
      }

      // Wait for line1 fade-in to land first
      setTimeout(function () { requestAnimationFrame(tick); }, 1500);
    })();
  </script>
