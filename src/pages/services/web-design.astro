import { statSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

// Cache-bust each demo screenshot using its file mtime. When a screenshot is
// re-captured, its mtime changes, so the query param changes, so Cloudflare
// edge serves the new file instead of the cached one.
const previewsDir = fileURLToPath(new URL('../../../public/web-design-previews/', import.meta.url));
const screenshotVer = (slug: string): string => {
  try { return Math.floor(statSync(previewsDir + slug + '.jpg').mtimeMs).toString(36); }
  catch { return '1'; }
};

