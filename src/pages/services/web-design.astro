    }
    .wd-orb-1 { width: 400px; height: 400px; top: -100px; left: -100px; background: var(--primary-blue); }
    .wd-orb-2 { width: 350px; height: 350px; top: 30%; right: -120px; background: var(--plasma-cyan); }
    .wd-orb-3 { width: 300px; height: 300px; bottom: -80px; left: 30%; background: var(--nebula-purple); }
    .wd-hero-content { position: relative; z-index: 2; text-align: center; }
    .wd-hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 8px 16px;
      background: rgba(59, 130, 246, 0.12);
      border: 1px solid var(--primary-blue);
      border-radius: 25px;
      font-family: 'Space Mono', monospace;
      font-size: 12px;
      color: var(--primary-blue);
      margin-bottom: 24px;
      letter-spacing: 1px;
    }
    .wd-hero-title {
      font-size: clamp(26px, 6.2vw, 64px);
      line-height: 1.1;
      margin-bottom: 24px;
      /* Toned-down glow — override the heavier .cosmic-glow */
      text-shadow:
        0 0 8px color-mix(in srgb, var(--plasma-cyan) 25%, transparent),
        0 0 14px color-mix(in srgb, var(--nebula-purple) 12%, transparent);
    }
    .wd-title-line1, .wd-title-line2 {
      display: inline-block;
      white-space: nowrap;
      font-variant-ligatures: none;
      /* Lines stay hidden until scramble JS reveals them */
      opacity: 0;
      transition: opacity 0.25s ease-out;
    }
    .wd-title-line1.wd-scramble-active,
    .wd-title-line2.wd-scramble-active {
      opacity: 1;
    }

    /* Stats — number first (with shuffle), label fades up under */
    .wd-hero-stats .wd-stat {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
    }
    .wd-stat-num {
      opacity: 0;
      animation: wd-stat-num-pop 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .wd-stat-label {
      opacity: 0;
      transform: translateY(12px);
      animation: wd-label-rise 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .wd-hero-stats .wd-stat:nth-child(1) .wd-stat-num   { animation-delay: 4.4s; }
    .wd-hero-stats .wd-stat:nth-child(1) .wd-stat-label { animation-delay: 5.2s; }
    .wd-hero-stats .wd-stat:nth-child(2) .wd-stat-num   { animation-delay: 4.6s; }
    .wd-hero-stats .wd-stat:nth-child(2) .wd-stat-label { animation-delay: 5.4s; }
    .wd-hero-stats .wd-stat:nth-child(3) .wd-stat-num   { animation-delay: 4.8s; }
    .wd-hero-stats .wd-stat:nth-child(3) .wd-stat-label { animation-delay: 5.6s; }
    @keyframes wd-stat-num-pop {
      0%   { opacity: 0; transform: scale(0.85); }
      100% { opacity: 1; transform: scale(1); }
    }
    @keyframes wd-label-rise {
      0%   { opacity: 0; transform: translateY(12px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    /* CTA buttons fade in after title */
    .wd-hero-cta .wd-btn {
      opacity: 0;
      animation: wd-cta-fade 0.6s ease-out 4.1s forwards;
    }
    .wd-hero-cta .wd-btn:nth-child(2) { animation-delay: 4.25s; }
    .wd-hero-cta .wd-btn:nth-child(3) { animation-delay: 4.4s; }
    @keyframes wd-cta-fade {
      0%   { opacity: 0; transform: translateY(8px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    /* Subtitle fades in between title scrambles */
    .wd-hero-subtitle {
      opacity: 0;
      animation: wd-cta-fade 0.6s ease-out 2.7s forwards;
    }
    /* Respect reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .wd-title-line1, .wd-title-line2,
      .wd-hero-stats .wd-stat-num,
      .wd-hero-stats .wd-stat-label,
      .wd-hero-cta .wd-btn,
      .wd-hero-subtitle {
        opacity: 1 !important;
        transform: none !important;
        filter: none !important;
        animation: none !important;
      }
    }
    .wd-hero-subtitle {
