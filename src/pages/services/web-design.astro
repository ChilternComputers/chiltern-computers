              <div class="wd-stack-preview" aria-hidden="true">
                <div class="wd-browser-frame">
                  <div class="wd-browser-bar">
                    <span class="wd-browser-dot wd-bd-r"></span>
                    <span class="wd-browser-dot wd-bd-y"></span>
                    <span class="wd-browser-dot wd-bd-g"></span>
                    <span class="wd-browser-url">{p.url.replace('https://', '')}</span>
                  </div>
                  <img
                    src={`/web-design-previews/${p.slug}.jpg?v=${screenshotVer(p.slug)}`}
                    alt={`Screenshot of ${p.name} homepage`}
                    width="1440"
                    height="900"
                    loading="lazy"
                    decoding="async"
                    class="wd-stack-screenshot"
                  />
