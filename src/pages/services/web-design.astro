---
import Layout from '../../layouts/Layout.astro';

const faqs = [
  {
    question: 'How long does it take to build a website?',
    answer:
      'A single-page site typically takes 1-2 weeks from start to finish. Premium multi-page sites take 3-6 weeks depending on scope. We give you a clear timeline upfront and keep you updated throughout.',
  },
  {
    question: 'Do I need to provide content and images?',
    answer:
      'If you have content and photos, great — we will work with what you have. If not, we can help write copy and source professional imagery. We will guide you through everything you need.',
  },
  {
    question: 'What if I want more pages later?',
    answer:
      'You can upgrade anytime. Start with a single page at £299, prove it works for your business, then add more pages when you are ready. No lock-in, no pressure.',
  },
  {
    question: 'Are there any monthly fees?',
    answer:
      'No. Your site is hosted on Cloudflare Pages for free — no monthly hosting fees, no subscriptions. The only ongoing cost is your domain name, which is typically around £10 per year.',
  },
  {
    question: 'Can I update the website myself?',
    answer:
      'We handle updates for you — just email or call us with changes. If you need frequent content updates (like a blog), we can add a headless CMS so you can edit content directly without touching code.',
  },
  {
    question: "What's the difference between the £299 and £800 packages?",
    answer:
      'The £299 Starter is a single-page website. The £800 Professional is a multi-page site with dedicated sub pages (gallery, service areas, etc.), a proper business email mailbox (not just forwarding), enhanced SEO with JSON-LD schema markup, security headers, performance optimisation for sub-second load times, analytics setup, and a second round of revisions. It is the better choice if you want to rank in Google for local searches.',
  },
];
---

<Layout
  title="Web Design Essex - Professional Websites from £299"
  description="Professional one-page websites from £299. Mobile-ready, fast-loading, £0 monthly hosting. Romford, Havering & Essex. Call 07971 331814."
  keywords="web design romford, website design essex, cheap website romford, one page website essex, small business website romford, affordable web design havering"
  type="service"
  publishedTime="2026-03-08"
  modifiedTime="2026-03-08"
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Repairs & Services', url: '/services/repairs/' },
    { name: 'Web Design', url: '/services/web-design/' },
  ]}
>
  <style>
    * {
      box-sizing: border-box;
    }
    html,
    body {
      overflow-x: hidden;
      width: 100%;
    }
    :root {
      --cosmic-blue: #1e3a8a;
      --nebula-purple: #DC2626;
      --starlight-white: #f8fafc;
      --plasma-cyan: #06b6d4;
      --aurora-green: #10b981;
      --solar-orange: #f59e0b;
      --deep-space: #0f172a;
      --void-black: #020617;
      --comet-silver: #e5e7eb;
      --mars-red: #dc2626;
    }
    .space-font {
      font-family: 'Orbitron', sans-serif;
      font-weight: 600;
    }
    .alien-font {
      font-family: 'Exo 2', sans-serif;
    }
    .tech-font {
      font-family: 'Space Mono', monospace;
    }
    @keyframes cosmic-pulse {
      0%,
      100% {
        text-shadow: 0 0 5px currentColor;
      }
      50% {
        text-shadow: 0 0 15px currentColor;
      }
    }
    @keyframes galaxy-flow {
      0% {
        background-position: 0% 0%;
      }
      50% {
        background-position: 100% 100%;
      }
      100% {
        background-position: 0% 0%;
      }
    }
    .trust-stat {
      background: rgba(6, 182, 212, 0.05);
      border: 1px solid rgba(6, 182, 212, 0.15);
      transition: border-color 0.3s ease, background 0.3s ease;
    }
    .trust-stat:hover {
      border-color: rgba(6, 182, 212, 0.4);
      background: rgba(6, 182, 212, 0.1);
    }
    .trust-stat-sweep {
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent 0%, rgba(56, 189, 248, 0.2) 40%, rgba(56, 189, 248, 0.35) 50%, rgba(56, 189, 248, 0.2) 60%, transparent 100%);
      animation: stat-sweep 4s ease-in-out infinite;
      z-index: 0;
      pointer-events: none;
    }
    @keyframes stat-sweep {
      0% { left: -100%; }
      40% { left: 100%; }
      100% { left: 100%; }
    }
    @media (prefers-reduced-motion: reduce) {
      .trust-stat-sweep { animation: none; display: none; }
    }
    .cosmic-glow {
      animation: cosmic-pulse 3s ease-in-out infinite alternate;
    }
    .galaxy-text {
      background: linear-gradient(
        135deg,
        var(--plasma-cyan),
        var(--aurora-green),
        var(--solar-orange)
      );
      background-size: 200% 200%;
      animation: galaxy-flow 4s ease-in-out infinite;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .section-bg {
      background: linear-gradient(135deg, rgba(2, 6, 23, 0.95), rgba(15, 23, 42, 0.9));
    }
    .cosmic-card {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 58, 138, 0.1));
      border: 1px solid var(--plasma-cyan);
      border-radius: 20px;
      backdrop-filter: blur(15px);
      box-shadow: 0 8px 32px rgba(6, 182, 212, 0.2);
      transition: all 0.3s ease;
    }
    .cosmic-card:hover {
      transform: translateY(-5px);
      border-color: var(--aurora-green);
    }
    .space-button {
      background: linear-gradient(135deg, var(--cosmic-blue), var(--nebula-purple));
      border: 1px solid var(--aurora-green);
      color: var(--starlight-white);
      padding: 14px 28px;
      border-radius: 25px;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      transition: all 0.3s ease;
    }
    .space-button:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 25px rgba(30, 58, 138, 0.4);
    }
    .container {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    /* Pricing Grid */
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .pricing-card {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 58, 138, 0.1));
      border: 1px solid var(--plasma-cyan);
      border-radius: 20px;
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      transition: all 0.3s ease;
    }
    .pricing-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 35px rgba(6, 182, 212, 0.25);
    }
    .pricing-card.featured {
      border-color: var(--aurora-green);
      box-shadow: 0 8px 32px rgba(16, 185, 129, 0.3);
      position: relative;
    }
    .pricing-card.premium {
      border-color: var(--nebula-purple);
      box-shadow: 0 8px 32px rgba(220, 38, 38, 0.3);
    }
    .pricing-card .price {
      font-size: clamp(28px, 4vw, 36px);
      margin: 16px 0;
    }
    .pricing-card .features {
      list-style: none;
      padding: 0;
      margin: 0 0 24px;
    }
    .pricing-card .features li {
      display: flex;
      gap: 10px;
      align-items: baseline;
      padding: 8px 0;
      border-bottom: 1px solid rgba(6, 182, 212, 0.1);
      color: var(--comet-silver);
      font-size: 14px;
    }
    .pricing-card .features li .check {
      color: var(--aurora-green);
      flex-shrink: 0;
    }
    .pricing-card .best-for {
      background: rgba(6, 182, 212, 0.1);
      border: 1px solid rgba(6, 182, 212, 0.2);
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 13px;
      color: var(--comet-silver);
    }

    /* Benefits Grid */
    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    }

    /* Process Steps */
    .process-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
    .process-step {
      text-align: center;
      position: relative;
    }
    .process-step .step-number {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--cosmic-blue), var(--nebula-purple));
      border: 2px solid var(--aurora-green);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
      font-size: 20px;
      font-weight: 700;
      color: var(--starlight-white);
    }

    /* Comparison Grid */
    .comparison-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
    .comparison-card {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 58, 138, 0.1));
      border-radius: 16px;
      padding: 28px;
    }
    .comparison-card.bad {
      border: 1px solid rgba(239, 68, 68, 0.3);
    }
    .comparison-card.good {
      border: 1px solid rgba(16, 185, 129, 0.3);
    }
    .comparison-card ul {
      padding-left: 20px;
      margin: 0;
    }
    .comparison-card li {
      color: var(--comet-silver);
      font-size: 14px;
      margin-bottom: 8px;
      line-height: 1.5;
    }

    /* Backend Feature Grid */
    .backend-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }

    /* Proof Table */
    .proof-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid rgba(6, 182, 212, 0.3);
    }
    .proof-table thead th {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.95), rgba(30, 58, 138, 0.2));
      color: var(--starlight-white);
      padding: 14px 12px;
      font-size: 12px;
      text-align: center;
      border-bottom: 2px solid rgba(6, 182, 212, 0.3);
      white-space: nowrap;
    }
    .proof-table thead th:first-child {
      text-align: left;
      padding-left: 20px;
    }
    .proof-table tbody td {
      padding: 12px;
      font-size: 13px;
      text-align: center;
      border-bottom: 1px solid rgba(6, 182, 212, 0.1);
      color: var(--comet-silver);
    }
    .proof-table tbody td:first-child {
      text-align: left;
      padding-left: 20px;
      font-weight: 600;
      color: var(--starlight-white);
    }
    .proof-table tbody tr {
      background: rgba(2, 6, 23, 0.6);
    }
    .proof-table tbody tr:hover {
      background: rgba(6, 182, 212, 0.05);
    }
    .proof-table tbody tr.highlight-row {
      background: rgba(16, 185, 129, 0.08);
      border-left: 3px solid var(--aurora-green);
    }
    .proof-table tbody tr.highlight-row td {
      color: var(--starlight-white);
    }
    .proof-table .check-yes {
      color: var(--aurora-green);
      font-weight: 700;
    }
    .proof-table .check-no {
      color: var(--mars-red);
      font-weight: 700;
    }
    .proof-table .check-partial {
      color: var(--solar-orange);
      font-weight: 700;
    }
    .proof-table-wrapper {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      border-radius: 16px;
    }
    .proof-cards-mobile {
      display: none;
      flex-direction: column;
      gap: 16px;
    }
    .proof-card-mobile {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 58, 138, 0.1));
      border: 1px solid rgba(6, 182, 212, 0.3);
      border-radius: 16px;
      padding: 20px;
    }
    .proof-card-mobile.highlight {
      border-color: var(--aurora-green);
      box-shadow: 0 4px 20px rgba(16, 185, 129, 0.2);
    }
    .proof-card-mobile .card-name {
      font-size: 16px;
      margin-bottom: 4px;
    }
    .proof-card-mobile .card-url {
      font-size: 11px;
      color: var(--comet-silver);
      margin-bottom: 16px;
    }
    .proof-card-mobile .card-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 0;
      border-bottom: 1px solid rgba(6, 182, 212, 0.1);
      font-size: 13px;
    }
    .proof-card-mobile .card-row:last-child {
      border-bottom: none;
    }
    .proof-card-mobile .card-label {
      color: var(--comet-silver);
    }
    .proof-card-mobile .card-value {
      text-align: right;
      font-weight: 600;
    }
    @media (max-width: 768px) {
      .proof-table-wrapper {
        display: none;
      }
      .proof-cards-mobile {
        display: flex;
      }
    }

    /* FAQ */
    .faq-item {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 58, 138, 0.1));
      border: 1px solid rgba(6, 182, 212, 0.3);
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 16px;
    }

    /* Services Grid */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    }

    @media (max-width: 1200px) {
      .pricing-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      .pricing-card.featured {
        grid-column: 1 / -1;
      }
    }
    @media (max-width: 968px) {
      .pricing-grid {
        grid-template-columns: 1fr;
        max-width: 500px;
        margin: 0 auto;
      }
      .process-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 768px) {
      .container {
        padding: 0 16px;
      }
      .comparison-grid {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 580px) {
      .process-grid {
        grid-template-columns: 1fr;
      }
    }

    /* Benchmark Section */
    .demo-showcase {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-bottom: 48px;
    }
    .demo-card {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.9), rgba(30, 58, 138, 0.15));
      border: 1px solid rgba(6, 182, 212, 0.3);
      border-radius: 16px;
      padding: 32px 24px;
      text-align: center;
    }
    .demo-card.highlight-demo {
      border-color: var(--aurora-green);
      box-shadow: 0 0 20px rgba(16, 185, 129, 0.1);
    }
    .demo-card .demo-tier {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      padding: 4px 12px;
      border-radius: 20px;
      margin-bottom: 12px;
    }
    .demo-card .demo-tier.starter {
      background: rgba(6, 182, 212, 0.15);
      color: var(--plasma-cyan);
      border: 1px solid rgba(6, 182, 212, 0.3);
    }
    .demo-card .demo-tier.professional {
      background: rgba(16, 185, 129, 0.15);
      color: var(--aurora-green);
      border: 1px solid rgba(16, 185, 129, 0.3);
    }
    .scores-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin: 20px 0;
    }
    .score-item {
      text-align: center;
    }
    .score-circle {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 6px;
      font-size: 18px;
      font-weight: 800;
    }
    .score-circle.green {
      border: 3px solid #0cce6b;
      color: #0cce6b;
      box-shadow: 0 0 12px rgba(12, 206, 107, 0.2);
    }
    .score-circle.orange {
      border: 3px solid #ffa400;
      color: #ffa400;
    }
    .score-circle.red {
      border: 3px solid #ff4e42;
      color: #ff4e42;
    }
    .score-label {
      font-size: 10px;
      color: var(--comet-silver);
      letter-spacing: 0.3px;
      line-height: 1.2;
    }
    .demo-link {
      display: inline-block;
      padding: 12px 28px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 700;
      text-decoration: none;
      margin-top: 12px;
      letter-spacing: 0.5px;
      border: 2px solid var(--aurora-green);
      color: var(--aurora-green);
      background: rgba(16, 185, 129, 0.1);
      transition: all 0.3s ease;
      animation: glowPulse 2.5s ease-in-out infinite;
    }
    .demo-link:hover {
      background: var(--aurora-green);
      color: #0a0a14;
      box-shadow: 0 0 24px rgba(16, 185, 129, 0.5);
    }
    @keyframes glowPulse {
      0%, 100% { box-shadow: 0 0 8px rgba(16, 185, 129, 0.2), 0 0 16px rgba(16, 185, 129, 0.1); }
      50% { box-shadow: 0 0 16px rgba(16, 185, 129, 0.4), 0 0 32px rgba(16, 185, 129, 0.2); }
    }

    /* Benchmark Comparison Table */
    .benchmark-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    .benchmark-table thead th {
      padding: 12px 10px;
      text-align: center;
      font-size: 11px;
      letter-spacing: 0.5px;
      color: var(--plasma-cyan);
      border-bottom: 2px solid rgba(6, 182, 212, 0.3);
    }
    .benchmark-table thead th:first-child {
      text-align: left;
    }
    .benchmark-table tbody td {
      padding: 12px 10px;
      text-align: center;
      border-bottom: 1px solid rgba(6, 182, 212, 0.08);
      color: var(--comet-silver);
    }
    .benchmark-table tbody td:first-child {
      text-align: left;
      color: var(--starlight-white);
      font-weight: 600;
    }
    .benchmark-table tbody tr.our-row {
      background: rgba(16, 185, 129, 0.08);
    }
    .benchmark-table tbody tr.our-row td {
      color: var(--aurora-green);
      font-weight: 700;
    }
    .benchmark-table tbody tr.our-row td:first-child {
      color: var(--aurora-green);
    }
    .benchmark-table-wrapper {
      overflow-x: auto;
    }
    .benchmark-cards-mobile {
      display: none;
    }
    .benchmark-card {
      background: rgba(15, 23, 42, 0.5);
      border: 1px solid rgba(6, 182, 212, 0.15);
      border-radius: 10px;
      padding: 16px;
      margin-bottom: 12px;
    }
    .benchmark-card.our-card {
      border-color: var(--aurora-green);
      background: rgba(16, 185, 129, 0.06);
    }
    .benchmark-card .bm-name {
      font-weight: 700;
      font-size: 14px;
      margin-bottom: 10px;
    }
    .benchmark-card .bm-scores {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
    }
    .benchmark-card .bm-score-item {
      text-align: center;
    }
    .benchmark-card .bm-score-val {
      font-weight: 800;
      font-size: 20px;
      display: block;
    }
    .benchmark-card .bm-score-lbl {
      font-size: 9px;
      color: var(--comet-silver);
      letter-spacing: 0.3px;
    }
    @media (max-width: 768px) {
      .demo-showcase {
        grid-template-columns: 1fr;
        max-width: 400px;
        margin: 0 auto 40px;
      }
      .scores-row {
        grid-template-columns: repeat(4, 1fr);
        gap: 8px;
      }
      .score-circle {
        width: 48px;
        height: 48px;
        font-size: 15px;
      }
      .benchmark-table-wrapper {
        display: none;
      }
      .benchmark-cards-mobile {
        display: block;
      }
    }
  </style>

  <div>
    <!-- HERO -->
    <section class="section-bg" style="padding: 100px 0 60px;">
      <div class="container">
        <div style="text-align: center; margin-bottom: 50px;">
          <div
            style="display: inline-flex; align-items: center; gap: 8px; background: rgba(16, 185, 129, 0.15); padding: 8px 20px; border-radius: 25px; border: 1px solid var(--aurora-green); margin-bottom: 24px;"
          >
            <span class="tech-font" style="color: var(--aurora-green); font-size: 13px;"
              ><span aria-hidden="true">🌐</span> WEB DESIGN SERVICE</span
            >
          </div>
          <h1
            class="space-font galaxy-text cosmic-glow"
            style="font-size: clamp(28px, 5vw, 48px); margin-bottom: 20px; line-height: 1.1;"
          >
            PROFESSIONAL WEBSITES FROM £299
          </h1>
          <p
            class="alien-font"
            style="font-size: clamp(16px, 3vw, 20px); color: var(--comet-silver); max-width: 700px; margin: 0 auto 30px; line-height: 1.6;"
          >
            Get your business online with a website that actually works. Fast, mobile-ready,
            found on Google — and £0 per month to host. No subscriptions, no templates, no nonsense.
          </p>
          <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
            <a href="/contact/" class="space-button space-font"><span aria-hidden="true">💬</span> Get Started</a>
            <a
              href="tel:+447971331814"
              class="space-button space-font"
              style="background: rgba(16, 185, 129, 0.2);"><span aria-hidden="true">📱</span> 07971 331814</a
            >
          </div>
        </div>
      </div>
    </section>

    <!-- TRUST SIGNALS BAR -->
    <section class="section-bg" style="padding: 40px 0;">
      <div class="container">
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; text-align: center;">
          <div class="trust-stat" style="padding: 16px; position: relative; overflow: hidden; border-radius: 10px;">
            <div class="trust-stat-sweep"></div>
            <div class="space-font" style="color: var(--aurora-green); font-size: clamp(24px, 4vw, 36px); margin-bottom: 4px; position: relative; z-index: 1;">20+</div>
            <div class="tech-font" style="color: var(--comet-silver); font-size: 11px; letter-spacing: 0.5px; position: relative; z-index: 1;">YEARS IN IT</div>
          </div>
          <div class="trust-stat" style="padding: 16px; position: relative; overflow: hidden; border-radius: 10px; animation-delay: 0.5s;">
