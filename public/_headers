# Default for every response: security headers + a "revalidate on every
# visit" cache policy for HTML. Specific asset patterns below override
# Cache-Control. CF Pages applies all matching rules but when the same
# header is set by two patterns, the MORE SPECIFIC pattern wins entirely
# for that header (not merged). That subtlety bit us in 2026-05-21 when
# /icons/* defined Cache-Control without an s-maxage override and the
# CDN held the previous favicon for the full max-age. Rules now split
# between truly-immutable (hashed URLs in /_astro/*) and stable-URL
# assets that need a short edge revalidation window so the next deploy
# propagates within a minute.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=(), payment=(), usb=(), bluetooth=(), serial=(), accelerometer=(), gyroscope=(), magnetometer=()
  X-Permitted-Cross-Domain-Policies: none
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
  Cross-Origin-Resource-Policy: same-origin
  X-DNS-Prefetch-Control: on
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com https://*.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https:; connect-src 'self' https://formspree.io https://*.cloudflareinsights.com; frame-src 'none'; object-src 'none'; base-uri 'self'; worker-src 'self'; form-action 'self' https://formspree.io; frame-ancestors 'none'; upgrade-insecure-requests
  Cache-Control: public, max-age=0, must-revalidate, s-maxage=60

/sw.js
  Cache-Control: no-cache

# Truly immutable — hashed filenames change when content changes
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Stable-URL assets — long browser cache, short edge cache so the CDN
# refetches within 60s of a deploy. Critical for files that can change
# without their URL changing (favicons, logos, icon pack).
/fonts/*
  Cache-Control: public, max-age=31536000, s-maxage=60
  Cross-Origin-Resource-Policy: cross-origin

/*.webp
  Cache-Control: public, max-age=31536000, s-maxage=60

/*.png
  Cache-Control: public, max-age=31536000, s-maxage=60

/*.jpg
  Cache-Control: public, max-age=31536000, s-maxage=60

/favicon.svg
  Cache-Control: public, max-age=31536000, s-maxage=60

/icons/*
  Cache-Control: public, max-age=31536000, s-maxage=60

/sitemap.xml
  Cache-Control: public, max-age=3600
