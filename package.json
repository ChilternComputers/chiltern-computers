{
  "name": "chiltern-computers",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && npm run postbuild:sw",
    "postbuild:sw": "node -e \"const fs=require('fs');const f='dist/sw.js';if(fs.existsSync(f)){const id=new Date().toISOString().replace(/[-:T]/g,'').slice(0,12);fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace('__BUILD_ID__',id));console.log('[postbuild] sw.js stamped with id',id);}\"",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.18.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "chrome-launcher": "^1.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-astro": "^1.5.0",
    "lighthouse": "^12.8.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
